<Page x:Class="OmniKiosk.Wpf.Views.Remittance.SenderPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:local="clr-namespace:OmniKiosk.Wpf.Converters"
      Background="{DynamicResource BackgroundBrush}">

    <Page.Resources>
        <!-- Value Converters -->
        <local:NullToVisibilityConverter x:Key="NullToVisibilityConverter"/>
        <local:InverseNullToVisibilityConverter x:Key="InverseNullToVisibilityConverter"/>
    </Page.Resources>

    <Grid>
        <!-- Notification Banner -->
        <Border x:Name="NotificationBanner"
                Background="#10B981"
                CornerRadius="12"
                Padding="24"
                Margin="40,20,40,0"
                VerticalAlignment="Top"
                Visibility="Collapsed"
                Panel.ZIndex="999">
            <Border.Effect>
                <DropShadowEffect BlurRadius="15" ShadowDepth="2" Opacity="0.3" Color="#000000"/>
            </Border.Effect>

            <Grid>
                <StackPanel Orientation="Horizontal">
                    <Border Background="#FFFFFF33" 
                            CornerRadius="20" 
                            Width="40" 
                            Height="40"
                            Margin="0,0,16,0">
                        <TextBlock x:Name="NotificationIcon"
                                 Text="✓"
                                 FontSize="24"
                                 Foreground="White"
                                 HorizontalAlignment="Center"
                                 VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock x:Name="NotificationTitle"
                                 Text="Success"
                                 FontSize="18"
                                 FontWeight="Bold"
                                 Foreground="White"
                                 Margin="0,0,0,4"/>
                        <TextBlock x:Name="NotificationMessage"
                                 Text="Action completed successfully"
                                 FontSize="15"
                                 Foreground="White"
                                 Opacity="0.95"
                                 TextWrapping="Wrap"/>
                    </StackPanel>
                </StackPanel>

                <Button Content="✕"
                        Background="Transparent"
                        Foreground="White"
                        BorderThickness="0"
                        FontSize="20"
                        Width="36"
                        Height="36"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Top"
                        Cursor="Hand"
                        Click="CloseNotification_Click">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}"
                                                CornerRadius="18">
                                            <ContentPresenter HorizontalAlignment="Center" 
                                                            VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#FFFFFF33"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </Grid>
        </Border>

        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Padding="0,0,0,100">
            <StackPanel Width="900" Margin="40,0,40,0" HorizontalAlignment="Center">

                <!-- Header Section -->
                <StackPanel Margin="0,40,0,40">
                    <TextBlock x:Name="TxtCustomerInfo" Text="👤 Customer Information"
                               FontSize="42"
                               FontWeight="Bold"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,12"/>
                    <TextBlock x:Name="TxtEnterDetails" Text="Enter your details to verify your identity"
                               FontSize="18"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               HorizontalAlignment="Center"/>
                </StackPanel>

                <!-- STEP 1: Identity Verification Panel -->
                <Border x:Name="IdentityVerificationPanel" 
                        Background="White" 
                        CornerRadius="20" 
                        Padding="40"
                        Margin="0,0,0,28"
                        Visibility="Visible">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="20" ShadowDepth="0" Opacity="0.08" Color="#000000"/>
                    </Border.Effect>

                    <StackPanel>
                        <!-- Section Header -->
                        <Grid Margin="0,0,0,36">
                            <Border Background="#EFF6FF" 
                                    CornerRadius="12" 
                                    Width="56" 
                                    Height="56"
                                    HorizontalAlignment="Left">
                                <TextBlock Text="🔐" 
                                           FontSize="28"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel Margin="72,0,0,0">
                                <TextBlock x:Name="TxtIdentityDetails" Text="Identity Details"
                                           FontSize="26"
                                           FontWeight="Bold"
                                           Foreground="#1E293B"
                                           Margin="0,0,0,6"/>
                                <TextBlock x:Name="TxtProvideDetails" Text="Please provide your identification and contact details"
                                           FontSize="16"
                                           Foreground="#64748B"/>
                            </StackPanel>
                        </Grid>

                        <!-- IC Type -->
                        <StackPanel Margin="0,0,0,24">
                            <TextBlock x:Name="LblICType"
 Text="IC/Passport Type *" 
                                       FontSize="15" 
                                       FontWeight="SemiBold"
                                       Foreground="#1E293B"
                                       Margin="0,0,0,10"/>
                            <ComboBox x:Name="CmbVerifyICType" 
                                      Height="68"
                                      FontSize="18"
                                      Foreground="#1E293B"
                                      Background="White"
                                      BorderBrush="#E2E8F0"
                                      BorderThickness="2">
                                <ComboBox.Style>
                                    <Style TargetType="ComboBox">
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="ComboBox">
                                                    <Grid>
                                                        <ToggleButton x:Name="ToggleButton"
                                                                      Grid.Column="2"
                                                                      Focusable="false"
                                                                      IsChecked="{Binding Path=IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                                                      ClickMode="Press"
                                                                      Background="White">
                                                            <ToggleButton.Template>
                                                                <ControlTemplate TargetType="ToggleButton">
                                                                    <Border Background="{TemplateBinding Background}"
                                                                            BorderBrush="#E2E8F0"
                                                                            BorderThickness="2"
                                                                            CornerRadius="14">
                                                                        <Grid>
                                                                            <ContentPresenter Content="{TemplateBinding Content}"
                                                                                              Margin="24,0"/>
                                                                            <Path x:Name="Arrow"
                                                                                  HorizontalAlignment="Right"
                                                                                  VerticalAlignment="Center"
                                                                                  Margin="0,0,24,0"
                                                                                  Data="M 0 0 L 5 5 L 10 0 Z"
                                                                                  Fill="#64748B"/>
                                                                        </Grid>
                                                                    </Border>
                                                                    <ControlTemplate.Triggers>
                                                                        <Trigger Property="IsMouseOver" Value="True">
                                                                            <Setter TargetName="Arrow" Property="Fill" Value="#2563EB"/>
                                                                        </Trigger>
                                                                    </ControlTemplate.Triggers>
                                                                </ControlTemplate>
                                                            </ToggleButton.Template>
                                                        </ToggleButton>
                                                        <ContentPresenter x:Name="ContentSite"
                                                                          IsHitTestVisible="False"
                                                                          Content="{TemplateBinding SelectionBoxItem}"
                                                                          ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                                                          ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}"
                                                                          Margin="24,0,48,0"
                                                                          VerticalAlignment="Center"
                                                                          HorizontalAlignment="Left"/>
                                                        <Popup x:Name="Popup"
                                                               Placement="Bottom"
                                                               IsOpen="{TemplateBinding IsDropDownOpen}"
                                                               AllowsTransparency="True"
                                                               Focusable="False"
                                                               PopupAnimation="Slide">
                                                            <Grid MaxHeight="300"
                                                                  MinWidth="{TemplateBinding ActualWidth}">
                                                                <Border Background="White"
                                                                        BorderBrush="#E2E8F0"
                                                                        BorderThickness="2"
                                                                        CornerRadius="14"
                                                                        Margin="0,4,0,0">
                                                                    <Border.Effect>
                                                                        <DropShadowEffect BlurRadius="16" ShadowDepth="0" Opacity="0.15" Color="#000000"/>
                                                                    </Border.Effect>
                                                                    <ScrollViewer Margin="0,6"
                                                                                  SnapsToDevicePixels="True">
                                                                        <StackPanel IsItemsHost="True"
                                                                                    KeyboardNavigation.DirectionalNavigation="Contained"/>
                                                                    </ScrollViewer>
                                                                </Border>
                                                            </Grid>
                                                        </Popup>
                                                    </Grid>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </ComboBox.Style>
                                <ComboBox.ItemContainerStyle>
                                    <Style TargetType="ComboBoxItem">
                                        <Setter Property="Padding" Value="20,14"/>
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="ComboBoxItem">
                                                    <Border x:Name="Border"
                                                            Background="Transparent"
                                                            Padding="{TemplateBinding Padding}">
                                                        <ContentPresenter/>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="Border" Property="Background" Value="#F1F5F9"/>
                                                        </Trigger>
                                                        <Trigger Property="IsSelected" Value="True">
                                                            <Setter TargetName="Border" Property="Background" Value="#EFF6FF"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </ComboBox.ItemContainerStyle>
                                <ComboBoxItem>
                                    <TextBlock Text="MyKad (IC)" FontSize="18" FontWeight="Medium" Foreground="#1E293B"/>
                                </ComboBoxItem>
                                <ComboBoxItem>
                                    <TextBlock Text="Passport" FontSize="18" FontWeight="Medium" Foreground="#1E293B"/>
                                </ComboBoxItem>
                                <!--<ComboBoxItem>
                                    <TextBlock Text="MyPR" FontSize="18" FontWeight="Medium" Foreground="#1E293B"/>
                                </ComboBoxItem>
                                <ComboBoxItem>
                                    <TextBlock Text="Police ID" FontSize="18" FontWeight="Medium" Foreground="#1E293B"/>
                                </ComboBoxItem>
                                <ComboBoxItem>
                                    <TextBlock Text="Army ID" FontSize="18" FontWeight="Medium" Foreground="#1E293B"/>
                                </ComboBoxItem>-->
                            </ComboBox>
                        </StackPanel>

                        <!-- IC Number -->
                        <StackPanel Margin="0,0,0,24">
                            <TextBlock x:Name="LblICNumber" Text="IC/Passport Number *" 
                                       FontSize="15" 
                                       FontWeight="SemiBold"
                                       Foreground="#1E293B"
                                       Margin="0,0,0,10"/>
                            <Border BorderBrush="#E2E8F0" BorderThickness="2" CornerRadius="14" Padding="20,0" Background="White">
                                <TextBox x:Name="TxtVerifyICNumber" 
                                         Height="62" 
                                         FontSize="18" 
                                         Foreground="#1E293B"
                                         BorderThickness="0" 
                                         Background="Transparent" 
                                         VerticalContentAlignment="Center"/>
                            </Border>
                        </StackPanel>

                        <!-- Mobile Number -->
                        <StackPanel  Margin="0,0,0,24">
                            <TextBlock x:Name="LblMobileNumber" Text="Mobile Number *" 
                                       FontSize="15" 
                                       FontWeight="SemiBold"
                                       Foreground="#1E293B"
                                       Margin="0,0,0,10"/>
                            <Border BorderBrush="#E2E8F0" BorderThickness="2" CornerRadius="14" Padding="20,0" Background="White">
                                <TextBox x:Name="TxtVerifyMobileNo" 
                                         Height="62" 
                                         FontSize="18" 
                                         Foreground="#1E293B"
                                         BorderThickness="0" 
                                         Background="Transparent" 
                                         VerticalContentAlignment="Center"/>
                            </Border>
                        </StackPanel>

                        <StackPanel  Margin="0,0,0,32">
                            <TextBlock x:Name="LblNationality" Text="Nationality *" 
                           FontSize="15" 
                           FontWeight="SemiBold"
                           Foreground="#1E293B"
                           Margin="0,0,0,10"/>
                            <ComboBox x:Name="CmbVerifyNationality" 
                          Height="68"
                          FontSize="18"
                          Foreground="#1E293B"
                          Background="White"
                          BorderBrush="#E2E8F0"
                          BorderThickness="2">
                                <ComboBox.Style>
                                    <Style TargetType="ComboBox">
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="ComboBox">
                                                    <Grid>
                                                        <ToggleButton x:Name="ToggleButton"
                                                                      Grid.Column="2"
                                                                      Focusable="false"
                                                                      IsChecked="{Binding Path=IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                                                      ClickMode="Press"
                                                                      Background="White">
                                                            <ToggleButton.Template>
                                                                <ControlTemplate TargetType="ToggleButton">
                                                                    <Border Background="{TemplateBinding Background}"
                                                                            BorderBrush="#E2E8F0"
                                                                            BorderThickness="2"
                                                                            CornerRadius="14">
                                                                        <Grid>
                                                                            <ContentPresenter Content="{TemplateBinding Content}"
                                                                                              Margin="24,0"/>
                                                                            <Path x:Name="Arrow"
                                                                                  HorizontalAlignment="Right"
                                                                                  VerticalAlignment="Center"
                                                                                  Margin="0,0,24,0"
                                                                                  Data="M 0 0 L 5 5 L 10 0 Z"
                                                                                  Fill="#64748B"/>
                                                                        </Grid>
                                                                    </Border>
                                                                    <ControlTemplate.Triggers>
                                                                        <Trigger Property="IsMouseOver" Value="True">
                                                                            <Setter TargetName="Arrow" Property="Fill" Value="#2563EB"/>
                                                                        </Trigger>
                                                                    </ControlTemplate.Triggers>
                                                                </ControlTemplate>
                                                            </ToggleButton.Template>
                                                        </ToggleButton>
                                                        <ContentPresenter x:Name="ContentSite"
                                                                          IsHitTestVisible="False"
                                                                          Content="{TemplateBinding SelectionBoxItem}"
                                                                          ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                                                          ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}"
                                                                          Margin="24,0,48,0"
                                                                          VerticalAlignment="Center"
                                                                          HorizontalAlignment="Left"/>
                                                        <Popup x:Name="Popup"
                                                               Placement="Bottom"
                                                               IsOpen="{TemplateBinding IsDropDownOpen}"
                                                               AllowsTransparency="True"
                                                               Focusable="False"
                                                               PopupAnimation="Slide">
                                                            <Grid MaxHeight="300"
                                                                  MinWidth="{TemplateBinding ActualWidth}">
                                                                <Border Background="White"
                                                                        BorderBrush="#E2E8F0"
                                                                        BorderThickness="2"
                                                                        CornerRadius="14"
                                                                        Margin="0,4,0,0">
                                                                    <Border.Effect>
                                                                        <DropShadowEffect BlurRadius="16" ShadowDepth="0" Opacity="0.15" Color="#000000"/>
                                                                    </Border.Effect>
                                                                    <ScrollViewer Margin="0,6"
                                                                                  SnapsToDevicePixels="True">
                                                                        <StackPanel IsItemsHost="True"
                                                                                    KeyboardNavigation.DirectionalNavigation="Contained"/>
                                                                    </ScrollViewer>
                                                                </Border>
                                                            </Grid>
                                                        </Popup>
                                                    </Grid>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </ComboBox.Style>
                                <ComboBox.ItemContainerStyle>
                                    <Style TargetType="ComboBoxItem">
                                        <Setter Property="Padding" Value="20,14"/>
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="ComboBoxItem">
                                                    <Border x:Name="Border"
                                                            Background="Transparent"
                                                            Padding="{TemplateBinding Padding}">
                                                        <ContentPresenter/>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="Border" Property="Background" Value="#F1F5F9"/>
                                                        </Trigger>
                                                        <Trigger Property="IsSelected" Value="True">
                                                            <Setter TargetName="Border" Property="Background" Value="#EFF6FF"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </ComboBox.ItemContainerStyle>
                                <ComboBoxItem IsSelected="True">
                                    <TextBlock Text="Malaysia" FontSize="18" FontWeight="Medium" Foreground="#1E293B"/>
                                </ComboBoxItem>
                                <ComboBoxItem>
                                    <TextBlock Text="Singapore" FontSize="18" FontWeight="Medium" Foreground="#1E293B"/>
                                </ComboBoxItem>
                                <ComboBoxItem>
                                    <TextBlock Text="Indonesia" FontSize="18" FontWeight="Medium" Foreground="#1E293B"/>
                                </ComboBoxItem>
                                <ComboBoxItem>
                                    <TextBlock Text="India" FontSize="18" FontWeight="Medium" Foreground="#1E293B"/>
                                </ComboBoxItem>
                                <ComboBoxItem>
                                    <TextBlock Text="Bangladesh" FontSize="18" FontWeight="Medium" Foreground="#1E293B"/>
                                </ComboBoxItem>
                                <ComboBoxItem>
                                    <TextBlock Text="Pakistan" FontSize="18" FontWeight="Medium" Foreground="#1E293B"/>
                                </ComboBoxItem>
                                <ComboBoxItem>
                                    <TextBlock Text="Phillipines" FontSize="18" FontWeight="Medium" Foreground="#1E293B"/>
                                </ComboBoxItem>
                                <ComboBoxItem>
                                    <TextBlock Text="Thailand" FontSize="18" FontWeight="Medium" Foreground="#1E293B"/>
                                </ComboBoxItem>
                                <ComboBoxItem>
                                    <TextBlock Text="Vietnam" FontSize="18" FontWeight="Medium" Foreground="#1E293B"/>
                                </ComboBoxItem>
                                <ComboBoxItem>
                                    <TextBlock Text="Other" FontSize="18" FontWeight="Medium" Foreground="#1E293B"/>
                                </ComboBoxItem>
                            </ComboBox>
                        </StackPanel>

                        <!-- Verify Button -->
                        <Button x:Name="ProceedButton"
        Height="68"
        Content="Proceed"
        FontSize="20"
        FontWeight="Bold"
        Click="VerifyIdentity_Click"
        BorderThickness="0"
        Cursor="Hand"
        Background="#2563EB"
        Foreground="White">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                CornerRadius="14"
                                BorderThickness="0">
                                                    <Border.Effect>
                                                        <DropShadowEffect BlurRadius="20" ShadowDepth="0" Opacity="0.3" Color="#2563EB"/>
                                                    </Border.Effect>
                                                    <StackPanel Orientation="Horizontal" 
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center">
                                                        <TextBlock Text="" 
                                           FontSize="24"
                                           Foreground="White"
                                           VerticalAlignment="Center"
                                           Margin="0,0,8,0"/>
                                                        <ContentPresenter HorizontalAlignment="Center"
                                                VerticalAlignment="Center"/>
                                                    </StackPanel>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="border" Property="Background" Value="#1D4ED8"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </Button.Style>
                        </Button>
                    </StackPanel>
                </Border>

                <!-- STEP 2: OTP Verification Panel -->
                <Border x:Name="OTPVerificationPanel" 
                        Background="White" 
                        CornerRadius="20" 
                        Padding="40"
                        Margin="0,0,0,28"
                        Visibility="Collapsed">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="20" ShadowDepth="0" Opacity="0.08" Color="#000000"/>
                    </Border.Effect>

                    <StackPanel>
                        <!-- Section Header -->
                        <Grid Margin="0,0,0,36">
                            <Border Background="#ECFDF5" 
                                    CornerRadius="12" 
                                    Width="56" 
                                    Height="56"
                                    HorizontalAlignment="Left">
                                <TextBlock Text="📱" 
                                           FontSize="28"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel Margin="72,0,0,0">
                                <TextBlock x:Name="TxtOTPVerification" Text="OTP Verification"
                                           FontSize="26"
                                           FontWeight="Bold"
                                           Foreground="#1E293B"
                                           Margin="0,0,0,6"/>
                                <TextBlock x:Name="TxtOTPSentMessage"
                                           Text="OTP sent to your mobile no ******9089"
                                           FontSize="16"
                                           Foreground="#64748B"/>
                            </StackPanel>
                        </Grid>

                        <!-- OTP Info Box -->
                        <Border Background="#ECFDF5" 
                                BorderBrush="#10B981"
                                BorderThickness="2"
                                CornerRadius="12" 
                                Padding="20"
                                Margin="0,0,0,32">
                            <StackPanel>
                                <TextBlock x:Name="TxtOTPInfo1" FontSize="15"
                                           Foreground="#047857"
                                           TextWrapping="Wrap"
                                           Margin="0,0,0,8">
                                    <Run Text="✓" FontWeight="Bold"/>
                                    <Run Text="A 6-digit One-Time Password has been sent to your registered mobile number."/>
                                </TextBlock>
                                <TextBlock x:Name="TxtOTPInfo2" Text="Please enter the OTP to proceed with your transaction."
                                           FontSize="14"
                                           Foreground="#059669"/>
                            </StackPanel>
                        </Border>

                        <!-- OTP Input -->
                        <StackPanel Margin="0,0,0,32">
                            <TextBlock x:Name="LblEnterOTP" Text="Enter 6-Digit OTP *" 
                                       FontSize="15" 
                                       FontWeight="SemiBold"
                                       Foreground="#1E293B"
                                       Margin="0,0,0,10"/>
                            <Border BorderBrush="#10B981" BorderThickness="3" CornerRadius="14" Padding="20,0" Background="White">
                                <TextBox x:Name="TxtOTP" 
                                         Height="72" 
                                         FontSize="32" 
                                         FontWeight="Bold"
                                         Foreground="#1E293B"
                                         BorderThickness="0" 
                                         Background="Transparent" 
                                         VerticalContentAlignment="Center"
                                         HorizontalContentAlignment="Center"
                                         MaxLength="6"
                                         TextAlignment="Center"/>
                            </Border>
                        </StackPanel>

                        <!-- Verify OTP Button -->
                        <Button x:Name="VerifyOTPButton"
        Height="68"
        Content="Verify OTP"
        FontSize="20"
        FontWeight="Bold"
        Click="VerifyOTP_Click"
        BorderThickness="0"
        Cursor="Hand"
        Background="#10B981"
        Foreground="White"
        Margin="0,0,0,16">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                CornerRadius="14"
                                BorderThickness="0">
                                                    <Border.Effect>
                                                        <DropShadowEffect BlurRadius="20" ShadowDepth="0" Opacity="0.3" Color="#10B981"/>
                                                    </Border.Effect>
                                                    <StackPanel Orientation="Horizontal" 
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center">
                                                        <TextBlock Text="✓ " 
                                           FontSize="24"
                                           Foreground="White"
                                           VerticalAlignment="Center"/>
                                                        <ContentPresenter HorizontalAlignment="Center"
                                                VerticalAlignment="Center"/>
                                                    </StackPanel>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="border" Property="Background" Value="#059669"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </Button.Style>
                        </Button>
                        <!--<Button Height="68"
                              Click="VerifyOTP_Click"
                              BorderThickness="0"
                              Cursor="Hand"
                              Margin="0,0,0,16">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="border"
                                                        Background="#10B981"
                                                        CornerRadius="14"
                                                        BorderThickness="0">
                                                    <Border.Effect>
                                                        <DropShadowEffect BlurRadius="20" ShadowDepth="0" Opacity="0.3" Color="#10B981"/>
                                                    </Border.Effect>
                                                    <StackPanel Orientation="Horizontal" 
                                                                HorizontalAlignment="Center"
                                                                VerticalAlignment="Center">
                                                        <TextBlock Text="✓ " 
                                                                   FontSize="24"
                                                                   VerticalAlignment="Center"
                                                                   Foreground="White"/>
                                                        <TextBlock x:Name="TxtVerifyOTP" Text="Verify OTP" 
                                                                   FontSize="20" 
                                                                   FontWeight="Bold"
                                                                   Foreground="White"
                                                                   VerticalAlignment="Center"/>
                                                    </StackPanel>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="border" Property="Background" Value="#059669"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </Button.Style>
                        </Button>-->

                        <!-- Resend OTP -->
                        <TextBlock HorizontalAlignment="Center">
                            <Run x:Name="TxtDidntReceive" Text="Didn't receive the OTP?" Foreground="#64748B" FontSize="14"/>
                            <Hyperlink Click="ResendOTP_Click">
                                <Run x:Name="TxtResendOTP" Text="Resend OTP" FontWeight="Bold" Foreground="#2563EB" FontSize="14"/>
                            </Hyperlink>
                        </TextBlock>
                    </StackPanel>
                </Border>

                <!-- STEP 3: Create New Sender Profile Panel -->
                <Border x:Name="CreateSenderPanel" 
        Background="White" 
        CornerRadius="20" 
        Padding="36"
        Margin="0,0,0,28"
        Visibility="Collapsed">
                    <Border.Effect>
