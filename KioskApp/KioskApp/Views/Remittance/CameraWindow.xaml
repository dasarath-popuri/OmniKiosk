<Window x:Class="OmniKiosk.Wpf.Views.Remittance.CameraWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Capture Photo" 
        Height="750" 
        Width="950"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        Background="Transparent"
        AllowsTransparency="True"
        ResizeMode="NoResize">

    <Border Background="White"
            CornerRadius="90"
            Padding="0" Margin="10"
            BorderThickness="0">
        <Border.Effect>
            <DropShadowEffect BlurRadius="30" ShadowDepth="0" Opacity="0.4" Color="#000000"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="80"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Border Grid.Row="0" 
                    Background="#2563EB" 
                    CornerRadius="20,20,0,0"
                    Padding="30,0">
                <Grid>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="📷" FontSize="32" Margin="0,0,16,0"/>
                        <TextBlock Text="Capture Customer Photo" 
                                 FontSize="24" 
                                 FontWeight="Bold"
                                 Foreground="White"
                                 VerticalAlignment="Center"/>
                    </StackPanel>

                    <Button Content="✕"
                            FontSize="32"
                            FontWeight="Bold"
                            Foreground="White"
                            Background="Transparent"
                            BorderThickness="0"
                            Width="50"
                            Height="50"
                            HorizontalAlignment="Right"
                            Cursor="Hand"
                            Click="Close_Click">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}"
                                                    CornerRadius="25">
                                                <ContentPresenter HorizontalAlignment="Center" 
                                                                VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#FFFFFF33"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </Grid>
            </Border>

            <!-- Camera Preview -->
            <Grid Grid.Row="1" Margin="30">
                <Border x:Name="VideoPreview"
            Background="Black"
            CornerRadius="16"
            ClipToBounds="True">
                    <Grid>
                        <!-- Video Player - Make sure it's on top -->
                        <Image x:Name="VideoPlayer" 
                   Stretch="Uniform"
                   Panel.ZIndex="1"/>

                        <!-- Captured Image Preview -->
                        <Image x:Name="CapturedImage" 
                   Stretch="Uniform"
                   Visibility="Collapsed"
                   Panel.ZIndex="2"/>

                        <!-- Face Guide Overlay -->
                        <Canvas x:Name="FaceGuide" Panel.ZIndex="3">
                            <Ellipse Width="320" Height="420"
                       Stroke="White"
                       StrokeThickness="4"
                       StrokeDashArray="8,4"
                       Canvas.Left="285"
                       Canvas.Top="90"
                       Opacity="0.8">
                                <Ellipse.Effect>
                                    <DropShadowEffect BlurRadius="10" Color="White" Opacity="0.6"/>
                                </Ellipse.Effect>
                            </Ellipse>

                            <!-- Guide Text -->
                            <TextBlock Text="Position face within the oval"
                         Canvas.Left="320"
                         Canvas.Top="530"
                         FontSize="18"
                         FontWeight="SemiBold"
                         Foreground="White"
                         HorizontalAlignment="Center">
                                <TextBlock.Effect>
                                    <DropShadowEffect BlurRadius="8" Color="Black" Opacity="0.8"/>
                                </TextBlock.Effect>
                            </TextBlock>
                        </Canvas>

                        <!-- Loading Indicator -->
                        <Border x:Name="LoadingPanel"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Center"
                    Visibility="Visible"
                    Panel.ZIndex="4"
                    Background="Transparent">
                            <StackPanel>
                                <TextBlock Text="📹" 
                             FontSize="64" 
                             HorizontalAlignment="Center"
                             Margin="0,0,0,20"/>
                                <TextBlock Text="Initializing camera..." 
                             FontSize="20"
                             Foreground="White"
                             FontWeight="SemiBold"
                             HorizontalAlignment="Center"/>
                                <TextBlock x:Name="LoadingMessage"
                             Text="Please wait..."
                             FontSize="16"
                             Foreground="White"
                             Opacity="0.8"
                             HorizontalAlignment="Center"
                             Margin="0,10,0,0"/>
                            </StackPanel>
                        </Border>

                        <!-- Camera Selection Panel -->
                        <Border x:Name="CameraSelectionPanel"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Center"
                    Visibility="Collapsed"
                    Background="#AA000000"
                    Padding="40"
                    MaxWidth="500"
                    CornerRadius="12"
                    Panel.ZIndex="5">
                            <StackPanel>
                                <TextBlock Text="📹 Multiple Cameras Detected" 
                             FontSize="22" 
                             FontWeight="Bold"
                             Foreground="White"
                             HorizontalAlignment="Center"
                             Margin="0,0,0,20"/>

                                <TextBlock Text="Please select a camera:" 
                             FontSize="16"
                             Foreground="White"
                             HorizontalAlignment="Center"
                             Margin="0,0,0,20"/>

                                <ListBox x:Name="CameraListBox"
                           Background="White"
                           BorderThickness="0"
                           MaxHeight="250"
                           FontSize="16"
                           Padding="10"
                           SelectionChanged="CameraListBox_SelectionChanged">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Border Padding="15,10" 
                                      Background="Transparent"
                                      BorderThickness="0,0,0,1"
                                      BorderBrush="#EEEEEE">
                                                <TextBlock Text="{Binding}" 
                                             FontSize="16"
                                             Foreground="#333333"/>
                                            </Border>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>
            </Grid>
            <!-- Controls -->
            <Border Grid.Row="2" 
                    Background="#F9FAFB"
                    CornerRadius="0,0,20,20"
                    Padding="30,20">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="20"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="20"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Cancel Button -->
                    <Button x:Name="CancelButton"
                            Grid.Column="0"
                            Content="✕ Cancel"
                            Height="70"
                            FontSize="20"
                            FontWeight="Bold"
                            Background="#6B7280"
                            Foreground="White"
                            BorderThickness="0"
                            Cursor="Hand"
                            Click="Close_Click">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}"
                                                    CornerRadius="12">
                                                <ContentPresenter HorizontalAlignment="Center" 
                                                                VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#4B5563"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>

                    <!-- Capture Button -->
                    <Button x:Name="CaptureButton"
                            Grid.Column="2"
                            Content="📸 Capture"
                            Height="70"
                            FontSize="22"
                            FontWeight="Bold"
                            Background="#10B981"
                            Foreground="White"
                            BorderThickness="0"
                            Cursor="Hand"
                            Click="Capture_Click">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}"
                                                    CornerRadius="12">
                                                <ContentPresenter HorizontalAlignment="Center" 
                                                                VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#059669"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>

                    <!-- Use Photo Button -->
                    <Button x:Name="UsePhotoButton"
                            Grid.Column="4"
                            Content="✓ Use Photo"
                            Height="70"
                            FontSize="22"
                            FontWeight="Bold"
                            Background="#2563EB"
                            Foreground="White"
                            BorderThickness="0"
                            Cursor="Hand"
                            Visibility="Collapsed"
                            Click="UsePhoto_Click">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}"
                                                    CornerRadius="12">
                                                <ContentPresenter HorizontalAlignment="Center" 
                                                                VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#1D4ED8"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>

                    <!-- Retake Button -->
                    <Button x:Name="RetakeButton"
                            Grid.Column="4"
                            Content="🔄 Retake"
                            Height="70"
                            FontSize="22"
                            FontWeight="Bold"
                            Background="#F59E0B"
                            Foreground="White"
                            BorderThickness="0"
                            Cursor="Hand"
                            Visibility="Collapsed"
                            Click="Retake_Click">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}"
                                                    CornerRadius="12">
                                                <ContentPresenter HorizontalAlignment="Center" 
                                                                VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#D97706"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>