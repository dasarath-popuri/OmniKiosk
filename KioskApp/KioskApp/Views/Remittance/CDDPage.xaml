<Page x:Class="OmniKiosk.Wpf.Views.Remittance.CDDPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="{DynamicResource BackgroundBrush}">

    <Grid>
        <!-- Notification Banner -->
        <Border x:Name="NotificationBanner"
                Background="#10B981"
                CornerRadius="12"
                Padding="24"
                Margin="40,20,40,0"
                VerticalAlignment="Top"
                Visibility="Collapsed"
                Panel.ZIndex="999">
            <Border.Effect>
                <DropShadowEffect BlurRadius="15" ShadowDepth="2" Opacity="0.3" Color="#000000"/>
            </Border.Effect>

            <Grid>
                <StackPanel Orientation="Horizontal">
                    <Border Background="#FFFFFF33" 
                            CornerRadius="20" 
                            Width="40" 
                            Height="40"
                            Margin="0,0,16,0">
                        <TextBlock x:Name="NotificationIcon"
                                 Text="✓"
                                 FontSize="24"
                                 Foreground="White"
                                 HorizontalAlignment="Center"
                                 VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock x:Name="NotificationTitle"
                                 Text="Success"
                                 FontSize="18"
                                 FontWeight="Bold"
                                 Foreground="White"
                                 Margin="0,0,0,4"/>
                        <TextBlock x:Name="NotificationMessage"
                                 Text="Action completed successfully"
                                 FontSize="15"
                                 Foreground="White"
                                 Opacity="0.95"
                                 TextWrapping="Wrap"/>
                    </StackPanel>
                </StackPanel>

                <Button Content="✕"
                        Background="Transparent"
                        Foreground="White"
                        BorderThickness="0"
                        FontSize="20"
                        Width="36"
                        Height="36"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Top"
                        Cursor="Hand"
                        Click="CloseNotification_Click">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}"
                                                CornerRadius="18">
                                            <ContentPresenter HorizontalAlignment="Center" 
                                                            VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#FFFFFF33"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </Grid>
        </Border>

        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Padding="0,0,0,100">
            <StackPanel Width="1000" Margin="40,30,40,40" HorizontalAlignment="Center">

                <!-- Header Section -->
                <StackPanel Margin="0,0,0,40">
                    <TextBlock  x:Name="TxtSendMoney" Text="💸 Send Money"
                               FontSize="42"
                               FontWeight="Bold"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,12"/>
                    <TextBlock  x:Name="TxtSubtitle" Text="Fast, secure, and transparent international money transfers"
                               FontSize="18"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               HorizontalAlignment="Center"/>
                </StackPanel>

                <!-- Step 1: Destination Selection -->
                <Border Background="White" 
                        CornerRadius="20" 
                        Padding="36"
                        Margin="0,0,0,24">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="20" ShadowDepth="0" Opacity="0.08" Color="#000000"/>
                    </Border.Effect>

                    <StackPanel>
                        <!-- Section Header -->
                        <Grid Margin="0,0,0,24">
                            <Border Background="#EFF6FF" 
                                    CornerRadius="12" 
                                    Width="48" 
                                    Height="48"
                                    HorizontalAlignment="Left">
                                <TextBlock Text="1" 
                                           FontSize="24" 
                                           FontWeight="Bold"
                                           Foreground="#2563EB"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel Margin="64,0,0,0">
                                <TextBlock x:Name="TxtSelectDestination" Text="Select Destination"
                                           FontSize="24"
                                           FontWeight="Bold"
                                           Foreground="#1E293B"
                                           Margin="0,0,0,4"/>
                                <TextBlock x:Name="TxtChooseCountry" Text="Choose the country where your recipient will receive money"
                                           FontSize="15"
                                           Foreground="#64748B"/>
                            </StackPanel>
                        </Grid>

                        <!-- Country Selector -->
                        <ComboBox x:Name="CountryComboBox"
                                  Height="64"
                                  FontSize="18"
                                  Foreground="#1E293B"
                                  Background="White"
                                  BorderBrush="#E2E8F0"
                                  BorderThickness="2"
                                  SelectedValuePath="CountryCode"
                                  SelectionChanged="CountryComboBox_SelectionChanged">
                            <ComboBox.Style>
                                <Style TargetType="ComboBox">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="ComboBox">
                                                <Grid>
                                                    <ToggleButton x:Name="ToggleButton"
                                                                  Grid.Column="2"
                                                                  Focusable="false"
                                                                  IsChecked="{Binding Path=IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                                                  ClickMode="Press"
                                                                  Background="White">
                                                        <ToggleButton.Template>
                                                            <ControlTemplate TargetType="ToggleButton">
                                                                <Border Background="{TemplateBinding Background}"
                                                                        BorderBrush="#E2E8F0"
                                                                        BorderThickness="2"
                                                                        CornerRadius="12">
                                                                    <Grid>
                                                                        <ContentPresenter Content="{TemplateBinding Content}"
                                                                                          Margin="20,0"/>
                                                                        <Path x:Name="Arrow"
                                                                              HorizontalAlignment="Right"
                                                                              VerticalAlignment="Center"
                                                                              Margin="0,0,20,0"
                                                                              Data="M 0 0 L 4 4 L 8 0 Z"
                                                                              Fill="#64748B"/>
                                                                    </Grid>
                                                                </Border>
                                                                <ControlTemplate.Triggers>
                                                                    <Trigger Property="IsMouseOver" Value="True">
                                                                        <Setter TargetName="Arrow" Property="Fill" Value="#2563EB"/>
                                                                    </Trigger>
                                                                </ControlTemplate.Triggers>
                                                            </ControlTemplate>
                                                        </ToggleButton.Template>
                                                    </ToggleButton>
                                                    <ContentPresenter x:Name="ContentSite"
                                                                      IsHitTestVisible="False"
                                                                      Content="{TemplateBinding SelectionBoxItem}"
                                                                      ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                                                      ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}"
                                                                      Margin="20,0,40,0"
                                                                      VerticalAlignment="Center"
                                                                      HorizontalAlignment="Left"/>
                                                    <Popup x:Name="Popup"
                                                           Placement="Bottom"
                                                           IsOpen="{TemplateBinding IsDropDownOpen}"
                                                           AllowsTransparency="True"
                                                           Focusable="False"
                                                           PopupAnimation="Slide">
                                                        <Grid MaxHeight="300"
                                                              MinWidth="{TemplateBinding ActualWidth}">
                                                            <Border Background="White"
                                                                    BorderBrush="#E2E8F0"
                                                                    BorderThickness="2"
                                                                    CornerRadius="12"
                                                                    Margin="0,4,0,0">
                                                                <Border.Effect>
                                                                    <DropShadowEffect BlurRadius="16" ShadowDepth="0" Opacity="0.15" Color="#000000"/>
                                                                </Border.Effect>
                                                                <ScrollViewer Margin="0,4"
                                                                              SnapsToDevicePixels="True">
                                                                    <StackPanel IsItemsHost="True"
                                                                                KeyboardNavigation.DirectionalNavigation="Contained"/>
                                                                </ScrollViewer>
                                                            </Border>
                                                        </Grid>
                                                    </Popup>
                                                </Grid>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </ComboBox.Style>
                            <ComboBox.ItemContainerStyle>
                                <Style TargetType="ComboBoxItem">
                                    <Setter Property="Padding" Value="16,12"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="ComboBoxItem">
                                                <Border x:Name="Border"
                                                        Background="Transparent"
                                                        Padding="{TemplateBinding Padding}">
                                                    <ContentPresenter/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="Border" Property="Background" Value="#F1F5F9"/>
                                                    </Trigger>
                                                    <Trigger Property="IsSelected" Value="True">
                                                        <Setter TargetName="Border" Property="Background" Value="#EFF6FF"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </ComboBox.ItemContainerStyle>
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal">
                                        <Border Background="#EFF6FF" 
                                                CornerRadius="8" 
                                                Padding="8,4"
                                                Margin="0,0,12,0">
                                            <TextBlock Text="{Binding Currency}" 
                                                       FontSize="14"
                                                       FontWeight="SemiBold"
                                                       Foreground="#2563EB"/>
                                        </Border>
                                        <TextBlock Text="{Binding CountryName}" 
                                                   FontSize="17" 
                                                   FontWeight="Medium"
                                                   Foreground="#1E293B"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                    </StackPanel>
                </Border>

                <!-- Step 2: Amount Input -->
                <Border Background="White" 
                        CornerRadius="20" 
                        Padding="36"
                        Margin="0,0,0,24">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="20" ShadowDepth="0" Opacity="0.08" Color="#000000"/>
                    </Border.Effect>

                    <StackPanel>
                        <!-- Section Header -->
                        <Grid Margin="0,0,0,24">
                            <Border Background="#ECFDF5" 
                                    CornerRadius="12" 
                                    Width="48" 
                                    Height="48"
                                    HorizontalAlignment="Left">
                                <TextBlock Text="2" 
                                           FontSize="24" 
                                           FontWeight="Bold"
                                           Foreground="#10B981"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel Margin="64,0,0,0">
                                <TextBlock x:Name="TxtSendAmount" Text="Send Amount"
                                           FontSize="24"
                                           FontWeight="Bold"
                                           Foreground="#1E293B"
                                           Margin="0,0,0,4"/>
                                <TextBlock x:Name="TxtHowMuch" Text="How much would you like to send?"
                                           FontSize="15"
                                           Foreground="#64748B"/>
                            </StackPanel>
                        </Grid>

                        <!-- Amount Input Field -->
                        <Border BorderBrush="#E2E8F0" 
                                BorderThickness="2" 
                                CornerRadius="12" 
                                Background="#FAFBFC"
                                Padding="20,0"
                                Margin="0,0,0,20">
                            <Grid Height="80">
                                <TextBlock Text="MYR"
                                           FontSize="20"
                                           FontWeight="Bold"
                                           Foreground="#64748B"
                                           VerticalAlignment="Center"
                                           HorizontalAlignment="Left"/>
                                <TextBox x:Name="SendAmountTextBox"
                                         FontSize="32"
                                         FontWeight="Bold"
                                         Foreground="#1E293B"
                                         BorderThickness="0"
                                         Background="Transparent"
                                         PreviewTextInput="SendAmountTextBox_PreviewTextInput"
                                         TextChanged="SendAmountTextBox_TextChanged"
                                         MaxLength="10"
                                         VerticalContentAlignment="Center"
                                         Padding="60,0,0,0"
                                         TextAlignment="Left">
                                    <TextBox.InputScope>
                                        <InputScope>
                                            <InputScope.Names>
                                                <InputScopeName NameValue="Number" />
                                            </InputScope.Names>
                                        </InputScope>
                                    </TextBox.InputScope>
                                </TextBox>
                            </Grid>
                        </Border>

                        <!-- Delivery Method - UPDATED TO MATCH COUNTRY SELECTOR -->
                        <StackPanel Margin="0,0,0,0">
                            <TextBlock x:Name="TxtDeliveryMethod" Text="Delivery Method" 
                                       FontSize="17"
                                       FontWeight="SemiBold"
                                       Foreground="#1E293B"
                                       Margin="0,0,0,12"/>

                            <!-- Delivery Method ComboBox with Same Style as Country -->
                            <ComboBox x:Name="CmbDeliveryMethod"
                                      Height="64"
                                      FontSize="17"
                                      Foreground="#1E293B"
                                      Background="White"
                                      BorderBrush="#E2E8F0"
                                      BorderThickness="2">
                                <ComboBox.Style>
                                    <Style TargetType="ComboBox">
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="ComboBox">
                                                    <Grid>
                                                        <ToggleButton x:Name="ToggleButton"
                                                                      Grid.Column="2"
                                                                      Focusable="false"
                                                                      IsChecked="{Binding Path=IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                                                      ClickMode="Press"
                                                                      Background="White">
                                                            <ToggleButton.Template>
                                                                <ControlTemplate TargetType="ToggleButton">
                                                                    <Border Background="{TemplateBinding Background}"
                                                                            BorderBrush="#E2E8F0"
                                                                            BorderThickness="2"
                                                                            CornerRadius="12">
                                                                        <Grid>
                                                                            <ContentPresenter Content="{TemplateBinding Content}"
                                                                                              Margin="20,0"/>
                                                                            <Path x:Name="Arrow"
                                                                                  HorizontalAlignment="Right"
                                                                                  VerticalAlignment="Center"
                                                                                  Margin="0,0,20,0"
                                                                                  Data="M 0 0 L 4 4 L 8 0 Z"
                                                                                  Fill="#64748B"/>
                                                                        </Grid>
                                                                    </Border>
                                                                    <ControlTemplate.Triggers>
                                                                        <Trigger Property="IsMouseOver" Value="True">
                                                                            <Setter TargetName="Arrow" Property="Fill" Value="#10B981"/>
                                                                        </Trigger>
                                                                    </ControlTemplate.Triggers>
                                                                </ControlTemplate>
                                                            </ToggleButton.Template>
                                                        </ToggleButton>
                                                        <ContentPresenter x:Name="ContentSite"
                                                                          IsHitTestVisible="False"
                                                                          Content="{TemplateBinding SelectionBoxItem}"
                                                                          ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                                                          ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}"
                                                                          Margin="20,0,40,0"
                                                                          VerticalAlignment="Center"
                                                                          HorizontalAlignment="Left"/>
                                                        <Popup x:Name="Popup"
                                                               Placement="Bottom"
                                                               IsOpen="{TemplateBinding IsDropDownOpen}"
                                                               AllowsTransparency="True"
                                                               Focusable="False"
                                                               PopupAnimation="Slide">
                                                            <Grid MaxHeight="300"
                                                                  MinWidth="{TemplateBinding ActualWidth}">
                                                                <Border Background="White"
                                                                        BorderBrush="#E2E8F0"
                                                                        BorderThickness="2"
                                                                        CornerRadius="12"
                                                                        Margin="0,4,0,0">
                                                                    <Border.Effect>
                                                                        <DropShadowEffect BlurRadius="16" ShadowDepth="0" Opacity="0.15" Color="#000000"/>
                                                                    </Border.Effect>
                                                                    <ScrollViewer Margin="0,4"
                                                                                  SnapsToDevicePixels="True">
                                                                        <StackPanel IsItemsHost="True"
                                                                                    KeyboardNavigation.DirectionalNavigation="Contained"/>
                                                                    </ScrollViewer>
                                                                </Border>
                                                            </Grid>
                                                        </Popup>
                                                    </Grid>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </ComboBox.Style>
                                <ComboBox.ItemContainerStyle>
                                    <Style TargetType="ComboBoxItem">
                                        <Setter Property="Padding" Value="16,12"/>
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="ComboBoxItem">
                                                    <Border x:Name="Border"
                                                            Background="Transparent"
                                                            Padding="{TemplateBinding Padding}">
                                                        <ContentPresenter/>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="Border" Property="Background" Value="#F1F5F9"/>
                                                        </Trigger>
                                                        <Trigger Property="IsSelected" Value="True">
                                                            <Setter TargetName="Border" Property="Background" Value="#ECFDF5"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </ComboBox.ItemContainerStyle>
                            </ComboBox>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Step 3: Transaction Summary -->
                <Border x:Name="TransactionSummaryPanel"
                        Background="White" 
                        CornerRadius="20" 
                        Padding="36"
                        Margin="0,0,0,32">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="20" ShadowDepth="0" Opacity="0.08" Color="#000000"/>
                    </Border.Effect>

                    <StackPanel>
                        <!-- Section Header -->
                        <Grid Margin="0,0,0,28">
                            <Border Background="#FEF3C7" 
                                    CornerRadius="12" 
                                    Width="48" 
                                    Height="48"
                                    HorizontalAlignment="Left">
                                <TextBlock Text="3" 
                                           FontSize="24" 
                                           FontWeight="Bold"
                                           Foreground="#F59E0B"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel Margin="64,0,0,0">
                                <TextBlock x:Name="TxtRemittanceDetails" Text="Remittance Details"
                                           FontSize="24"
                                           FontWeight="Bold"
                                           Foreground="#1E293B"
                                           Margin="0,0,0,4"/>
                                <TextBlock x:Name="TxtReviewDetails" Text="Review the details of your transfer"
                                           FontSize="15"
                                           Foreground="#64748B"/>
                            </StackPanel>
                        </Grid>

                        <!-- Exchange Rate Card -->
                        <Border Background="#F8FAFC" 
                                CornerRadius="12" 
                                Padding="20"
                                Margin="0,0,0,16">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <Border Background="#EFF6FF" 
                                        CornerRadius="10" 
                                        Width="44" 
                                        Height="44"
                                        Margin="0,0,16,0">
                                    <TextBlock Text="💱" 
                                               FontSize="22"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                                </Border>

                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock x:Name="TxtExchangeRate" Text="Exchange Rate"
                                               FontSize="14"
                                               Foreground="#64748B"
                                               Margin="0,0,0,4"/>
                                    <TextBlock x:Name="ExchangeRateDisplay"
                                               Text="Select a country first"
                                               FontSize="18"
                                               FontWeight="Bold"
                                               Foreground="#1E293B"/>
                                </StackPanel>

                                <Border Grid.Column="2"
                                        Background="#10B98133"
                                        CornerRadius="8"
                                        Padding="12,6"
                                        VerticalAlignment="Center">
                                    <TextBlock x:Name="TxtLiveRate" Text="Live Rate"
                                               FontSize="13"
                                               FontWeight="SemiBold"
                                               Foreground="#10B981"/>
                                </Border>
                            </Grid>
                        </Border>

                        <!-- Service Fee Card -->
                        <Border Background="#F8FAFC" 
                                CornerRadius="12" 
                                Padding="20"
                                Margin="0,0,0,16">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <Border Background="#FEF3C7" 
                                        CornerRadius="10" 
                                        Width="44" 
                                        Height="44"
                                        Margin="0,0,16,0">
                                    <TextBlock Text="💳" 
                                               FontSize="22"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                                </Border>

                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock x:Name="TxtServiceFee" Text="Service Fee"
                                               FontSize="14"
                                               Foreground="#64748B"
                                               Margin="0,0,0,4"/>
                                    <TextBlock x:Name="ServiceFeeDisplay"
                                               Text="MYR 0.00"
                                               FontSize="18"
                                               FontWeight="Bold"
                                               Foreground="#1E293B"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- Divider -->
                        <Border Height="2" 
                                Background="#E2E8F0" 
                                Margin="0,8,0,16"
                                CornerRadius="1"/>

                        <!-- Recipient Gets - Highlighted -->
                        <Border  
                                CornerRadius="16" 
                                Padding="24">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#ECFDF5" Offset="0"/>
                                    <GradientStop Color="#D1FAE5" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <Border Background="#10B981" 
                                        CornerRadius="12" 
                                        Width="52" 
                                        Height="52"
                                        Margin="0,0,20,0">
                                    <TextBlock Text="✓" 
                                               FontSize="28"
                                               FontWeight="Bold"
                                               Foreground="White"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                                </Border>

                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock x:Name="TxtBeneficiaryReceives" Text="Beneficiary Receives"
                                               FontSize="15"
                                               Foreground="#059669"
                                               FontWeight="SemiBold"
                                               Margin="0,0,0,6"/>
                                    <TextBlock x:Name="BeneficiaryAmountDisplay"
                                               Text="0.00"
                                               FontSize="32"
                                               FontWeight="Bold"
                                               Foreground="#10B981"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- Continue Button -->
                <Button x:Name="ContinueButton"
            Grid.Column="2"
            Content="Next"
            Height="60"
            FontSize="19"
            FontWeight="Bold"
            IsEnabled="True"
            Click="Continue_Click"
            BorderThickness="0"
            Cursor="Hand"
            Background="#2563EB"
            Foreground="White">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="border"
                                    Background="{TemplateBinding Background}"
                                    CornerRadius="12"
                                    BorderThickness="0">
                                            <Border.Effect>
                                                <DropShadowEffect BlurRadius="20" ShadowDepth="0" Opacity="0.3" Color="#2563EB"/>
                                            </Border.Effect>
                                            <StackPanel Orientation="Horizontal" 
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center">
                                                <ContentPresenter HorizontalAlignment="Center" 
                                                    VerticalAlignment="Center"/>
                                                <TextBlock Text="" 
                                               FontSize="22" 
                                               FontWeight="Bold"
                                               Foreground="White"
                                               Margin="8,0,0,0"
                                               VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsEnabled" Value="False">
                                                <Setter TargetName="border" Property="Background" Value="#CBD5E1"/>
                                                <Setter TargetName="border" Property="Effect" Value="{x:Null}"/>
                                            </Trigger>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="border" Property="Background" Value="#1D4ED8"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>


                <!-- Trust Indicators -->
                <Grid Margin="0,32,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                        <TextBlock Text="🔒" FontSize="28" Foreground="{DynamicResource TextPrimaryBrush}" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                        <TextBlock x:Name="TxtSecureTransfer"
               Text="Secure Transfer" 
               FontSize="14" 
               FontWeight="SemiBold"
               Foreground="{DynamicResource TextPrimaryBrush}"
               HorizontalAlignment="Center"
               Margin="0,0,0,4"/>
                        <TextBlock x:Name="TxtBankLevel"
               Text="Bank-level encryption" 
               FontSize="12" 
               Foreground="{DynamicResource TextSecondaryBrush}"
               HorizontalAlignment="Center"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                        <TextBlock Text="⚡" FontSize="28" Foreground="{DynamicResource TextPrimaryBrush}" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                        <TextBlock x:Name="TxtFastProcessing"
               Text="Fast Processing" 
               FontSize="14" 
               FontWeight="SemiBold"
               Foreground="{DynamicResource TextPrimaryBrush}"
               HorizontalAlignment="Center"
               Margin="0,0,0,4"/>
                        <TextBlock x:Name="TxtWithinMinutes"
               Text="Within minutes" 
               FontSize="12" 
               Foreground="{DynamicResource TextSecondaryBrush}"
               HorizontalAlignment="Center"/>
                    </StackPanel>

                    <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                        <TextBlock Text="💰" FontSize="28" Foreground="{DynamicResource TextPrimaryBrush}" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                        <TextBlock x:Name="TxtBestRates"
               Text="Best Rates" 
               FontSize="14" 
               FontWeight="SemiBold"
               Foreground="{DynamicResource TextPrimaryBrush}"
               HorizontalAlignment="Center"
               Margin="0,0,0,4"/>
                        <TextBlock x:Name="TxtCompetitive"
