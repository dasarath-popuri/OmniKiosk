<Page x:Class="OmniKiosk.Wpf.Views.Remittance.SummaryPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="{DynamicResource BackgroundBrush}"
      Unloaded="Page_Unloaded">

    <Grid>
        <!-- Notification Banner -->
        <Border x:Name="NotificationBanner"
                Background="#10B981"
                CornerRadius="12"
                Padding="24"
                Margin="40,20,40,0"
                VerticalAlignment="Top"
                Visibility="Collapsed"
                Panel.ZIndex="999">
            <Border.Effect>
                <DropShadowEffect BlurRadius="15" ShadowDepth="2" Opacity="0.3" Color="#000000"/>
            </Border.Effect>

            <Grid>
                <StackPanel Orientation="Horizontal">
                    <Border Background="#FFFFFF33" 
                            CornerRadius="20" 
                            Width="40" 
                            Height="40"
                            Margin="0,0,16,0">
                        <TextBlock x:Name="NotificationIcon"
                                 Text="✓"
                                 FontSize="24"
                                 Foreground="White"
                                 HorizontalAlignment="Center"
                                 VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock x:Name="NotificationTitle"
                                 Text="Success"
                                 FontSize="18"
                                 FontWeight="Bold"
                                 Foreground="White"
                                 Margin="0,0,0,4"/>
                        <TextBlock x:Name="NotificationMessage"
                                 Text="Action completed successfully"
                                 FontSize="15"
                                 Foreground="White"
                                 Opacity="0.95"
                                 TextWrapping="Wrap"/>
                    </StackPanel>
                </StackPanel>

                <Button Content="✕"
                        Background="Transparent"
                        Foreground="White"
                        BorderThickness="0"
                        FontSize="20"
                        Width="36"
                        Height="36"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Top"
                        Cursor="Hand"
                        Click="CloseNotification_Click">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}"
                                                CornerRadius="18">
                                            <ContentPresenter HorizontalAlignment="Center" 
                                                            VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#FFFFFF33"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </Grid>
        </Border>

        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Padding="0,0,0,100">
            <StackPanel Width="1000" Margin="40,20,40,40" HorizontalAlignment="Center">

                <!-- Header -->
                <StackPanel Margin="0,0,0,32" HorizontalAlignment="Center">
                    <TextBlock x:Name="TxtReviewTransaction" Text="📋 Review Transaction" 
                               FontSize="42"
                               FontWeight="Bold"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,12"/>
                    <TextBlock x:Name="TxtReviewCarefully" Text="Please review all details carefully before proceeding to payment" 
                               FontSize="18"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               HorizontalAlignment="Center"/>
                </StackPanel>

                <!-- Transaction Amount Summary Card -->
                <Border Background="White"
                        CornerRadius="20"
                        Padding="40"
                        Margin="0,0,0,24">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="20" ShadowDepth="0" Opacity="0.08" Color="#000000"/>
                    </Border.Effect>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="2*"/>
                        </Grid.ColumnDefinitions>

                        <!-- You Send Section -->
                        <Border Grid.Column="0" 
                                Background="#EFF6FF"
                                CornerRadius="16"
                                Padding="28">
                            <StackPanel>
                                <TextBlock x:Name="TxtYouSendSummary" Text="You Send" 
                                           FontSize="16"
                                           FontWeight="SemiBold"
                                           Foreground="#2563EB"
                                           HorizontalAlignment="Center"
                                           Margin="0,0,0,12"/>
                                <TextBlock Text="{Binding SendAmountMYR, StringFormat='MYR {0:N2}'}" 
                                           FontSize="36"
                                           FontWeight="Bold"
                                           Foreground="#1E293B"
                                           HorizontalAlignment="Center"
                                           Margin="0,0,0,8"/>
                                <Border Height="1" Background="#CBD5E1" Margin="0,12,0,12"/>
                                <Grid Margin="0,0,0,8">
                                    <TextBlock x:Name="TxtServiceFeeSummary" Text="Service Fee" FontSize="14" Foreground="#64748B" HorizontalAlignment="Left"/>
                                    <TextBlock Text="{Binding ServiceFee, StringFormat='+ MYR {0:N2}'}" 
                                               FontSize="14" FontWeight="SemiBold" Foreground="#64748B" HorizontalAlignment="Right"/>
                                </Grid>
                                <Border Height="2" Background="#2563EB" Margin="0,8,0,12" CornerRadius="1"/>
                                <Grid>
                                    <TextBlock x:Name="TxtTotalAmountSummary" Text="Total Amount" FontSize="15" FontWeight="Bold" Foreground="#1E293B" HorizontalAlignment="Left"/>
                                    <TextBlock Text="{Binding TotalAmountMYR, StringFormat='MYR {0:N2}'}" 
                                               FontSize="20" FontWeight="Bold" Foreground="#2563EB" HorizontalAlignment="Right"/>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- Arrow -->
                        <Viewbox Grid.Column="1" Width="80" Height="80" Margin="20,0">
                            <Canvas Width="100" Height="100">
                                <!-- Arrow Body -->
                                <Path Data="M20,50 L80,50" 
                                      Stroke="#10B981" 
                                      StrokeThickness="6" 
                                      StrokeEndLineCap="Round"/>
                                <!-- Arrow Head -->
                                <Path Data="M65,35 L80,50 L65,65" 
                                      Stroke="#10B981" 
                                      StrokeThickness="6" 
                                      StrokeEndLineCap="Round"
                                      StrokeLineJoin="Round"
                                      Fill="Transparent"/>
                            </Canvas>
                        </Viewbox>

                        <!-- Beneficiary Receives Section -->
                        <Border Grid.Column="2"
                                CornerRadius="16"
                                Padding="28">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#ECFDF5" Offset="0"/>
                                    <GradientStop Color="#D1FAE5" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <StackPanel>
                                <TextBlock x:Name="TxtBeneReceivesSummary" Text="Beneficiary Receives" 
                                           FontSize="16"
                                           FontWeight="SemiBold"
                                           Foreground="#10B981"
                                           HorizontalAlignment="Center"
                                           Margin="0,0,0,12"/>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,12">
                                    <TextBlock Text="{Binding ReceiveCurrency}" 
                                               FontSize="28"
                                               FontWeight="Bold"
                                               Foreground="#1E293B"
                                               VerticalAlignment="Center"
                                               Margin="0,0,8,0"/>
                                    <TextBlock Text="{Binding ReceiveAmount, StringFormat='{}{0:N2}'}" 
                                               FontSize="40"
                                               FontWeight="Bold"
                                               Foreground="#10B981"/>
                                </StackPanel>
                                <Border Background="#10B98133"
                                        CornerRadius="8"
                                        Padding="12,8"
                                        HorizontalAlignment="Center"
                                        Margin="0,8,0,0">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="💱" FontSize="16" Margin="0,0,8,0"/>
                                        <TextBlock FontSize="14" FontWeight="SemiBold" Foreground="#059669">
                                            <Run x:Name="TxtRateLabel" Text="Rate: 1 MYR = "/>
                                            <Run Text="{Binding ExchangeRate, StringFormat='{}{0:N4}'}"/>
                                            <Run Text=" "/>
                                            <Run Text="{Binding ReceiveCurrency}"/>
                                        </TextBlock>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>

                <!-- Details Cards Grid -->
                <Grid Margin="0,0,0,24">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="24"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Sender Details Card -->
                    <Border Grid.Column="0"
                            Background="White"
                            CornerRadius="20"
                            Padding="32">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="20" ShadowDepth="0" Opacity="0.08" Color="#000000"/>
                        </Border.Effect>

                        <StackPanel>
                            <!-- Card Header -->
                            <Border Background="#EFF6FF"
                                    CornerRadius="12"
                                    Padding="16"
                                    Margin="0,0,0,24">
                                <StackPanel Orientation="Horizontal">
                                    <Border Background="#2563EB"
                                            CornerRadius="10"
                                            Width="40"
                                            Height="40"
                                            Margin="0,0,16,0">
                                        <TextBlock Text="👤" 
                                                   FontSize="22"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                    </Border>
                                    <TextBlock x:Name="TxtSenderDetails" Text="Sender Details" 
                                               FontSize="22" 
                                               FontWeight="Bold"
                                               Foreground="#1E293B"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>

                            <!-- Details -->
                            <StackPanel>
                                <Grid Margin="0,0,0,16">
                                    <TextBlock x:Name="TxtFullNameSender" Text="Full Name" FontSize="13" Foreground="#64748B" FontWeight="SemiBold"/>
                                    <TextBlock Text="{Binding SenderFullName}" 
                                               FontSize="16" FontWeight="Bold" Foreground="#1E293B" 
                                               HorizontalAlignment="Right" TextWrapping="Wrap" TextAlignment="Right"/>
                                </Grid>
                                <Border Height="1" Background="#E2E8F0" Margin="0,0,0,16"/>

                                <Grid Margin="0,0,0,16">
                                    <TextBlock x:Name="TxtICPassportSender" Text="IC/Passport" FontSize="13" Foreground="#64748B" FontWeight="SemiBold"/>
                                    <TextBlock Text="{Binding SenderIC}" 
                                               FontSize="16" FontWeight="Bold" Foreground="#1E293B" 
                                               HorizontalAlignment="Right"/>
                                </Grid>
                                <Border Height="1" Background="#E2E8F0" Margin="0,0,0,16"/>

                                <Grid Margin="0,0,0,16">
                                    <TextBlock x:Name="TxtMobileSender" Text="Mobile" FontSize="13" Foreground="#64748B" FontWeight="SemiBold"/>
                                    <TextBlock Text="{Binding SenderMobileNo}" 
                                               FontSize="16" FontWeight="Bold" Foreground="#1E293B" 
                                               HorizontalAlignment="Right"/>
                                </Grid>
                                <Border Height="1" Background="#E2E8F0" Margin="0,0,0,16"/>

                                <Grid Margin="0,0,0,16">
                                    <TextBlock x:Name="TxtOccupationSender" Text="Occupation" FontSize="13" Foreground="#64748B" FontWeight="SemiBold"/>
                                    <TextBlock Text="{Binding SenderOccupation}" 
                                               FontSize="16" FontWeight="Bold" Foreground="#1E293B" 
                                               HorizontalAlignment="Right" TextWrapping="Wrap" TextAlignment="Right"/>
                                </Grid>
                                <Border Height="1" Background="#E2E8F0" Margin="0,0,0,16"/>

                                <StackPanel>
                                    <TextBlock x:Name="TxtAddressSender" Text="Address" FontSize="13" Foreground="#64748B" FontWeight="SemiBold"/>
                                    <TextBlock FontSize="15" Foreground="#1E293B" HorizontalAlignment="Right" TextWrapping="Wrap" TextAlignment="Right" LineHeight="22">
                                        <Run Text="{Binding SenderAddress}"/><LineBreak/>
                                        <Run Text="{Binding SenderCity}"/>, <Run Text="{Binding SenderPostcode}"/><LineBreak/>
                                        <Run Text="{Binding SenderState}"/>, <Run Text="{Binding SenderCountry}"/>
                                    </TextBlock>
                                </StackPanel>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Beneficiary Details Card -->
                    <Border Grid.Column="2"
                            Background="White"
                            CornerRadius="20"
                            Padding="32">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="20" ShadowDepth="0" Opacity="0.08" Color="#000000"/>
                        </Border.Effect>

                        <StackPanel>
                            <!-- Card Header -->
                            <Border Background="#ECFDF5"
                                    CornerRadius="12"
                                    Padding="16"
                                    Margin="0,0,0,24">
                                <StackPanel Orientation="Horizontal">
                                    <Border Background="#10B981"
                                            CornerRadius="10"
                                            Width="40"
                                            Height="40"
                                            Margin="0,0,16,0">
                                        <TextBlock Text="💰" 
                                                   FontSize="22"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                    </Border>
                                    <TextBlock x:Name="TxtBeneficiaryDetails" Text="Beneficiary Details" 
                                               FontSize="22" 
                                               FontWeight="Bold"
                                               Foreground="#1E293B"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>

                            <!-- Details -->
                            <StackPanel>
                                <Grid Margin="0,0,0,16">
                                    <TextBlock x:Name="TxtFullNameBene" Text="Full Name" FontSize="13" Foreground="#64748B" FontWeight="SemiBold"/>
                                    <TextBlock Text="{Binding BeneficiaryFullName}" 
                                               FontSize="16" FontWeight="Bold" Foreground="#1E293B" 
                                               HorizontalAlignment="Right" TextWrapping="Wrap" TextAlignment="Right"/>
                                </Grid>
                                <Border Height="1" Background="#E2E8F0" Margin="0,0,0,16"/>

                                <Grid Margin="0,0,0,16">
                                    <TextBlock x:Name="TxtRelationshipBene" Text="Relationship" FontSize="13" Foreground="#64748B" FontWeight="SemiBold"/>
                                    <TextBlock Text="{Binding BeneficiaryRelationship}" 
                                               FontSize="16" FontWeight="Bold" Foreground="#1E293B" 
                                               HorizontalAlignment="Right"/>
                                </Grid>
                                <Border Height="1" Background="#E2E8F0" Margin="0,0,0,16"/>

                                <Grid Margin="0,0,0,16">
                                    <TextBlock x:Name="TxtMobileBene" Text="Mobile" FontSize="13" Foreground="#64748B" FontWeight="SemiBold"/>
                                    <TextBlock Text="{Binding BeneficiaryMobileNo}" 
                                               FontSize="16" FontWeight="Bold" Foreground="#1E293B" 
                                               HorizontalAlignment="Right"/>
                                </Grid>
                                <Border Height="1" Background="#E2E8F0" Margin="0,0,0,16"/>

                                <Grid Margin="0,0,0,16">
                                    <TextBlock x:Name="TxtCountryBene" Text="Country" FontSize="13" Foreground="#64748B" FontWeight="SemiBold"/>
                                    <TextBlock Text="{Binding DestinationCountry}" 
                                               FontSize="16" FontWeight="Bold" Foreground="#10B981" 
                                               HorizontalAlignment="Right"/>
                                </Grid>
                                <Border Height="1" Background="#E2E8F0" Margin="0,0,0,16"/>

                                <StackPanel Margin="0,0,0,16">
                                    <TextBlock x:Name="TxtBankDetailsBene" Text="Bank Details" FontSize="13" Foreground="#64748B" FontWeight="SemiBold"/>
                                    <TextBlock Text="{Binding BeneficiaryBankName}" 
                                               FontSize="15" FontWeight="Bold" Foreground="#1E293B" 
                                               TextWrapping="Wrap" HorizontalAlignment="Right" Margin="0,0,0,4"/>
                                    <TextBlock FontSize="17" HorizontalAlignment="Right" FontWeight="Bold" Foreground="#2563EB">
                                        <Run Text="💳 "/>
                                        <Run Text="{Binding BeneficiaryAccountNo}"/>
                                    </TextBlock>
                                </StackPanel>
                                <Border Height="1" Background="#E2E8F0" Margin="0,0,0,16"/>

                                <Grid Margin="0,0,0,16">
                                    <TextBlock x:Name="TxtPurposeBene" Text="Purpose" FontSize="13" Foreground="#64748B" FontWeight="SemiBold"/>
                                    <TextBlock Text="{Binding PurposeOfRemittance}" 
                                               FontSize="16" FontWeight="Bold" Foreground="#1E293B" 
                                               HorizontalAlignment="Right" TextWrapping="Wrap" TextAlignment="Right"/>
                                </Grid>
                                <Border Height="1" Background="#E2E8F0" Margin="0,0,0,16"/>

                                <Grid>
                                    <TextBlock x:Name="TxtDeliveryBene" Text="Delivery" FontSize="13" Foreground="#64748B" FontWeight="SemiBold"/>
                                    <TextBlock Text="{Binding DeliveryMethod}" 
                                               FontSize="16" FontWeight="Bold" Foreground="#1E293B" 
                                               HorizontalAlignment="Right" TextWrapping="Wrap" TextAlignment="Right"/>
                                </Grid>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- Payment Method Selection -->
                <!-- Payment Method Selection -->
                <Border Background="White"
        CornerRadius="20"
        Padding="40"
        Margin="0,0,0,24">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="20" ShadowDepth="0" Opacity="0.08" Color="#000000"/>
                    </Border.Effect>

                    <StackPanel>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,32">
                            <Border Background="#FEF3C7"
                    CornerRadius="12"
                    Width="48"
                    Height="48"
                    Margin="0,0,16,0">
                                <TextBlock Text="💳" 
                           FontSize="26"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock x:Name="TxtSelectPayment" 
                           Text="Select Payment Method" 
                           FontSize="26"
                           FontWeight="Bold"
                           Foreground="#1E293B"
                           Margin="0,0,0,4"/>
                                <TextBlock x:Name="TxtChoosePayment" 
                           Text="Choose how you'd like to complete this transaction"
                           FontSize="15"
                           Foreground="#64748B"/>
                            </StackPanel>
                        </StackPanel>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="24"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- Pay with Card Button - Using Tag property to store text -->
                            <Button x:Name="PayWithCardButton" 
                    Grid.Column="0"
                    Tag="Pay with Card"
                    Click="PayWithCard_Click"
                    Height="180"
                    BorderThickness="0"
                    Cursor="Hand"
                    Background="Transparent">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="border"
                                Background="White"
                                BorderBrush="#2563EB"
                                BorderThickness="3"
                                CornerRadius="16"
                                Padding="24">
                                            <StackPanel>
                                                <Border Background="#EFF6FF"
                                        CornerRadius="12"
                                        Width="60"
                                        Height="60"
                                        Margin="0,0,0,16"
                                        HorizontalAlignment="Center">
                                                    <TextBlock Text="💳" 
                                               FontSize="32"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                                                </Border>
                                                <TextBlock Text="{TemplateBinding Tag}" 
                                           FontSize="22" 
                                           FontWeight="Bold"
                                           Foreground="#1E293B"
                                           HorizontalAlignment="Center"
                                           Margin="0,0,0,8"/>
                                            </StackPanel>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="border" Property="Background" Value="#EFF6FF"/>
                                                <Setter TargetName="border" Property="Effect">
                                                    <Setter.Value>
                                                        <DropShadowEffect BlurRadius="20" ShadowDepth="0" Opacity="0.2" Color="#2563EB"/>
                                                    </Setter.Value>
                                                </Setter>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>

                            <!-- Pay at Counter Button - Using Tag property to store text -->
                            <Button x:Name="PayAtCounterButton"
                    Grid.Column="2"
                    Tag="Pay at Counter"
                    Click="PayAtCounter_Click"
                    Height="180"
                    BorderThickness="0"
                    Cursor="Hand"
                    Background="Transparent">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="border"
                                Background="White"
                                BorderBrush="#10B981"
                                BorderThickness="3"
                                CornerRadius="16"
                                Padding="24">
                                            <StackPanel>
                                                <Border Background="#ECFDF5"
                                        CornerRadius="12"
                                        Width="60"
                                        Height="60"
                                        Margin="0,0,0,16"
                                        HorizontalAlignment="Center">
                                                    <TextBlock Text="🏦" 
                                               FontSize="32"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                                                </Border>
                                                <TextBlock Text="{TemplateBinding Tag}" 
                                           FontSize="22" 
                                           FontWeight="Bold"
                                           Foreground="#1E293B"
                                           HorizontalAlignment="Center"
                                           Margin="0,0,0,8"/>
                                            </StackPanel>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="border" Property="Background" Value="#ECFDF5"/>
                                                <Setter TargetName="border" Property="Effect">
                                                    <Setter.Value>
                                                        <DropShadowEffect BlurRadius="20" ShadowDepth="0" Opacity="0.2" Color="#10B981"/>
                                                    </Setter.Value>
                                                </Setter>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Action Buttons Grid -->
                <Grid Margin="0,0,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="20"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Back Button -->
                    <Button Grid.Column="0" 
            x:Name="BackButton"
            Content="Back"
            Height="64"
            FontSize="18"
            FontWeight="SemiBold"
            BorderThickness="0"
            Cursor="Hand"
            Click="Back_Click"
            Background="Transparent">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="border"
                        Background="White"
                        BorderBrush="#E2E8F0"
                        BorderThickness="2"
                        CornerRadius="12">
                                    <ContentPresenter HorizontalAlignment="Center" 
                                    VerticalAlignment="Center"
                                    TextBlock.Foreground="#64748B"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="border" Property="BorderBrush" Value="#CBD5E1"/>
                                        <Setter TargetName="border" Property="Background" Value="#F8FAFC"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <!-- Start New Transaction Button -->
                    <Button Grid.Column="2" 
            x:Name="StartNewButton"
            Content="Start New Transaction"
            Height="64"
            FontSize="18"
            FontWeight="Bold"
            BorderThickness="0"
            Cursor="Hand"
            Click="StartNewTransaction_Click"
            Background="#10B981">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="border"
                        Background="{TemplateBinding Background}"
                        CornerRadius="12">
                                    <Border.Effect>
                                        <DropShadowEffect BlurRadius="15" ShadowDepth="0" Opacity="0.2" Color="#10B981"/>
                                    </Border.Effect>
                                    <ContentPresenter HorizontalAlignment="Center" 
                                    VerticalAlignment="Center"
                                    TextBlock.Foreground="White"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="border" Property="Background" Value="#059669"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>