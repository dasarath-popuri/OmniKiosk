                                      CornerRadius="10"
                                      Height="58"
                                      Padding="16">
                                    <TextBlock VerticalAlignment="Center">
                                        <Run Text="{Binding ReceiveCurrency}" FontSize="19" FontWeight="Bold" Foreground="White"/>
                                        <Run Text=" " />
                                        <Run Text="{Binding ReceiveAmount, StringFormat='{}{0:N2}'}" FontSize="19" FontWeight="Bold" Foreground="White"/>
                                    </TextBlock>
                                </Border>
                            </StackPanel>

                            <!-- Row 2: Purpose & Source of Funds (with same dropdown style) -->
