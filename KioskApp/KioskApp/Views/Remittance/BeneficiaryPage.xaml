                                      CornerRadius="10"
                                      Height="58"
                                      Padding="16">
                                    <TextBlock VerticalAlignment="Center">
                                        <Run Text="MYR" FontSize="19" FontWeight="Bold" Foreground="White"/>
                                        <Run Text=" " />
