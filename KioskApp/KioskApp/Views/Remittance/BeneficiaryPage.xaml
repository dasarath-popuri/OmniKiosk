                                    <ComboBoxItem>
                                        <TextBlock Text="Gift" FontSize="17" FontWeight="Medium" Foreground="#1E293B"/>
                                    </ComboBoxItem>
                                    <ComboBoxItem>
                                        <TextBlock Text="Loan Repayment" FontSize="17" FontWeight="Medium" Foreground="#1E293B"/>
                                    </ComboBoxItem>
                                    <ComboBoxItem>
                                        <TextBlock Text="Business Payment" FontSize="17" FontWeight="Medium" Foreground="#1E293B"/>
                                    </ComboBoxItem>
                                    <ComboBoxItem>
                                        <TextBlock Text="Other" FontSize="17" FontWeight="Medium" Foreground="#1E293B"/>
                                    </ComboBoxItem>
                                </ComboBox>
