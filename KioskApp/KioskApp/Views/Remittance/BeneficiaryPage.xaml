<Page x:Class="OmniKiosk.Wpf.Views.Remittance.BeneficiaryPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="{DynamicResource BackgroundBrush}">

    <Grid>
        <!-- Notification Banner -->
        <Border x:Name="NotificationBanner"
                Background="#10B981"
                CornerRadius="12"
                Padding="24"
                Margin="40,20,40,0"
                VerticalAlignment="Top"
                Visibility="Collapsed"
                Panel.ZIndex="999">
            <Border.Effect>
                <DropShadowEffect BlurRadius="15" ShadowDepth="2" Opacity="0.3" Color="#000000"/>
            </Border.Effect>

            <Grid>
                <StackPanel Orientation="Horizontal">
                    <Border Background="#FFFFFF33" 
                            CornerRadius="20" 
                            Width="40" 
                            Height="40"
                            Margin="0,0,16,0">
                        <TextBlock x:Name="NotificationIcon"
                                 Text="✓"
                                 FontSize="24"
                                 Foreground="White"
                                 HorizontalAlignment="Center"
                                 VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock x:Name="NotificationTitle"
                                 Text="Success"
                                 FontSize="18"
                                 FontWeight="Bold"
                                 Foreground="White"
                                 Margin="0,0,0,4"/>
                        <TextBlock x:Name="NotificationMessage"
                                 Text="Action completed successfully"
                                 FontSize="15"
                                 Foreground="White"
                                 Opacity="0.95"
                                 TextWrapping="Wrap"/>
                    </StackPanel>
                </StackPanel>

                <Button Content="✕"
                        Background="Transparent"
                        Foreground="White"
                        BorderThickness="0"
                        FontSize="20"
                        Width="36"
                        Height="36"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Top"
                        Cursor="Hand"
                        Click="CloseNotification_Click">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}"
                                                CornerRadius="18">
                                            <ContentPresenter HorizontalAlignment="Center" 
                                                            VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#FFFFFF33"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </Grid>
        </Border>

        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Padding="0,0,0,0">
            <StackPanel Width="900" Margin="40,20,40,40" HorizontalAlignment="Center">

                <!-- Header Section -->
                <StackPanel Margin="0,0,0,32">
                    <TextBlock x:Name="TxtBeneficiaryInfo" Text="💰 Beneficiary Information"
                               FontSize="42"
                               FontWeight="Bold"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,12"/>
                    <TextBlock x:Name="TxtSelectOrCreate" Text="Select an existing beneficiary or create a new profile"
                               FontSize="18"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               HorizontalAlignment="Center"/>
                </StackPanel>

                <!-- Destination Country Info Card -->
                <Border Background="White"
                        CornerRadius="20"
                        Padding="0"
                        Margin="0,0,0,28">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="20" ShadowDepth="0" Opacity="0.08" Color="#000000"/>
                    </Border.Effect>

                    <Grid>
                        <Border Background="#10B981"
                                CornerRadius="14"
                                Padding="24">
                            <Grid>
                                <StackPanel Orientation="Horizontal">
                                    <Border Background="Red"
                                            CornerRadius="12"
                                            Width="52"
                                            Height="52"
                                            Margin="0,0,20,0">
                                        <TextBlock Text="📍" 
                                                   FontSize="28" 
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                    </Border>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock x:Name="TxtSendingMoneyTo" Text="Sending Money To" 
                                                 Foreground="White"
                                                 FontSize="14"
                                                 Opacity="0.9"
                                                 Margin="0,0,0,6"/>
                                        <TextBlock Text="{Binding DestinationCountry}" 
                                                 Foreground="White"
                                                 FontSize="26"
                                                 FontWeight="Bold"/>
                                    </StackPanel>
                                </StackPanel>

                                <Border Background="Blue"
                                        CornerRadius="12"
                                        Padding="16,12"
                                        HorizontalAlignment="Right"
                                        VerticalAlignment="Center">
                                    <StackPanel>
                                        <TextBlock x:Name="TxtExchangeRateLabel" Text="Exchange Rate" 
                                                 Foreground="White"
                                                 FontSize="13"
                                                 Opacity="0.9"
                                                 HorizontalAlignment="Right"
                                                 Margin="0,0,0,4"/>
                                        <TextBlock Text="{Binding ExchangeRate, StringFormat='1 MYR = {0:F4}'}" 
                                                 Foreground="White"
                                                 FontSize="20"
                                                 FontWeight="Bold"
                                                 HorizontalAlignment="Right"/>
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </Border>
                    </Grid>
                </Border>

                <!-- Selection Mode Tabs -->
                <Border Background="{DynamicResource BackgroundBrush}" Margin="0,0,0,28">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="20"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Button x:Name="ExistingBeneficiaryButton"
                                Grid.Column="0"
                                Content="📋 Select Existing Beneficiary"
                                Style="{StaticResource PrimaryButton}"
                                Height="76"
                                FontSize="21"
                                Click="ExistingBeneficiary_Click"/>

                        <Button x:Name="NewBeneficiaryButton"
                                Grid.Column="2"
                                Content="➕ Create New Beneficiary"
                                Style="{StaticResource OutlineButton}"
                                Height="76"
                                FontSize="21"
                                Click="NewBeneficiary_Click"/>
                    </Grid>
                </Border>

                <!-- Existing Beneficiaries Panel -->
                <Border x:Name="ExistingBeneficiariesPanel" 
                        Background="White" 
                        CornerRadius="20" 
                        Padding="36"
                        Margin="0,0,0,28"
                        Visibility="Visible">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="20" ShadowDepth="0" Opacity="0.08" Color="#000000"/>
                    </Border.Effect>

                    <StackPanel>
                        <!-- Section Header -->
                        <Grid Margin="0,0,0,28">
                            <Border Background="#FEF3C7" 
                                    CornerRadius="12" 
                                    Width="48" 
                                    Height="48"
                                    HorizontalAlignment="Left">
                                <TextBlock Text="💰" 
                                           FontSize="24"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel Margin="64,0,0,0">
                                <TextBlock x:Name="TxtRecentBeneficiaries"  Text="Recent Beneficiaries"
                                           FontSize="24"
                                           FontWeight="Bold"
                                           Foreground="#1E293B"
                                           Margin="0,0,0,4"/>
                                <TextBlock  x:Name="TxtSelectFromPrevious" Text="Select from your previously saved beneficiary profiles"
                                           FontSize="15"
                                           Foreground="#64748B"/>
                            </StackPanel>
                        </Grid>

                        <!-- Search Box -->
                        <Border BorderBrush="#E2E8F0" 
                                BorderThickness="2" 
                                CornerRadius="12" 
                                Background="#FAFBFC"
                                Padding="16,0"
                                Margin="0,0,0,24">
                            <Grid Height="56">
                                <TextBlock Text="🔍"
                                           FontSize="20"
                                           VerticalAlignment="Center"
                                           HorizontalAlignment="Left"/>
                                <TextBox x:Name="SearchBeneficiaryTextBox"
                                         FontSize="17"
                                         Foreground="#1E293B"
                                         BorderThickness="0"
                                         Background="Transparent"
                                         VerticalContentAlignment="Center"
                                         Padding="32,0,0,0"
                                         TextChanged="SearchBeneficiary_TextChanged">
                                    <TextBox.Resources>
                                        <Style TargetType="TextBox">
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="TextBox">
                                                        <Grid>
                                                            <TextBlock IsHitTestVisible="False" x:Name="TxtSearchPlaceholder"
                                                                     Text="Search by name or account number..."
                                                                     Foreground="#94A3B8"
                                                                     FontSize="17"
                                                                     Margin="32,0,0,0"
                                                                     VerticalAlignment="Center">
                                                                <TextBlock.Style>
                                                                    <Style TargetType="TextBlock">
                                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding Text, ElementName=SearchBeneficiaryTextBox}" Value="">
                                                                                <Setter Property="Visibility" Value="Visible"/>
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </TextBlock.Style>
                                                            </TextBlock>
                                                            <ScrollViewer x:Name="PART_ContentHost" 
                                                                        Margin="{TemplateBinding Padding}"
                                                                        VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                                                        </Grid>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Style>
                                    </TextBox.Resources>
                                </TextBox>
                            </Grid>
                        </Border>

                        <!-- Beneficiaries List -->
                        <ListBox x:Name="BeneficiariesListBox"
                               MaxHeight="650"
                               Background="Transparent"
                               BorderThickness="0"
                               ScrollViewer.VerticalScrollBarVisibility="Auto"
                               SelectionChanged="Beneficiary_SelectionChanged">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#F8FAFC"
                                          BorderBrush="#E2E8F0"
                                          BorderThickness="2"
                                          CornerRadius="16"
                                          Padding="20"
                                          Margin="0,0,0,16"
                                          Cursor="Hand">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <!-- Icon -->
                                            <Border Grid.Column="0"
                                                  Width="72" Height="72"
                                                  Background="#10B981"
                                                  CornerRadius="36"
                                                  Margin="0,0,20,0">
                                                <TextBlock Text="💸" 
                                                         FontSize="36"
                                                         HorizontalAlignment="Center"
                                                         VerticalAlignment="Center"/>
                                            </Border>

                                            <!-- Details -->
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding FullName}" 
                                                         FontSize="20" 
                                                         FontWeight="Bold"
                                                         Foreground="#1E293B"
                                                         Margin="0,0,0,8"/>
                                                <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                                    <Border Background="#ECFDF5" 
                                                            CornerRadius="6" 
                                                            Padding="8,4"
                                                            Margin="0,0,8,0">
                                                        <TextBlock FontSize="14" 
                                                                   Foreground="#10B981"
                                                                   FontWeight="SemiBold">
                                                            <Run Text="🏦 "/>
                                                            <Run Text="{Binding BankName}"/>
                                                        </TextBlock>
                                                    </Border>
                                                </StackPanel>
                                                <TextBlock FontSize="15" 
                                                         Foreground="#64748B"
                                                         Margin="0,0,0,4">
                                                    <Run Text="💳 "/>
                                                    <Run Text="{Binding AccountNo}"/>
                                                </TextBlock>
                                                <TextBlock Text="{Binding LastUsedText}" 
                                                         FontSize="13"
                                                         Foreground="#94A3B8"/>
                                            </StackPanel>

                                            <!-- Arrow -->
                                            <Border Grid.Column="2"
                                                    Background="#ECFDF5"
                                                    CornerRadius="20"
                                                    Width="40"
                                                    Height="40"
                                                    VerticalAlignment="Center">
                                                <TextBlock Text="→"
                                                         FontSize="24"
                                                         Foreground="#10B981"
                                                         HorizontalAlignment="Center"
                                                         VerticalAlignment="Center"/>
                                            </Border>
                                        </Grid>

                                        <!-- Hover Effect -->
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Style.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="White"/>
                                                        <Setter Property="BorderBrush" Value="#10B981"/>
                                                        <Setter Property="Effect">
                                                            <Setter.Value>
                                                                <DropShadowEffect BlurRadius="20" ShadowDepth="0" Opacity="0.15" Color="#10B981"/>
                                                            </Setter.Value>
                                                        </Setter>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <!-- No Beneficiaries Message -->
                        <Border x:Name="NoBeneficiariesMessage"
                              Background="#F8FAFC"
                              CornerRadius="16"
                              Padding="48"
                              Visibility="Collapsed">
                            <StackPanel HorizontalAlignment="Center">
                                <TextBlock Text="📭" FontSize="72" HorizontalAlignment="Center" Margin="0,0,0,20"/>
                                <TextBlock x:Name="TxtNoBeneficiaries" Text="No beneficiaries found" 
                                         FontSize="22"
                                         FontWeight="Bold"
                                         Foreground="#1E293B"
                                         HorizontalAlignment="Center"
                                         Margin="0,0,0,8"/>
                                <TextBlock x:Name="TxtCreateToC" Text="Create a new beneficiary to continue" 
                                         FontSize="16"
                                         Foreground="#64748B"
                                         HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- New Beneficiary Form -->
                <!-- New Beneficiary Form - REGROUPED SECTIONS -->
                <Border x:Name="NewBeneficiaryPanel" 
        Background="White" 
        CornerRadius="20" 
        Padding="36"
        Margin="0,0,0,28"
        Visibility="Collapsed">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="20" ShadowDepth="0" Opacity="0.08" Color="#000000"/>
                    </Border.Effect>

                    <StackPanel>
                        <!-- Section Header -->
                        <Grid Margin="0,0,0,32">
                            <Border Background="#ECFDF5" 
                    CornerRadius="12" 
                    Width="48" 
                    Height="48"
                    HorizontalAlignment="Left">
                                <TextBlock Text="✏️" 
                           FontSize="24"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel Margin="64,0,0,0">
                                <TextBlock x:Name="TxtEnterBeneficiaryDetails" Text="Enter Beneficiary Details"
                           FontSize="24"
                           FontWeight="Bold"
                           Foreground="#1E293B"
                           Margin="0,0,0,4"/>
                                <TextBlock x:Name="TxtCompleteFieldsBene" Text="Complete all required fields to create a new beneficiary profile"
                           FontSize="15"
                           Foreground="#64748B"/>
                            </StackPanel>
                        </Grid>

                        <!-- GROUP 1: PERSONAL INFORMATION -->
                        <Border BorderBrush="#E2E8F0" 
                BorderThickness="2" 
                CornerRadius="16" 
                Padding="28"
                Margin="0,0,0,24"
                Background="#FAFBFC">
                            <StackPanel>
                                <!-- Group Header -->
                                <Grid Margin="0,0,0,24">
                                    <Border Background="#EFF6FF" 
                            CornerRadius="10" 
                            Width="40" 
                            Height="40"
                            HorizontalAlignment="Left">
                                        <TextBlock Text="👤" 
                                   FontSize="20"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                                    </Border>
                                    <TextBlock x:Name="TxtPersonalInfo" Text="Personal Information" 
                               FontSize="20"
                               FontWeight="Bold"
                               Foreground="#1E293B"
                               Margin="52,0,0,0"
                               VerticalAlignment="Center"/>
                                </Grid>

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="20"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <!-- Row 1: First Name & Last Name -->
                                    <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,0,20">
                                        <TextBlock x:Name="LblBeneFirstName" Text="First Name *" 
                                   FontSize="14" 
                                   FontWeight="SemiBold"
                                   Foreground="#1E293B"
                                   Margin="0,0,0,8"/>
                                        <Border BorderBrush="#E2E8F0" BorderThickness="2" CornerRadius="10" Padding="14,0" Background="White">
                                            <TextBox x:Name="TxtBeneficiaryFirstName" 
                                     Height="54" 
                                     FontSize="17" 
                                     Foreground="#1E293B"
                                     BorderThickness="0" 
                                     Background="Transparent" 
                                     VerticalContentAlignment="Center"/>
                                        </Border>
                                    </StackPanel>

                                    <StackPanel Grid.Row="0" Grid.Column="2" Margin="0,0,0,20">
                                        <TextBlock x:Name="LblBeneLastName" Text="Last Name *" 
                                   FontSize="14" 
                                   FontWeight="SemiBold"
                                   Foreground="#1E293B"
                                   Margin="0,0,0,8"/>
                                        <Border BorderBrush="#E2E8F0" BorderThickness="2" CornerRadius="10" Padding="14,0" Background="White">
                                            <TextBox x:Name="TxtBeneficiaryLastName" 
                                     Height="54" 
                                     FontSize="17" 
                                     Foreground="#1E293B"
                                     BorderThickness="0" 
                                     Background="Transparent" 
                                     VerticalContentAlignment="Center"/>
                                        </Border>
                                    </StackPanel>

                                    <!-- Row 2: Mobile Number & Relationship -->
                                    <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,0,20">
                                        <TextBlock x:Name="LblBeneMobile" Text="Mobile Number *" 
                                   FontSize="14" 
                                   FontWeight="SemiBold"
                                   Foreground="#1E293B"
                                   Margin="0,0,0,8"/>
                                        <Border BorderBrush="#E2E8F0" BorderThickness="2" CornerRadius="10" Padding="14,0" Background="White">
                                            <TextBox x:Name="TxtBeneficiaryMobile" 
                                     Height="54" 
                                     FontSize="17" 
                                     Foreground="#1E293B"
                                     BorderThickness="0" 
                                     Background="Transparent" 
                                     VerticalContentAlignment="Center"/>
                                        </Border>
                                    </StackPanel>

                                    <StackPanel Grid.Row="1" Grid.Column="2" Margin="0,0,0,20">
                                        <TextBlock  x:Name="LblRelationship" Text="Relationship *" 
               FontSize="14" 
               FontWeight="SemiBold"
               Foreground="#1E293B"
               Margin="0,0,0,8"/>
                                        <ComboBox x:Name="CmbRelationship" 
              Height="64"
              FontSize="17"
              Foreground="#1E293B"
              Background="White"
              BorderBrush="#E2E8F0"
              BorderThickness="2">
                                            <ComboBox.Style>
                                                <Style TargetType="ComboBox">
                                                    <Setter Property="Template">
                                                        <Setter.Value>
                                                            <ControlTemplate TargetType="ComboBox">
                                                                <Grid>
                                                                    <ToggleButton x:Name="ToggleButton"
                                              Grid.Column="2"
                                              Focusable="false"
                                              IsChecked="{Binding Path=IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                              ClickMode="Press"
                                              Background="White">
                                                                        <ToggleButton.Template>
                                                                            <ControlTemplate TargetType="ToggleButton">
                                                                                <Border Background="{TemplateBinding Background}"
                                                    BorderBrush="#E2E8F0"
                                                    BorderThickness="2"
                                                    CornerRadius="12">
                                                                                    <Grid>
                                                                                        <ContentPresenter Content="{TemplateBinding Content}"
                                                                      Margin="20,0"/>
                                                                                        <Path x:Name="Arrow"
                                                          HorizontalAlignment="Right"
                                                          VerticalAlignment="Center"
                                                          Margin="0,0,20,0"
                                                          Data="M 0 0 L 4 4 L 8 0 Z"
                                                          Fill="#64748B"/>
                                                                                    </Grid>
                                                                                </Border>
                                                                                <ControlTemplate.Triggers>
                                                                                    <Trigger Property="IsMouseOver" Value="True">
                                                                                        <Setter TargetName="Arrow" Property="Fill" Value="#2563EB"/>
                                                                                    </Trigger>
                                                                                </ControlTemplate.Triggers>
                                                                            </ControlTemplate>
                                                                        </ToggleButton.Template>
                                                                    </ToggleButton>
                                                                    <ContentPresenter x:Name="ContentSite"
                                                  IsHitTestVisible="False"
                                                  Content="{TemplateBinding SelectionBoxItem}"
                                                  ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                                  ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}"
                                                  Margin="20,0,40,0"
                                                  VerticalAlignment="Center"
                                                  HorizontalAlignment="Left"/>
                                                                    <Popup x:Name="Popup"
                                       Placement="Bottom"
                                       IsOpen="{TemplateBinding IsDropDownOpen}"
                                       AllowsTransparency="True"
                                       Focusable="False"
                                       PopupAnimation="Slide">
                                                                        <Grid MaxHeight="300"
                                          MinWidth="{TemplateBinding ActualWidth}">
                                                                            <Border Background="White"
                                                BorderBrush="#E2E8F0"
                                                BorderThickness="2"
                                                CornerRadius="12"
                                                Margin="0,4,0,0">
                                                                                <Border.Effect>
                                                                                    <DropShadowEffect BlurRadius="16" ShadowDepth="0" Opacity="0.15" Color="#000000"/>
                                                                                </Border.Effect>
                                                                                <ScrollViewer Margin="0,4"
                                                          SnapsToDevicePixels="True">
                                                                                    <StackPanel IsItemsHost="True"
                                                            KeyboardNavigation.DirectionalNavigation="Contained"/>
                                                                                </ScrollViewer>
                                                                            </Border>
                                                                        </Grid>
                                                                    </Popup>
                                                                </Grid>
                                                            </ControlTemplate>
                                                        </Setter.Value>
                                                    </Setter>
                                                </Style>
                                            </ComboBox.Style>
                                            <ComboBox.ItemContainerStyle>
                                                <Style TargetType="ComboBoxItem">
                                                    <Setter Property="Padding" Value="16,12"/>
                                                    <Setter Property="Template">
                                                        <Setter.Value>
                                                            <ControlTemplate TargetType="ComboBoxItem">
                                                                <Border x:Name="Border"
                                    Background="Transparent"
                                    Padding="{TemplateBinding Padding}">
                                                                    <ContentPresenter/>
                                                                </Border>
                                                                <ControlTemplate.Triggers>
                                                                    <Trigger Property="IsMouseOver" Value="True">
                                                                        <Setter TargetName="Border" Property="Background" Value="#F1F5F9"/>
                                                                    </Trigger>
                                                                    <Trigger Property="IsSelected" Value="True">
                                                                        <Setter TargetName="Border" Property="Background" Value="#EFF6FF"/>
                                                                    </Trigger>
                                                                </ControlTemplate.Triggers>
                                                            </ControlTemplate>
                                                        </Setter.Value>
                                                    </Setter>
                                                </Style>
                                            </ComboBox.ItemContainerStyle>
                                            <ComboBoxItem>
                                                <TextBlock Text="Parent" FontSize="17" FontWeight="Medium" Foreground="#1E293B"/>
                                            </ComboBoxItem>
                                            <ComboBoxItem>
                                                <TextBlock Text="Spouse" FontSize="17" FontWeight="Medium" Foreground="#1E293B"/>
                                            </ComboBoxItem>
                                            <ComboBoxItem>
                                                <TextBlock Text="Child" FontSize="17" FontWeight="Medium" Foreground="#1E293B"/>
                                            </ComboBoxItem>
                                            <ComboBoxItem>
                                                <TextBlock Text="Sibling" FontSize="17" FontWeight="Medium" Foreground="#1E293B"/>
                                            </ComboBoxItem>
                                            <ComboBoxItem>
                                                <TextBlock Text="Friend" FontSize="17" FontWeight="Medium" Foreground="#1E293B"/>
                                            </ComboBoxItem>
                                            <ComboBoxItem>
                                                <TextBlock Text="Relative" FontSize="17" FontWeight="Medium" Foreground="#1E293B"/>
                                            </ComboBoxItem>
                                            <ComboBoxItem>
                                                <TextBlock Text="Business Partner" FontSize="17" FontWeight="Medium" Foreground="#1E293B"/>
                                            </ComboBoxItem>
                                            <ComboBoxItem>
                                                <TextBlock Text="Other" FontSize="17" FontWeight="Medium" Foreground="#1E293B"/>
                                            </ComboBoxItem>
                                        </ComboBox>
                                    </StackPanel>
                                    <!-- Row 3: Nationality -->
                                    <StackPanel Grid.Row="2" Grid.Column="0" Margin="0,0,0,0">
                                        <TextBlock x:Name="LblBeneNationality" Text="Nationality *" 
               FontSize="14" 
               FontWeight="SemiBold"
               Foreground="#1E293B"
               Margin="0,0,0,8"/>
                                        <ComboBox x:Name="CmbBeneficiaryNationality" 
              Height="64"
              FontSize="17"
              Foreground="#1E293B"
              Background="White"
              BorderBrush="#E2E8F0"
              BorderThickness="2">
                                            <!-- Use the SAME Style and ItemContainerStyle as Relationship ComboBox above -->
                                            <ComboBox.Style>
                                                <Style TargetType="ComboBox">
                                                    <Setter Property="Template">
                                                        <Setter.Value>
                                                            <ControlTemplate TargetType="ComboBox">
                                                                <Grid>
                                                                    <ToggleButton x:Name="ToggleButton"
                                              Grid.Column="2"
                                              Focusable="false"
                                              IsChecked="{Binding Path=IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                              ClickMode="Press"
                                              Background="White">
                                                                        <ToggleButton.Template>
                                                                            <ControlTemplate TargetType="ToggleButton">
                                                                                <Border Background="{TemplateBinding Background}"
                                                    BorderBrush="#E2E8F0"
                                                    BorderThickness="2"
                                                    CornerRadius="12">
                                                                                    <Grid>
                                                                                        <ContentPresenter Content="{TemplateBinding Content}"
                                                                      Margin="20,0"/>
                                                                                        <Path x:Name="Arrow"
                                                          HorizontalAlignment="Right"
                                                          VerticalAlignment="Center"
                                                          Margin="0,0,20,0"
