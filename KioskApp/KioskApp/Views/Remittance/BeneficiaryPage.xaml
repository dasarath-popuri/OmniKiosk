                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Style>
                                    </ComboBox.ItemContainerStyle>
                                    <ComboBoxItem>
                                        <TextBlock Text="Family Support" FontSize="17" FontWeight="Medium" Foreground="#1E293B"/>
