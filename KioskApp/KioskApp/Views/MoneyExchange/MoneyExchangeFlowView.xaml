<UserControl x:Class="OmniKiosk.Wpf.Views.MoneyExchange.MoneyExchangeFlowView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource BackgroundBrush}"
             Loaded="UserControl_Loaded"
             Unloaded="UserControl_Unloaded">

    <Grid Margin="32">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0" Margin="0,0,0,24">
            <Button Content="←" Width="64" Height="64" Style="{DynamicResource OutlineButton}" BorderThickness="1" Click="Back_Click"/>
            <StackPanel Orientation="Vertical" Margin="24,0,0,0" VerticalAlignment="Center">
                <TextBlock x:Name="TitleText" Text="Money Exchange" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="32" FontWeight="Bold"/>
                <TextBlock x:Name="StepText" Text="Step 1/6" Foreground="{DynamicResource PrimaryBrush}" FontWeight="SemiBold" FontSize="16" Margin="0,4,0,0"/>
            </StackPanel>
        </DockPanel>

        <Border Grid.Row="1" CornerRadius="20" ClipToBounds="True" Background="White">
            <ContentControl x:Name="Host" HorizontalAlignment="Stretch" VerticalAlignment="Stretch"/>
        </Border>
    </Grid>
</UserControl>