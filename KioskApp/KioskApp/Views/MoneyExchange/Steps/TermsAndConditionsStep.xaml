<UserControl x:Class="OmniKiosk.Wpf.Views.MoneyExchange.Steps.TermsAndConditionsStep"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Loaded="UserControl_Loaded" Background="White">

    <UserControl.Resources>
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="#2563EB"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="32"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="16" Padding="32,24">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#E2E8F0"/>
                    <Setter Property="Foreground" Value="#94A3B8"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="OutlineButton" TargetType="Button">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#EF4444"/>
            <Setter Property="BorderBrush" Value="#EF4444"/>
            <Setter Property="BorderThickness" Value="4"/>
            <Setter Property="FontSize" Value="32"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="16" Padding="32,24">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Margin="60">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,40" HorizontalAlignment="Center">
            <TextBlock Text="Terms &amp; Conditions" Foreground="#0F172A" FontSize="56" FontWeight="Black" TextAlignment="Center"/>
            <TextBlock Text="Please read and accept the kiosk policies to proceed." Foreground="#64748B" FontSize="28" Margin="0,16,0,0" TextAlignment="Center"/>
        </StackPanel>

        <Border Grid.Row="1" Background="#F8FAFC" BorderBrush="#E2E8F0" BorderThickness="3" CornerRadius="20" Padding="48" MaxWidth="1400">
            <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0,0,24,0">
                <StackPanel>
                    <TextBlock Text="1. Currency Dispensing Rules" FontWeight="Black" FontSize="32" Foreground="#0F172A" Margin="0,0,0,16"/>
                    <TextBlock Text="This kiosk only dispenses MYR in RM 1, RM 10, RM 50, and RM 100 denominations. Coins are not dispensed." TextWrapping="Wrap" FontSize="26" Foreground="#475569" Margin="0,0,0,40"/>

                    <TextBlock Text="2. Rounding Mechanism" FontWeight="Black" FontSize="32" Foreground="#0F172A" Margin="0,0,0,16"/>
                    <TextBlock Text="Your total exchange amount will be rounded down to the nearest RM 1.00. The remaining decimal value will not be refunded." TextWrapping="Wrap" FontSize="26" Foreground="#475569" Margin="0,0,0,40"/>

                    <TextBlock Text="3. Inserted Cash Policy" FontWeight="Black" FontSize="32" Foreground="#0F172A" Margin="0,0,0,16"/>
                    <TextBlock Text="Once a foreign note is inserted and accepted, it is securely locked in the vault and CANNOT be returned." TextWrapping="Wrap" FontSize="26" Foreground="#EF4444" Margin="0,0,0,40"/>

                    <TextBlock Text="4. Identity Verification" FontWeight="Black" FontSize="32" Foreground="#0F172A" Margin="0,0,0,16"/>
                    <TextBlock Text="By law, all transactions require a valid Passport or Malaysian IC, accompanied by a live face verification scan." TextWrapping="Wrap" FontSize="26" Foreground="#475569" Margin="0,0,0,40"/>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <StackPanel Grid.Row="2" Margin="0,40,0,0" HorizontalAlignment="Stretch" MaxWidth="1400">
            <CheckBox x:Name="ChkAgree" Margin="0,0,0,48" HorizontalAlignment="Center" Checked="ChkAgree_Checked" Unchecked="ChkAgree_Checked">
                <CheckBox.LayoutTransform>
                    <ScaleTransform ScaleX="2.5" ScaleY="2.5"/>
                </CheckBox.LayoutTransform>
                <TextBlock Text="I have read, understood, and accept the Terms &amp; Conditions." FontSize="12" Foreground="#0F172A" FontWeight="Bold" Margin="12,0,0,0" VerticalAlignment="Center"/>
            </CheckBox>
            <Grid>
                <Button x:Name="BtnBack" Content="Decline &amp; Go Back" Width="360" HorizontalAlignment="Left" Click="Back_Click" Style="{StaticResource OutlineButton}"/>
                <Button x:Name="BtnNext" Content="I Agree ➔" Width="360" HorizontalAlignment="Right" IsEnabled="False" Click="Next_Click" Style="{StaticResource PrimaryButton}"/>
            </Grid>
        </StackPanel>
    </Grid>
</UserControl>