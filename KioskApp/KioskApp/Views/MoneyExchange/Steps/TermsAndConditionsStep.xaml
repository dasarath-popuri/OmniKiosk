<UserControl x:Class="OmniKiosk.Wpf.Views.MoneyExchange.Steps.TermsAndConditionsStep"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Loaded="UserControl_Loaded" Background="{StaticResource BackgroundBrush}">

    <Grid Margin="60,40">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,20" HorizontalAlignment="Center">
            <Border Background="{StaticResource AccentGoldLightBrush}" CornerRadius="16" Width="72" Height="72" HorizontalAlignment="Center" Margin="0,0,0,16">
                <TextBlock Text="📜" FontSize="40" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <TextBlock x:Name="TitleText" Style="{StaticResource HeaderText}" TextAlignment="Center" HorizontalAlignment="Center"/>
            <TextBlock x:Name="SubtitleText" Foreground="{StaticResource TextSecondaryBrush}" FontSize="{StaticResource FontSizeSmall}" TextAlignment="Center" HorizontalAlignment="Center" Margin="0,6,0,0"/>
        </StackPanel>

        <Border Grid.Row="1" Style="{StaticResource Card}" Padding="28">
            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <StackPanel>

                    <ItemsControl x:Name="TermsList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{StaticResource BackgroundBrush}" CornerRadius="12" Padding="16" Margin="0,0,0,12">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Border Background="{StaticResource PrimarySurfaceBrush}" CornerRadius="8" Width="36" Height="36" Margin="0,0,16,0">
                                            <TextBlock Text="{Binding Icon}" FontSize="21" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <TextBlock Grid.Column="1" Text="{Binding Text}" FontSize="18" Foreground="{StaticResource TextPrimaryBrush}"
                                                   TextWrapping="Wrap" VerticalAlignment="Center" LineHeight="24"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <Border Background="{StaticResource AccentGoldLightBrush}" CornerRadius="16" Padding="20" Margin="0,8,0,0">
                        <StackPanel>
                            <TextBlock x:Name="ConfirmHeaderText" FontSize="19" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,12" TextWrapping="Wrap"/>
                            <ItemsControl x:Name="ConfirmList">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,0,0,8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="✓" FontSize="19" FontWeight="Bold" Foreground="{StaticResource AccentGoldBrush}" Margin="0,0,10,0"/>
                                            <TextBlock Grid.Column="1" Text="{Binding}" FontSize="17" Foreground="{StaticResource TextPrimaryBrush}" TextWrapping="Wrap" VerticalAlignment="Center"/>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>

                </StackPanel>
            </ScrollViewer>
        </Border>

        <Grid Grid.Row="2" Margin="0,20,0,0">
            <Button x:Name="BtnBack" Width="220" HorizontalAlignment="Left" Click="Back_Click" Style="{StaticResource OutlineButton}"/>
            <Button x:Name="BtnNext" Width="280" HorizontalAlignment="Right" Click="Next_Click" Style="{StaticResource PrimaryButton}"/>
        </Grid>
    </Grid>
</UserControl>
