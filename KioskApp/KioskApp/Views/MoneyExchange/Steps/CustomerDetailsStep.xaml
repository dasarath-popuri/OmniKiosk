<UserControl x:Class="OmniKiosk.Wpf.Views.MoneyExchange.Steps.CustomerDetailsStep"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Loaded="UserControl_Loaded" Unloaded="UserControl_Unloaded" Background="White">

    <UserControl.Resources>
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="#2563EB"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="32"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="16" Padding="32,24">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="OutlineButton" TargetType="Button">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#475569"/>
            <Setter Property="BorderBrush" Value="#CBD5E1"/>
            <Setter Property="BorderThickness" Value="4"/>
            <Setter Property="FontSize" Value="32"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="16" Padding="32,24">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Margin="60">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,40" HorizontalAlignment="Center">
            <TextBlock Text="Identity Verification" Foreground="#0F172A" FontSize="64" FontWeight="Black" TextAlignment="Center"/>
            <TextBlock Text="Please select your nationality to proceed." Foreground="#64748B" FontSize="28" Margin="0,16,0,0" TextAlignment="Center"/>
        </StackPanel>

        <Grid x:Name="ViewSelection" Grid.Row="1" Visibility="Visible" MaxWidth="1400" VerticalAlignment="Center">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="60"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0" Click="BtnMalaysian_Click" Background="White" BorderBrush="#E2E8F0" BorderThickness="4" Cursor="Hand" Height="400">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="24">
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                <TextBlock Text="🇲🇾" FontSize="100" HorizontalAlignment="Center" Margin="0,0,0,24"/>
                                <TextBlock Text="Malaysian Citizen" Foreground="#0F172A" FontSize="40" FontWeight="Black" HorizontalAlignment="Center"/>
                                <TextBlock Text="Scan MyKad (IC)" Foreground="#2563EB" FontSize="28" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,16,0,0"/>
                            </StackPanel>
                        </Border>
                    </ControlTemplate>
                </Button.Template>
            </Button>

            <Button Grid.Column="2" Click="BtnForeigner_Click" Background="White" BorderBrush="#E2E8F0" BorderThickness="4" Cursor="Hand" Height="400">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="24">
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                <TextBlock Text="🌐" FontSize="100" HorizontalAlignment="Center" Margin="0,0,0,24"/>
                                <TextBlock Text="Foreign National" Foreground="#0F172A" FontSize="40" FontWeight="Black" HorizontalAlignment="Center"/>
                                <TextBlock Text="Scan Passport" Foreground="#2563EB" FontSize="28" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,16,0,0"/>
                            </StackPanel>
                        </Border>
                    </ControlTemplate>
                </Button.Template>
            </Button>
        </Grid>

        <Grid x:Name="ViewScanning" Grid.Row="1" Visibility="Collapsed" VerticalAlignment="Center">
            <Border Background="#F8FAFC" BorderBrush="#E2E8F0" BorderThickness="4" CornerRadius="24" Padding="60" MaxWidth="900">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock Text="🪪" FontSize="120" HorizontalAlignment="Center" Margin="0,0,0,32"/>
                    <TextBlock x:Name="AutoReadStatus" Text="Please insert document" Foreground="#0F172A" FontSize="48" FontWeight="Black" TextAlignment="Center"/>
                    <TextBlock x:Name="StatusText" Text="Hardware is reading..." Foreground="#64748B" FontSize="28" Margin="0,24,0,0" TextAlignment="Center"/>
                </StackPanel>
            </Border>
        </Grid>

        <Grid x:Name="ViewResult" Grid.Row="1" Visibility="Collapsed" VerticalAlignment="Center">
            <Border Background="#F8FAFC" BorderBrush="#10B981" BorderThickness="4" CornerRadius="24" Padding="48" MaxWidth="1200">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="60"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" BorderBrush="#CBD5E1" BorderThickness="2" CornerRadius="16" ClipToBounds="True" Width="300" Height="400">
                        <Image x:Name="PortraitImage" Stretch="UniformToFill"/>
                    </Border>

                    <StackPanel Grid.Column="2" VerticalAlignment="Center">
                        <TextBlock Text="Identity Confirmed" Foreground="#10B981" FontSize="36" FontWeight="Black" Margin="0,0,0,32"/>

                        <TextBlock Text="FULL NAME" Foreground="#64748B" FontSize="20" FontWeight="Bold"/>
                        <TextBlock x:Name="TxtName" Foreground="#0F172A" FontSize="48" FontWeight="Black" Margin="0,8,0,32" TextWrapping="Wrap"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="DOCUMENT NO." Foreground="#64748B" FontSize="20" FontWeight="Bold"/>
                                <TextBlock x:Name="TxtIdNo" Foreground="#0F172A" FontSize="32" FontWeight="Bold" Margin="0,8,0,0"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="NATIONALITY" Foreground="#64748B" FontSize="20" FontWeight="Bold"/>
                                <TextBlock x:Name="TxtNat" Foreground="#0F172A" FontSize="32" FontWeight="Bold" Margin="0,8,0,0"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <Grid Grid.Row="2">
            <Button x:Name="BtnBack" Content="Back" Width="260" HorizontalAlignment="Left" Click="Back_Click" Style="{StaticResource OutlineButton}"/>
            <Button x:Name="BtnNext" Content="Verify Face ➔" Width="360" HorizontalAlignment="Right" Visibility="Collapsed" Click="Next_Click" Style="{StaticResource PrimaryButton}"/>
        </Grid>
    </Grid>
</UserControl>