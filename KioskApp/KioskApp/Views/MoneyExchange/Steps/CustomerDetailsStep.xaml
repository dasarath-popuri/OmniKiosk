<UserControl x:Class="OmniKiosk.Wpf.Views.MoneyExchange.Steps.CustomerDetailsStep"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Loaded="UserControl_Loaded" Unloaded="UserControl_Unloaded" Background="{StaticResource BackgroundBrush}">

    <UserControl.Resources>
        <!-- Passport: slides down onto the scanner bed, pauses, resets. Pure
             TranslateTransform + Opacity on plain shapes - same technique as
             the proven-safe cash-note animation in FinalReceiptStep, nothing
             video/bitmap based, so it can't reintroduce the lag we already
             fixed once on the camera screen. -->
        <Storyboard x:Key="PassportPlaceAnim" RepeatBehavior="Forever">
            <DoubleAnimation Storyboard.TargetName="PassportTrans" Storyboard.TargetProperty="Y" From="0" To="78" Duration="0:0:0.9" BeginTime="0:0:0">
                <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseInOut"/></DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="ScannerGlow" Storyboard.TargetProperty="Opacity" From="0.4" To="1" Duration="0:0:0.3" BeginTime="0:0:0.9"/>
            <DoubleAnimation Storyboard.TargetName="ScannerGlow" Storyboard.TargetProperty="Opacity" From="1" To="0.4" Duration="0:0:0.5" BeginTime="0:0:1.6"/>
            <DoubleAnimation Storyboard.TargetName="PassportTrans" Storyboard.TargetProperty="Y" From="78" To="0" Duration="0:0:0.6" BeginTime="0:0:2.3">
                <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseInOut"/></DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>

        <!-- Card: slides horizontally into the reader slot, pauses, resets. -->
        <Storyboard x:Key="CardInsertAnim" RepeatBehavior="Forever">
            <DoubleAnimation Storyboard.TargetName="CardTrans" Storyboard.TargetProperty="X" From="0" To="-95" Duration="0:0:0.8" BeginTime="0:0:0">
                <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseInOut"/></DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="ReaderGlow" Storyboard.TargetProperty="Opacity" From="0.4" To="1" Duration="0:0:0.3" BeginTime="0:0:0.8"/>
            <DoubleAnimation Storyboard.TargetName="ReaderGlow" Storyboard.TargetProperty="Opacity" From="1" To="0.4" Duration="0:0:0.5" BeginTime="0:0:1.5"/>
            <DoubleAnimation Storyboard.TargetName="CardTrans" Storyboard.TargetProperty="X" From="-95" To="0" Duration="0:0:0.5" BeginTime="0:0:2.2">
                <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseInOut"/></DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>
    </UserControl.Resources>

    <Grid Margin="60,32">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,24" HorizontalAlignment="Center">
            <TextBlock x:Name="TitleText" Style="{StaticResource HeaderText}" TextAlignment="Center"/>
            <TextBlock x:Name="SubtitleText" Foreground="{StaticResource TextSecondaryBrush}" FontSize="{StaticResource FontSizeSmall}" Margin="0,8,0,0" TextAlignment="Center"/>
        </StackPanel>

        <!-- DOCUMENT TYPE SELECTION - "which document do you have", not tied
             to nationality, since a Malaysian can hold a passport too. -->
        <Grid x:Name="ViewSelection" Grid.Row="1" Visibility="Visible" MaxWidth="1200" VerticalAlignment="Center">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="40"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="{StaticResource CardBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="16" Padding="24" Cursor="Hand" Height="340" MouseDown="BtnIc_Click">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock Text="🪪" FontSize="90" HorizontalAlignment="Center" Margin="0,0,0,20"/>
                    <TextBlock x:Name="IcTitle" FontFamily="{StaticResource DisplayFont}" FontSize="30" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}" HorizontalAlignment="Center"/>
                    <TextBlock x:Name="IcSubtitle" Foreground="{StaticResource AccentGoldBrush}" FontSize="18" FontWeight="SemiBold" HorizontalAlignment="Center" Margin="0,10,0,0"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="2" Background="{StaticResource CardBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="16" Padding="24" Cursor="Hand" Height="340" MouseDown="BtnPassport_Click">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock Text="🛂" FontSize="90" HorizontalAlignment="Center" Margin="0,0,0,20"/>
                    <TextBlock x:Name="PassportTitle" FontFamily="{StaticResource DisplayFont}" FontSize="30" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}" HorizontalAlignment="Center"/>
                    <TextBlock x:Name="PassportSubtitle" Foreground="{StaticResource AccentGoldBrush}" FontSize="18" FontWeight="SemiBold" HorizontalAlignment="Center" Margin="0,10,0,0"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- READING / SCANNING - animation + guidance text specific to which
             document was chosen. -->
        <Grid x:Name="ViewScanning" Grid.Row="1" Visibility="Collapsed" VerticalAlignment="Center">
            <Border Background="{StaticResource CardBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="16" Padding="48" MaxWidth="800">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">

                    <!-- Passport placement stage -->
                    <Grid x:Name="PassportAnimStage" Width="260" Height="170" Visibility="Collapsed" Margin="0,0,0,28">
                        <Border x:Name="ScannerGlow" Width="220" Height="10" Background="{StaticResource AccentGoldBrush}" CornerRadius="5" VerticalAlignment="Bottom" Margin="0,0,0,44" Opacity="0.4"/>
                        <Border Width="240" Height="34" Background="{StaticResource TextPrimaryBrush}" CornerRadius="8" VerticalAlignment="Bottom"/>
                        <Border Width="130" Height="88" Background="{StaticResource PrimaryBrush}" BorderBrush="{StaticResource AccentGoldBrush}" BorderThickness="3" CornerRadius="6" VerticalAlignment="Top">
                            <Border.RenderTransform>
                                <TranslateTransform x:Name="PassportTrans" Y="0"/>
                            </Border.RenderTransform>
                            <TextBlock Text="🛂" FontSize="34" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </Grid>

                    <!-- Card insertion stage -->
                    <Grid x:Name="CardAnimStage" Width="260" Height="130" Visibility="Collapsed" Margin="0,0,0,28">
                        <Border Width="70" Height="90" Background="{StaticResource TextPrimaryBrush}" CornerRadius="8" HorizontalAlignment="Right">
                            <Border x:Name="ReaderGlow" Width="8" Height="60" Background="{StaticResource AccentGoldBrush}" CornerRadius="4" HorizontalAlignment="Left" Margin="10,0,0,0" Opacity="0.4"/>
                        </Border>
                        <Border Width="130" Height="82" Background="{StaticResource PrimaryBrush}" BorderBrush="{StaticResource AccentGoldBrush}" BorderThickness="3" CornerRadius="6" HorizontalAlignment="Right" Margin="0,0,150,0">
                            <Border.RenderTransform>
                                <TranslateTransform x:Name="CardTrans" X="0"/>
                            </Border.RenderTransform>
                            <TextBlock Text="🪪" FontSize="34" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </Grid>

                    <TextBlock x:Name="AutoReadStatus" FontFamily="{StaticResource DisplayFont}" FontSize="28" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}" TextAlignment="Center" TextWrapping="Wrap"/>
                    <TextBlock x:Name="StatusText" Foreground="{StaticResource TextSecondaryBrush}" FontSize="{StaticResource FontSizeSmall}" Margin="0,14,0,0" TextAlignment="Center"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- RESULT - denser than before: photo sized down slightly, fields in
             a tighter 3-per-row grid instead of 2, expiry shown for passports. -->
        <Grid x:Name="ViewResult" Grid.Row="1" Visibility="Collapsed" VerticalAlignment="Center">
            <Border Background="{StaticResource CardBrush}" BorderBrush="{StaticResource AccentBrush}" BorderThickness="2" CornerRadius="16" Padding="32" MaxWidth="1200">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="32"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="14" ClipToBounds="True" Width="200" Height="260">
                        <Image x:Name="PortraitImage" Stretch="UniformToFill"/>
                    </Border>

                    <StackPanel Grid.Column="2" VerticalAlignment="Center">
                        <TextBlock x:Name="IdentityConfirmedText" Foreground="{StaticResource AccentBrush}" FontSize="19" FontWeight="Bold" Margin="0,0,0,10"/>
                        <TextBlock x:Name="TxtName" FontFamily="{StaticResource DisplayFont}" FontSize="28" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,14" TextWrapping="Wrap"/>

                        <UniformGrid Columns="3" Margin="0,0,0,14">
                            <StackPanel Margin="0,0,10,0">
                                <TextBlock x:Name="DocNoLabel" Style="{StaticResource FieldLabel}"/>
                                <TextBlock x:Name="TxtIdNo" FontSize="18" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}"/>
                            </StackPanel>
                            <StackPanel Margin="0,0,10,0">
                                <TextBlock x:Name="NationalityLabel" Style="{StaticResource FieldLabel}"/>
                                <TextBlock x:Name="TxtNat" FontSize="18" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}"/>
                            </StackPanel>
                            <StackPanel>
                                <TextBlock x:Name="GenderLabel" Style="{StaticResource FieldLabel}"/>
                                <TextBlock x:Name="TxtGender" FontSize="18" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}"/>
                            </StackPanel>
                        </UniformGrid>

                        <UniformGrid Columns="3" Margin="0,0,0,18">
                            <StackPanel Margin="0,0,10,0">
                                <TextBlock x:Name="DobLabel" Style="{StaticResource FieldLabel}"/>
                                <TextBlock x:Name="TxtDob" FontSize="18" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}"/>
                            </StackPanel>
                            <StackPanel x:Name="ExpiryPanel" Margin="0,0,10,0" Visibility="Collapsed">
                                <TextBlock x:Name="ExpiryLabel" Style="{StaticResource FieldLabel}"/>
                                <TextBlock x:Name="TxtExpiry" FontSize="18" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}"/>
                            </StackPanel>
                        </UniformGrid>

                        <TextBlock x:Name="MobileLabel" Style="{StaticResource FieldLabel}"/>
                        <TextBox x:Name="TxtMobile" Style="{StaticResource ModernTextBox}" Width="320" HorizontalAlignment="Left"
                                 MaxLength="15" TextChanged="TxtMobile_TextChanged"/>
                        <TextBlock x:Name="MobileHintText" Foreground="{StaticResource TextSecondaryBrush}" FontSize="13" Margin="0,6,0,0"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <Grid Grid.Row="2" Margin="0,24,0,0">
            <Button x:Name="BtnBack" Width="220" HorizontalAlignment="Left" Click="Back_Click" Style="{StaticResource OutlineButton}"/>
            <Button x:Name="BtnNext" Width="320" HorizontalAlignment="Right" IsEnabled="False" Visibility="Collapsed" Click="Next_Click" Style="{StaticResource PrimaryButton}"/>
        </Grid>
    </Grid>
</UserControl>
