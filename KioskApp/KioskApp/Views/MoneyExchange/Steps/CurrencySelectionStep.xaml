<UserControl x:Class="OmniKiosk.Wpf.Views.MoneyExchange.Steps.CurrencySelectionStep"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:svgc="http://sharpvectors.codeplex.com/svgc/"
             Loaded="UserControl_Loaded" Background="{StaticResource BackgroundBrush}">

    <Grid Margin="60,40">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,28" HorizontalAlignment="Center">
            <TextBlock x:Name="TitleText" Style="{StaticResource HeaderText}" TextAlignment="Center" HorizontalAlignment="Center"/>
            <TextBlock x:Name="SubtitleText" Foreground="{StaticResource TextSecondaryBrush}" FontSize="{StaticResource FontSizeSmall}" TextAlignment="Center" HorizontalAlignment="Center" Margin="0,8,0,0"/>
        </StackPanel>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <ItemsControl x:Name="LstCurrencies">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel HorizontalAlignment="Center" Orientation="Horizontal"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border x:Name="Bd" Style="{StaticResource Card}" Width="220" Height="240" Margin="12"
                                Tag="{Binding}" MouseDown="CurrencyCard_MouseDown" Cursor="Hand">
                            <StackPanel VerticalAlignment="Center">

                                <!-- Updated border for the flag to differentiate it from the background -->
                                <Border Width="72" Height="52" CornerRadius="8" ClipToBounds="True" Background="{StaticResource BackgroundBrush}" BorderThickness="2" BorderBrush="{StaticResource BorderBrush}" Margin="0,0,0,14" HorizontalAlignment="Center">
                                    <svgc:SvgViewbox Source="{Binding FlagUri}" Stretch="UniformToFill"/>
                                </Border>

                                <TextBlock Text="{Binding Code}" FontFamily="{StaticResource DisplayFont}" FontSize="28" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}" HorizontalAlignment="Center"/>
                                <TextBlock Text="{Binding CountryName}" FontSize="16" Foreground="{StaticResource TextSecondaryBrush}" HorizontalAlignment="Center" Margin="0,2,0,14" TextAlignment="Center" TextWrapping="Wrap" MaxWidth="170"/>
                                <Border Background="{StaticResource BackgroundBrush}" CornerRadius="8" Padding="10,6">
                                    <TextBlock Text="{Binding RateDisplay}" Style="{StaticResource DataMono}" FontSize="16" HorizontalAlignment="Center"/>
                                </Border>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <Grid Grid.Row="2" Margin="0,28,0,0">
            <Button x:Name="BtnBack" Width="220" HorizontalAlignment="Left" Click="Back_Click" Style="{StaticResource OutlineButton}"/>
            <Button x:Name="BtnNext" Width="280" HorizontalAlignment="Right" IsEnabled="False" Click="Next_Click" Style="{StaticResource PrimaryButton}"/>
        </Grid>
    </Grid>
</UserControl>
