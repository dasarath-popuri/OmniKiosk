<UserControl x:Class="OmniKiosk.Wpf.Views.MoneyExchange.Steps.FaceVerificationStep"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:OmniKiosk.Wpf.Views.SDKTest"
             Loaded="UserControl_Loaded" Unloaded="UserControl_Unloaded" Background="White">

    <UserControl.Resources>
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="#2563EB"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="32"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="16" Padding="32,24">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="OutlineButton" TargetType="Button">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#475569"/>
            <Setter Property="BorderBrush" Value="#CBD5E1"/>
            <Setter Property="BorderThickness" Value="4"/>
            <Setter Property="FontSize" Value="32"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="16" Padding="32,24">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="WarningButton" TargetType="Button">
            <Setter Property="Background" Value="#F59E0B"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="32"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="16" Padding="32,24">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Margin="60">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,40" HorizontalAlignment="Center">
            <TextBlock x:Name="Hdr" Text="Face Verification" Foreground="#0F172A" FontSize="64" FontWeight="Black" TextAlignment="Center"/>
            <TextBlock Text="Please look at the camera to match your face with your ID document." Foreground="#64748B" FontSize="28" Margin="0,16,0,0" TextAlignment="Center"/>
        </StackPanel>

        <Border Grid.Row="1" Background="#F8FAFC" BorderBrush="#E2E8F0" BorderThickness="4" CornerRadius="24" Padding="40" HorizontalAlignment="Center" VerticalAlignment="Center">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">

                <Grid Width="640" Height="480" ClipToBounds="True">
                    <Border CornerRadius="16" ClipToBounds="True" Background="Black">
                        <local:NativeVideoHost x:Name="VisHost" />
                    </Border>

                    <local:NativeVideoHost x:Name="NirHost" Width="1" Height="1" Opacity="0"/>

                    <Path Fill="#CC0F172A">
                        <Path.Data>
                            <GeometryGroup FillRule="EvenOdd">
                                <RectangleGeometry Rect="0,0,640,480"/>
                                <EllipseGeometry Center="320,240" RadiusX="140" RadiusY="190"/>
                            </GeometryGroup>
                        </Path.Data>
                    </Path>
                    <Ellipse Width="280" Height="380" Stroke="#2563EB" StrokeThickness="6" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Grid>

                <Border Background="White" BorderBrush="#E2E8F0" BorderThickness="2" CornerRadius="12" Padding="24,16" HorizontalAlignment="Center" Margin="0,32,0,0">
                    <StackPanel>
                        <TextBlock x:Name="StatusText" Text="Initializing Camera..." Foreground="#2563EB" FontSize="24" FontWeight="Bold" HorizontalAlignment="Center"/>
                        <TextBlock x:Name="HintText" Text="Align your face in the frame" Foreground="#64748B" FontSize="18" Margin="0,8,0,0" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Border>

        <Grid Grid.Row="2" Margin="0,40,0,0">
            <Button x:Name="BtnSkipBack" Content="Back" Width="260" HorizontalAlignment="Left" Click="Back_Click" Style="{StaticResource OutlineButton}"/>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button x:Name="BtnSkip" Content="Skip &amp; Continue ➔" Width="360" Margin="0,0,24,0" Visibility="Collapsed" Click="Skip_Click" Style="{StaticResource WarningButton}"/>
                <Button x:Name="BtnRetry" Content="Retry Scan" Width="360" Click="Retry_Click" Style="{StaticResource PrimaryButton}"/>
            </StackPanel>
        </Grid>

        <Popup x:Name="WelcomePopup" PlacementTarget="{Binding ElementName=Root}" Placement="Center" AllowsTransparency="True" IsOpen="False">
            <Border Background="#CC0F172A" CornerRadius="24" Padding="60">
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock Text="✅" FontSize="120" HorizontalAlignment="Center" Margin="0,0,0,24"/>
                    <TextBlock x:Name="WelcomeTitle" Text="Identity Verified" Foreground="White" FontSize="48" FontWeight="Black" TextAlignment="Center"/>
                    <TextBlock x:Name="WelcomeName" Text="Name" Foreground="#94A3B8" FontSize="36" Margin="0,16,0,0" TextAlignment="Center"/>
                </StackPanel>
            </Border>
        </Popup>

        <Popup x:Name="FailPopup" PlacementTarget="{Binding ElementName=Root}" Placement="Center" AllowsTransparency="True" IsOpen="False">
            <Border Background="White" BorderBrush="#EF4444" BorderThickness="6" CornerRadius="24" Padding="60" Width="800">
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock Text="⚠️" Foreground="#EF4444" FontSize="120" HorizontalAlignment="Center" Margin="0,0,0,24"/>
                    <TextBlock Text="Verification Failed" Foreground="#0F172A" FontSize="48" FontWeight="Black" TextAlignment="Center"/>
                    <TextBlock Text="Your face did not match the document. Please proceed to the counter for manual assistance." Foreground="#64748B" FontSize="28" Margin="0,24,0,40" TextAlignment="Center" TextWrapping="Wrap"/>
                    <Button Content="Exit Transaction" Width="360" Height="80" Click="FailAcknowledge_Click" Style="{StaticResource PrimaryButton}"/>
                </StackPanel>
            </Border>
        </Popup>
    </Grid>
</UserControl>