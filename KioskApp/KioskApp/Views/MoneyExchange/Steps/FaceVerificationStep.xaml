<UserControl x:Class="OmniKiosk.Wpf.Views.MoneyExchange.Steps.FaceVerificationStep"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:OmniKiosk.Wpf.Views.SDKTest"
             Loaded="UserControl_Loaded" Unloaded="UserControl_Unloaded" Background="{StaticResource BackgroundBrush}">

    <Grid Margin="60,32">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,20" HorizontalAlignment="Center">
            <TextBlock x:Name="Hdr" Style="{StaticResource HeaderText}" TextAlignment="Center"/>
            <TextBlock x:Name="SubtitleText" Foreground="{StaticResource TextSecondaryBrush}" FontSize="{StaticResource FontSizeSmall}" Margin="0,8,0,16" TextAlignment="Center"/>

            <!-- Branch-aware instructions: wording differs for a recognized
                 returning customer (local match) vs first-time eKYC. -->
            <Border x:Name="InstructionsBanner" Background="{StaticResource PrimarySurfaceBrush}" CornerRadius="14" Padding="24,16" MaxWidth="800">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <TextBlock x:Name="InstructionsIcon" FontSize="32" Margin="0,0,16,0" VerticalAlignment="Center"/>
                    <StackPanel>
                        <TextBlock x:Name="InstructionsTitle" FontSize="20" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}"/>
                        <TextBlock x:Name="InstructionsBody" FontSize="17" Foreground="{StaticResource TextSecondaryBrush}" TextWrapping="Wrap" MaxWidth="680" Margin="0,4,0,0"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </StackPanel>

        <!-- Deliberately NOT using Style="{StaticResource Card}" here. Card
             carries a RenderTransform for the menu-tile press animation, and
             RenderTransform on a border that contains an HwndHost (VisHost /
             NirHost below) is a known WPF rough edge - native child windows
             don't participate in WPF's transform system cleanly, and just
             having a non-null RenderTransform present can force extra
             repositioning/compositing work on the native window underneath,
             even while sitting at an identity scale. A live camera preview
             is never tapped for press feedback anyway, so it never needed
             the Card style's animation - same look, built by hand, no
             RenderTransform anywhere in the tree. -->
        <Border Grid.Row="1" Background="{StaticResource CardBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="16" Padding="24" HorizontalAlignment="Center" VerticalAlignment="Center">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">

                <Grid Width="640" Height="480" ClipToBounds="True">
                    <Border CornerRadius="16" ClipToBounds="True" Background="Black">
                        <local:NativeVideoHost x:Name="VisHost" />
                    </Border>

                    <local:NativeVideoHost x:Name="NirHost" Width="1" Height="1" Opacity="0"/>

                    <Path Fill="#CC0F172A">
                        <Path.Data>
                            <GeometryGroup FillRule="EvenOdd">
                                <RectangleGeometry Rect="0,0,640,480"/>
                                <EllipseGeometry Center="320,240" RadiusX="140" RadiusY="190"/>
                            </GeometryGroup>
                        </Path.Data>
                    </Path>
                    <Ellipse Width="280" Height="380" Stroke="{StaticResource PrimaryBrush}" StrokeThickness="6" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Grid>

                <Border Background="{StaticResource CardBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="12" Padding="24,16" HorizontalAlignment="Center" Margin="0,28,0,0">
                    <StackPanel>
                        <TextBlock x:Name="StatusText" Foreground="{StaticResource PrimaryBrush}" FontSize="24" FontWeight="Bold" HorizontalAlignment="Center"/>
                        <TextBlock x:Name="HintText" Foreground="{StaticResource TextSecondaryBrush}" FontSize="18" Margin="0,6,0,0" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Border>

        <Grid Grid.Row="2" Margin="0,28,0,0">
            <Button x:Name="BtnSkipBack" Width="220" HorizontalAlignment="Left" Click="Back_Click" Style="{StaticResource OutlineButton}"/>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button x:Name="BtnSkip" Width="320" Margin="0,0,20,0" Visibility="Collapsed" Click="Skip_Click" Style="{StaticResource PrimaryButton}" Background="{StaticResource WarningBrush}"/>
                <Button x:Name="BtnRetry" Width="280" Click="Retry_Click" Style="{StaticResource PrimaryButton}"/>
            </StackPanel>
        </Grid>

        <Popup x:Name="WelcomePopup" Placement="Center" AllowsTransparency="True" IsOpen="False">
            <Border Background="#CC0E4B43" CornerRadius="24" Padding="60">
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock Text="✅" FontSize="124" HorizontalAlignment="Center" Margin="0,0,0,24"/>
                    <TextBlock x:Name="WelcomeTitle" Foreground="White" FontSize="46" FontWeight="Black" TextAlignment="Center"/>
                    <TextBlock x:Name="WelcomeName" Foreground="#CFE3E0" FontSize="36" Margin="0,16,0,0" TextAlignment="Center"/>
                </StackPanel>
            </Border>
        </Popup>

        <Popup x:Name="FailPopup" Placement="Center" AllowsTransparency="True" IsOpen="False">
            <Border Background="{StaticResource CardBrush}" BorderBrush="{StaticResource DangerBrush}" BorderThickness="4" CornerRadius="24" Padding="60" Width="760">
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock Text="⚠️" Foreground="{StaticResource DangerBrush}" FontSize="104" HorizontalAlignment="Center" Margin="0,0,0,24"/>
                    <TextBlock x:Name="FailTitle" Foreground="{StaticResource TextPrimaryBrush}" FontSize="40" FontWeight="Black" TextAlignment="Center"/>
                    <TextBlock x:Name="FailBody" Foreground="{StaticResource TextSecondaryBrush}" FontSize="24" Margin="0,20,0,36" TextAlignment="Center" TextWrapping="Wrap"/>
                    <Button x:Name="FailAcknowledgeButton" Width="320" Height="72" Click="FailAcknowledge_Click" Style="{StaticResource PrimaryButton}" Background="{StaticResource DangerBrush}"/>
                </StackPanel>
            </Border>
        </Popup>
    </Grid>
</UserControl>
