<UserControl x:Class="OmniKiosk.Wpf.Views.MoneyExchange.Steps.CashInStep"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Loaded="UserControl_Loaded" Unloaded="UserControl_Unloaded" Background="{StaticResource BackgroundBrush}">

    <Grid>
        <Grid Margin="60,32">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="0,0,0,28">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock x:Name="TitleText" Style="{StaticResource HeaderText}"/>
                    <TextBlock x:Name="SubtitleText" Foreground="{StaticResource TextSecondaryBrush}" FontSize="{StaticResource FontSizeSmall}" Margin="0,8,0,0"/>
                </StackPanel>

                <Border Grid.Column="1" Background="{StaticResource PrimarySurfaceBrush}" CornerRadius="14" Padding="24,14" VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock x:Name="RateLabel" Foreground="{StaticResource TextSecondaryBrush}" FontSize="21" FontWeight="SemiBold"/>
                        <TextBlock x:Name="TxtLiveRate" Foreground="{StaticResource PrimaryBrush}" FontSize="21" FontWeight="Bold" Margin="6,0,0,0"/>
                    </StackPanel>
                </Border>
            </Grid>

            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.3*"/>
                    <ColumnDefinition Width="32"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Style="{StaticResource Card}" Padding="40">
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock x:Name="InsertedLabel" Style="{StaticResource FieldLabel}"/>
                        <TextBlock x:Name="TxtInsertedForeign" FontFamily="{StaticResource DisplayFont}" Foreground="{StaticResource TextPrimaryBrush}" FontSize="60" FontWeight="Bold" Margin="0,4,0,32"/>

                        <TextBlock x:Name="EquivalentLabel" Style="{StaticResource FieldLabel}"/>
                        <TextBlock x:Name="TxtEquivalentMyr" FontFamily="{StaticResource DisplayFont}" Foreground="{StaticResource TextPrimaryBrush}" FontSize="42" FontWeight="Bold" Margin="0,4,0,32"/>

                        <Border Background="{StaticResource PrimarySurfaceBrush}" BorderBrush="{StaticResource PrimaryBrush}" BorderThickness="2" CornerRadius="16" Padding="32">
                            <StackPanel>
                                <TextBlock x:Name="PayableLabel" Foreground="{StaticResource PrimaryBrush}" FontSize="19" FontWeight="Bold"/>
                                <TextBlock x:Name="TxtPayableMyr" FontFamily="{StaticResource DisplayFont}" Foreground="{StaticResource PrimaryBrush}" FontSize="68" FontWeight="Black" Margin="0,4,0,0"/>
                            </StackPanel>
                        </Border>

                        <StackPanel Orientation="Horizontal" Margin="0,32,0,0" HorizontalAlignment="Center">
                            <Ellipse x:Name="StatusDot" Width="14" Height="14" Fill="{StaticResource AccentBrush}" Margin="0,0,12,0" VerticalAlignment="Center"/>
                            <TextBlock x:Name="TxtStatus" Foreground="{StaticResource TextSecondaryBrush}" FontSize="19" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Note slot illustration - a calmer, customer-facing replacement
                     for the raw hardware log that used to render here. The log
                     events still fire (Svc_OnLog), just no longer as visible text -
                     technicians have other ways to diagnose a specific kiosk. -->
                <Border Grid.Column="2" Style="{StaticResource Card}" Padding="32">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <Border Width="180" Height="110" Background="{StaticResource BackgroundBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="2" CornerRadius="12" HorizontalAlignment="Center">
                            <Border Width="150" Height="10" Background="{StaticResource TextDisabledBrush}" CornerRadius="4" VerticalAlignment="Top" Margin="0,14,0,0"/>
                        </Border>
                        <TextBlock x:Name="SlotHintText" Foreground="{StaticResource TextSecondaryBrush}" FontSize="19" TextAlignment="Center" TextWrapping="Wrap" Margin="0,24,0,0" MaxWidth="280"/>
                    </StackPanel>
                </Border>
            </Grid>

            <Grid Grid.Row="2" Margin="0,28,0,0">
                <Button x:Name="BtnBack" Width="300" HorizontalAlignment="Left" Click="Back_Click" Style="{StaticResource OutlineButton}" Foreground="{StaticResource DangerBrush}" BorderBrush="{StaticResource DangerBrush}"/>
                <Button x:Name="BtnNext" Width="360" HorizontalAlignment="Right" IsEnabled="False" Click="Next_Click" Style="{StaticResource PrimaryButton}"/>
            </Grid>
        </Grid>

        <Border x:Name="EscrowOverlay" Visibility="Collapsed" Background="#CC121816" Panel.ZIndex="999">
            <Border Background="{StaticResource CardBrush}" CornerRadius="24" Padding="56" HorizontalAlignment="Center" VerticalAlignment="Center" MinWidth="700">
                <StackPanel>
                    <TextBlock x:Name="NoteDetectedLabel" Foreground="{StaticResource TextSecondaryBrush}" FontSize="24" FontWeight="Bold" HorizontalAlignment="Center"/>
                    <TextBlock x:Name="TxtEscrowAmount" FontFamily="{StaticResource DisplayFont}" Foreground="{StaticResource TextPrimaryBrush}" FontSize="60" FontWeight="Black" Margin="0,12,0,44" HorizontalAlignment="Center"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="24"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Button x:Name="BtnEscrowReturn" Grid.Column="0" Click="EscrowReturn_Click" Style="{StaticResource OutlineButton}"/>
                        <Button x:Name="BtnEscrowAccept" Grid.Column="2" Click="EscrowAccept_Click" Style="{StaticResource PrimaryButton}"/>
                    </Grid>
                </StackPanel>
            </Border>
        </Border>

        <Border x:Name="DoneOverlay" Visibility="Collapsed" Background="{StaticResource PrimaryBrush}" Panel.ZIndex="999">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock Text="✅" FontSize="104" HorizontalAlignment="Center" Margin="0,0,0,20"/>
                <TextBlock x:Name="DoneTitle" Foreground="White" FontSize="48" FontWeight="Black" TextAlignment="Center"/>
                <TextBlock x:Name="DoneSubtitle" Foreground="#CFE3E0" FontSize="26" Margin="0,12,0,0" TextAlignment="Center"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
