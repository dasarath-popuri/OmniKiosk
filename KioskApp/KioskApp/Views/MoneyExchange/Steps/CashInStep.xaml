<UserControl x:Class="OmniKiosk.Wpf.Views.MoneyExchange.Steps.CashInStep"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Loaded="UserControl_Loaded" Unloaded="UserControl_Unloaded" Background="White">

    <UserControl.Resources>
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="#2563EB"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="32"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="16" Padding="32,24">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#E2E8F0"/>
                    <Setter Property="Foreground" Value="#94A3B8"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="OutlineButton" TargetType="Button">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#EF4444"/>
            <Setter Property="BorderBrush" Value="#EF4444"/>
            <Setter Property="BorderThickness" Value="4"/>
            <Setter Property="FontSize" Value="32"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="16" Padding="32,24">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>

        <Grid Margin="60">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="0,0,0,40">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="Insert Cash" Foreground="#0F172A" FontSize="64" FontWeight="Black"/>
                    <TextBlock Text="Please insert your notes into the acceptor below." Foreground="#64748B" FontSize="28" Margin="0,16,0,0"/>
                </StackPanel>

                <Border Grid.Column="1" Background="#F8FAFC" BorderBrush="#E2E8F0" BorderThickness="3" CornerRadius="16" Padding="32,20" VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Rate: " Foreground="#64748B" FontSize="28" FontWeight="SemiBold"/>
                        <TextBlock x:Name="TxtLiveRate" Text="1 USD = 4.75 MYR" Foreground="#2563EB" FontSize="28" FontWeight="Black"/>
                    </StackPanel>
                </Border>
            </Grid>

            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.5*"/>
                    <ColumnDefinition Width="60"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Background="#F8FAFC" BorderBrush="#E2E8F0" BorderThickness="3" CornerRadius="24" Padding="48">
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="TOTAL INSERTED (FOREIGN)" Foreground="#64748B" FontSize="24" FontWeight="Bold"/>
                        <TextBlock x:Name="TxtInsertedForeign" Text="0.00" Foreground="#0F172A" FontSize="80" FontWeight="Black" Margin="0,8,0,48"/>

                        <TextBlock Text="EQUIVALENT AMOUNT (MYR)" Foreground="#64748B" FontSize="24" FontWeight="Bold"/>
                        <TextBlock x:Name="TxtEquivalentMyr" Text="RM 0.00" Foreground="#0F172A" FontSize="56" FontWeight="Bold" Margin="0,8,0,48"/>

                        <Border Background="#ECFDF5" BorderBrush="#10B981" BorderThickness="4" CornerRadius="20" Padding="40">
                            <StackPanel>
                                <TextBlock Text="PAYABLE AMOUNT (ROUNDED)" Foreground="#047857" FontSize="24" FontWeight="Bold"/>
                                <TextBlock x:Name="TxtPayableMyr" Text="RM 0" Foreground="#10B981" FontSize="96" FontWeight="Black" Margin="0,8,0,0"/>
                            </StackPanel>
                        </Border>

                        <StackPanel Orientation="Horizontal" Margin="0,48,0,0" VerticalAlignment="Center" HorizontalAlignment="Center">
                            <Ellipse Width="24" Height="24" Fill="#2563EB" Margin="0,0,16,0"/>
                            <TextBlock Text="Machine is ready and accepting notes..." Foreground="#2563EB" FontSize="28" FontWeight="Bold"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <Border Grid.Column="2" Background="#F8FAFC" BorderBrush="#E2E8F0" BorderThickness="3" CornerRadius="24" Padding="32">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,24">
                            <TextBlock Text="Hardware Log" Foreground="#0F172A" FontSize="32" FontWeight="Black"/>
                            <TextBlock x:Name="TxtStatus" Text="• Online" Foreground="#10B981" FontSize="24" FontWeight="Bold" Margin="16,6,0,0"/>
                        </StackPanel>
                        <TextBox x:Name="TxtLog" Grid.Row="1" Background="White" BorderThickness="2" BorderBrush="#E2E8F0" Foreground="#475569" FontSize="20" IsReadOnly="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" FontFamily="Consolas" Padding="20" />
                    </Grid>
                </Border>
            </Grid>

            <Grid Grid.Row="2" Margin="0,40,0,0">
                <Button x:Name="BtnBack" Content="Cancel Transaction" Width="360" HorizontalAlignment="Left" Click="Back_Click" Style="{StaticResource OutlineButton}"/>
                <Button x:Name="BtnNext" Content="Finish &amp; Get Cash ➔" Width="400" HorizontalAlignment="Right" IsEnabled="False" Click="Next_Click" Style="{StaticResource PrimaryButton}"/>
            </Grid>
        </Grid>

        <Border x:Name="EscrowOverlay" Visibility="Collapsed" Background="#E60F172A" Panel.ZIndex="999">
            <Border Background="White" CornerRadius="24" Padding="60" HorizontalAlignment="Center" VerticalAlignment="Center" MinWidth="800">
                <StackPanel>
                    <TextBlock Text="Note Detected" Foreground="#64748B" FontSize="32" FontWeight="Bold" HorizontalAlignment="Center"/>
                    <TextBlock x:Name="TxtEscrowAmount" Text="100 USD" Foreground="#0F172A" FontSize="80" FontWeight="Black" Margin="0,16,0,60" HorizontalAlignment="Center"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="40"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0" Content="Return Note" Click="EscrowReturn_Click" Style="{StaticResource OutlineButton}"/>
                        <Button Grid.Column="2" Content="Accept Note" Click="EscrowAccept_Click" Style="{StaticResource PrimaryButton}"/>
                    </Grid>
                </StackPanel>
            </Border>
        </Border>

        <Border x:Name="DoneOverlay" Visibility="Collapsed" Background="#E60F172A" Panel.ZIndex="999">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock Text="✅" FontSize="120" HorizontalAlignment="Center" Margin="0,0,0,24"/>
                <TextBlock Text="Acceptance Stopped" Foreground="White" FontSize="56" FontWeight="Black" TextAlignment="Center"/>
                <TextBlock Text="Proceeding to dispense your cash..." Foreground="#94A3B8" FontSize="32" Margin="0,16,0,0" TextAlignment="Center"/>
            </StackPanel>
        </Border>

    </Grid>
</UserControl>