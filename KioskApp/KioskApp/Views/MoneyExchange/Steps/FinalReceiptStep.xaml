<UserControl x:Class="OmniKiosk.Wpf.Views.MoneyExchange.Steps.FinalReceiptStep"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Loaded="UserControl_Loaded" Background="White">

    <UserControl.Resources>
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="#10B981"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="32"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="16" Padding="32,24">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="OutlineButton" TargetType="Button">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#2563EB"/>
            <Setter Property="BorderBrush" Value="#2563EB"/>
            <Setter Property="BorderThickness" Value="4"/>
            <Setter Property="FontSize" Value="32"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="16" Padding="32,24">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Storyboard x:Key="DispenseAnim" RepeatBehavior="Forever">
            <DoubleAnimation Storyboard.TargetName="CashNoteTrans" Storyboard.TargetProperty="Y" From="-150" To="100" Duration="0:0:1.5">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="CashNote" Storyboard.TargetProperty="Opacity" From="1" To="0" BeginTime="0:0:1.2" Duration="0:0:0.3"/>
        </Storyboard>
    </UserControl.Resources>

    <UserControl.Triggers>
        <EventTrigger RoutedEvent="FrameworkElement.Loaded">
            <BeginStoryboard Storyboard="{StaticResource DispenseAnim}"/>
        </EventTrigger>
    </UserControl.Triggers>

    <Grid Margin="60">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,40" HorizontalAlignment="Center">
            <TextBlock Text="Transaction Complete" Foreground="#0F172A" FontSize="64" FontWeight="Black" TextAlignment="Center"/>
            <TextBlock Text="Please collect your cash from the dispenser below." Foreground="#64748B" FontSize="28" Margin="0,16,0,0" TextAlignment="Center"/>
        </StackPanel>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="4*"/>
                <ColumnDefinition Width="60"/>
                <ColumnDefinition Width="6*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="#F8FAFC" BorderBrush="#E2E8F0" BorderThickness="3" CornerRadius="24" Padding="40">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Stretch">

                    <Grid Height="240" Margin="0,0,0,24" ClipToBounds="True">
                        <Border Width="260" Height="24" Background="#0F172A" CornerRadius="12" VerticalAlignment="Top" Panel.ZIndex="10">
                            <Border.Effect>
                                <DropShadowEffect ShadowDepth="6" BlurRadius="15" Opacity="0.4" Direction="270"/>
                            </Border.Effect>
                        </Border>
                        <Border x:Name="CashNote" Width="200" Height="120" Background="#10B981" BorderBrush="#047857" BorderThickness="4" CornerRadius="8" VerticalAlignment="Top" Margin="0,12,0,0">
                            <Border.RenderTransform>
                                <TranslateTransform x:Name="CashNoteTrans" Y="-150"/>
                            </Border.RenderTransform>
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                <TextBlock Text="💵" FontSize="48" HorizontalAlignment="Center"/>
                                <TextBlock Text="MYR" Foreground="White" FontWeight="Black" FontSize="20" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <TextBlock Text="TOTAL DISPENSED" Foreground="#64748B" FontSize="24" FontWeight="Bold" HorizontalAlignment="Center"/>

                    <Viewbox Stretch="Uniform" StretchDirection="DownOnly" MaxHeight="120" Margin="0,16,0,0">
                        <TextBlock x:Name="TxtMyr" Text="RM 0" Foreground="#10B981" FontSize="96" FontWeight="Black" HorizontalAlignment="Center"/>
                    </Viewbox>
                </StackPanel>
            </Border>

            <Border Grid.Column="2" Background="#F8FAFC" BorderBrush="#E2E8F0" BorderThickness="3" CornerRadius="24" Padding="48">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="40"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="40"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" BorderBrush="#CBD5E1" BorderThickness="3" CornerRadius="20" ClipToBounds="True" Height="200" Width="180">
                            <Image x:Name="LiveFaceImage" Stretch="UniformToFill"/>
                        </Border>

                        <StackPanel Grid.Column="2" VerticalAlignment="Center">
                            <TextBlock Text="Verified Customer" Foreground="#64748B" FontSize="20" FontWeight="Bold"/>

                            <Viewbox Stretch="Uniform" StretchDirection="DownOnly" HorizontalAlignment="Left" MaxHeight="60" Margin="0,8,0,24">
                                <TextBlock x:Name="TxtCustomer" Text="Loading Name..." Foreground="#0F172A" FontSize="48" FontWeight="Black"/>
                            </Viewbox>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Foreign Inserted" Foreground="#64748B" FontSize="20" FontWeight="Bold"/>
                                    <Viewbox Stretch="Uniform" StretchDirection="DownOnly" HorizontalAlignment="Left" MaxHeight="40" Margin="0,8,0,0">
                                        <TextBlock x:Name="TxtForeign" Text="0.00" Foreground="#0F172A" FontSize="32" FontWeight="Bold"/>
                                    </Viewbox>
                                </StackPanel>
                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="Exchange Rate" Foreground="#64748B" FontSize="20" FontWeight="Bold"/>
                                    <Viewbox Stretch="Uniform" StretchDirection="DownOnly" HorizontalAlignment="Left" MaxHeight="40" Margin="0,8,0,0">
                                        <TextBlock x:Name="TxtRate" Text="0.00" Foreground="#0F172A" FontSize="32" FontWeight="Bold"/>
                                    </Viewbox>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Grid>

                    <StackPanel Grid.Row="2" VerticalAlignment="Bottom">
                        <TextBlock Text="Notes Dispensed Breakdown" Foreground="#0F172A" FontSize="28" FontWeight="Black" Margin="0,0,0,24"/>
                        <UniformGrid Columns="2" Rows="2">
                            <Border Background="White" BorderBrush="#E2E8F0" BorderThickness="2" CornerRadius="16" Padding="24" Margin="0,0,16,16">
                                <Grid>
                                    <TextBlock Text="RM 100" Foreground="#64748B" FontSize="28" FontWeight="Bold" VerticalAlignment="Center"/>
                                    <TextBlock x:Name="Txt100" Text="0" Foreground="#0F172A" FontSize="40" FontWeight="Black" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                </Grid>
                            </Border>
                            <Border Background="White" BorderBrush="#E2E8F0" BorderThickness="2" CornerRadius="16" Padding="24" Margin="16,0,0,16">
                                <Grid>
                                    <TextBlock Text="RM 50" Foreground="#64748B" FontSize="28" FontWeight="Bold" VerticalAlignment="Center"/>
                                    <TextBlock x:Name="Txt50" Text="0" Foreground="#0F172A" FontSize="40" FontWeight="Black" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                </Grid>
                            </Border>
                            <Border Background="White" BorderBrush="#E2E8F0" BorderThickness="2" CornerRadius="16" Padding="24" Margin="0,0,16,0">
                                <Grid>
                                    <TextBlock Text="RM 10" Foreground="#64748B" FontSize="28" FontWeight="Bold" VerticalAlignment="Center"/>
                                    <TextBlock x:Name="Txt10" Text="0" Foreground="#0F172A" FontSize="40" FontWeight="Black" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                </Grid>
                            </Border>
                            <Border Background="White" BorderBrush="#E2E8F0" BorderThickness="2" CornerRadius="16" Padding="24" Margin="16,0,0,0">
                                <Grid>
                                    <TextBlock Text="RM 1" Foreground="#64748B" FontSize="28" FontWeight="Bold" VerticalAlignment="Center"/>
                                    <TextBlock x:Name="Txt1" Text="0" Foreground="#0F172A" FontSize="40" FontWeight="Black" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                </Grid>
                            </Border>
                        </UniformGrid>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <Grid Grid.Row="2" Margin="0,40,0,0">
            <Button Content="🖨️ Print Receipt" Width="360" HorizontalAlignment="Left" Click="PrintReceipt_Click" Style="{StaticResource OutlineButton}"/>
            <Button x:Name="BtnDone" Content="Complete Transaction" Width="460" HorizontalAlignment="Right" Click="Done_Click" Style="{StaticResource PrimaryButton}"/>
        </Grid>
    </Grid>
</UserControl>