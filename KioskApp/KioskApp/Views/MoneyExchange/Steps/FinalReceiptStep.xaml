<UserControl x:Class="OmniKiosk.Wpf.Views.MoneyExchange.Steps.FinalReceiptStep"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Loaded="UserControl_Loaded" Background="{StaticResource BackgroundBrush}">

    <UserControl.Resources>
        <Storyboard x:Key="DispenseAnim" RepeatBehavior="Forever">
            <DoubleAnimation Storyboard.TargetName="CashNoteTrans" Storyboard.TargetProperty="Y" From="-150" To="100" Duration="0:0:1.5">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="CashNote" Storyboard.TargetProperty="Opacity" From="1" To="0" BeginTime="0:0:1.2" Duration="0:0:0.3"/>
        </Storyboard>
    </UserControl.Resources>

    <UserControl.Triggers>
        <EventTrigger RoutedEvent="FrameworkElement.Loaded">
            <BeginStoryboard Storyboard="{StaticResource DispenseAnim}"/>
        </EventTrigger>
    </UserControl.Triggers>

    <Grid Margin="60,32">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,20" HorizontalAlignment="Center">
            <TextBlock x:Name="TitleText" Style="{StaticResource HeaderText}" TextAlignment="Center"/>
            <TextBlock x:Name="SubtitleText" Foreground="{StaticResource TextSecondaryBrush}" FontSize="{StaticResource FontSizeSmall}" Margin="0,8,0,0" TextAlignment="Center"/>
        </StackPanel>

        <!-- Everything below flows top-to-bottom in one column - photo, name,
             and every detail stacked vertically rather than split across
             side-by-side panels, both for readability and because this suits
             a portrait kiosk screen better than a wide horizontal split. -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <StackPanel MaxWidth="700" HorizontalAlignment="Center">

                <Border Style="{StaticResource Card}" Padding="32" Margin="0,0,0,20">
                    <StackPanel HorizontalAlignment="Center">
                        <Border BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="14" ClipToBounds="True" Width="180" Height="230" Background="{StaticResource BackgroundBrush}" HorizontalAlignment="Center">
                            <Image x:Name="LiveFaceImage" Stretch="Uniform"/>
                        </Border>

                        <TextBlock x:Name="VerifiedCustomerLabel" Style="{StaticResource FieldLabel}" HorizontalAlignment="Center" Margin="0,18,0,0"/>
                        <TextBlock x:Name="TxtCustomer" FontFamily="{StaticResource DisplayFont}" Foreground="{StaticResource TextPrimaryBrush}" FontSize="30" FontWeight="Bold" HorizontalAlignment="Center" TextAlignment="Center" Margin="0,2,0,20"/>

                        <TextBlock x:Name="ForeignInsertedLabel" Style="{StaticResource FieldLabel}" HorizontalAlignment="Center"/>
                        <TextBlock x:Name="TxtForeign" FontSize="22" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}" HorizontalAlignment="Center" Margin="0,0,0,16"/>

                        <TextBlock x:Name="ExchangeRateLabel" Style="{StaticResource FieldLabel}" HorizontalAlignment="Center"/>
                        <TextBlock x:Name="TxtRate" FontSize="22" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource Card}" Padding="32" Margin="0,0,0,20">
                    <StackPanel HorizontalAlignment="Center">
                        <Grid Height="180" Width="240" ClipToBounds="True">
                            <Border Width="240" Height="20" Background="{StaticResource TextPrimaryBrush}" CornerRadius="10" VerticalAlignment="Top" Panel.ZIndex="10"/>
                            <Border x:Name="CashNote" Width="190" Height="112" Background="{StaticResource AccentBrush}" BorderBrush="{StaticResource PrimaryHoverBrush}" BorderThickness="4" CornerRadius="8" VerticalAlignment="Top" Margin="0,10,0,0">
                                <Border.RenderTransform>
                                    <TranslateTransform x:Name="CashNoteTrans" Y="-150"/>
                                </Border.RenderTransform>
                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <TextBlock Text="💵" FontSize="38" HorizontalAlignment="Center"/>
                                    <TextBlock Text="MYR" Foreground="White" FontWeight="Black" FontSize="16" HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                        </Grid>

                        <TextBlock x:Name="TotalDispensedLabel" Style="{StaticResource FieldLabel}" HorizontalAlignment="Center" Margin="0,8,0,0"/>
                        <TextBlock x:Name="TxtMyr" FontFamily="{StaticResource DisplayFont}" Foreground="{StaticResource AccentBrush}" FontSize="56" FontWeight="Black" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource Card}" Padding="32">
                    <StackPanel>
                        <TextBlock x:Name="BreakdownLabel" Style="{StaticResource HeaderText}" FontSize="{StaticResource FontSizeLarge}" HorizontalAlignment="Center" Margin="0,0,0,20"/>

                        <!-- Each row hidden entirely when its count is zero -
                             a customer paid in RM10s and RM1s doesn't need an
                             "RM100 x 0" line cluttering the list. Txt100/
                             Txt50/Txt10/Txt1 are named to match exactly what
                             UserControl_Loaded already reads/writes - Run
                             supports Text the same way TextBlock does, so the
                             existing calculation code needs zero changes. -->
                        <Border x:Name="Row100" Background="{StaticResource BackgroundBrush}" CornerRadius="12" Padding="20,16" Margin="0,0,0,10">
                            <Grid>
                                <TextBlock Text="RM 100" FontFamily="{StaticResource DisplayFont}" Foreground="{StaticResource TextPrimaryBrush}" FontSize="22" FontWeight="Bold"/>
                                <TextBlock FontSize="20" FontWeight="Bold" Foreground="{StaticResource TextSecondaryBrush}" HorizontalAlignment="Right"><Run Text="×"/><Run Text=" "/><Run x:Name="Txt100" Text="0"/></TextBlock>
                            </Grid>
                        </Border>
                        <Border x:Name="Row50" Background="{StaticResource BackgroundBrush}" CornerRadius="12" Padding="20,16" Margin="0,0,0,10">
                            <Grid>
                                <TextBlock Text="RM 50" FontFamily="{StaticResource DisplayFont}" Foreground="{StaticResource TextPrimaryBrush}" FontSize="22" FontWeight="Bold"/>
                                <TextBlock FontSize="20" FontWeight="Bold" Foreground="{StaticResource TextSecondaryBrush}" HorizontalAlignment="Right"><Run Text="×"/><Run Text=" "/><Run x:Name="Txt50" Text="0"/></TextBlock>
                            </Grid>
                        </Border>
                        <Border x:Name="Row10" Background="{StaticResource BackgroundBrush}" CornerRadius="12" Padding="20,16" Margin="0,0,0,10">
                            <Grid>
                                <TextBlock Text="RM 10" FontFamily="{StaticResource DisplayFont}" Foreground="{StaticResource TextPrimaryBrush}" FontSize="22" FontWeight="Bold"/>
                                <TextBlock FontSize="20" FontWeight="Bold" Foreground="{StaticResource TextSecondaryBrush}" HorizontalAlignment="Right"><Run Text="×"/><Run Text=" "/><Run x:Name="Txt10" Text="0"/></TextBlock>
                            </Grid>
                        </Border>
                        <Border x:Name="Row1" Background="{StaticResource BackgroundBrush}" CornerRadius="12" Padding="20,16">
                            <Grid>
                                <TextBlock Text="RM 1" FontFamily="{StaticResource DisplayFont}" Foreground="{StaticResource TextPrimaryBrush}" FontSize="22" FontWeight="Bold"/>
                                <TextBlock FontSize="20" FontWeight="Bold" Foreground="{StaticResource TextSecondaryBrush}" HorizontalAlignment="Right"><Run Text="×"/><Run Text=" "/><Run x:Name="Txt1" Text="0"/></TextBlock>
                            </Grid>
                        </Border>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <Grid Grid.Row="2" Margin="0,24,0,0">
            <Button x:Name="BtnPrintReceipt" Width="320" HorizontalAlignment="Left" Click="PrintReceipt_Click" Style="{StaticResource OutlineButton}"/>
            <Button x:Name="BtnDone" Width="380" HorizontalAlignment="Right" Click="Done_Click" Style="{StaticResource PrimaryButton}"/>
        </Grid>
    </Grid>
</UserControl>
