<UserControl x:Class="OmniKiosk.Wpf.Views.SDKTest.PassportSdkTestView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#FF05070D"
             Loaded="UserControl_Loaded"
             Unloaded="UserControl_Unloaded">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border CornerRadius="18" Background="#FF0B1220" Padding="16" Grid.Row="0">
            <DockPanel>
                <Button Content="← Back"
                        Width="120"
                        Height="42"
                        Click="Back_Click"
                        Background="#FF111827"
                        Foreground="White"
                        BorderBrush="#223047"
                        BorderThickness="1"
                        FontWeight="SemiBold"/>

                <StackPanel DockPanel.Dock="Left" Margin="16,0,0,0">
                    <TextBlock Text="Passport Reader"
                               Foreground="White"
                               FontSize="24"
                               FontWeight="Bold"/>
                    <TextBlock Text="Place passport on the scanner. It will read automatically after Init."
                               Foreground="#FFD1D5DB"
                               FontSize="14"
                               Margin="0,4,0,0"/>
                </StackPanel>

                <Border DockPanel.Dock="Right"
                        CornerRadius="999"
                        Background="#FF111827"
                        Padding="12,6"
                        BorderBrush="#223047"
                        BorderThickness="1">
                    <TextBlock x:Name="StatusText"
                               Foreground="White"
                               FontSize="13"
                               FontWeight="SemiBold"
                               Text="Ready. Click Init."/>
                </Border>
            </DockPanel>
        </Border>

        <!-- Content -->
        <Grid Grid.Row="1" Margin="0,16,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Details Card -->
            <Border Grid.Column="0"
                    Background="#FF0B1220"
                    CornerRadius="18"
                    Padding="18"
                    Margin="0,0,14,0"
                    BorderBrush="#223047"
                    BorderThickness="1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="Detected Details"
                               Foreground="White"
                               FontSize="18"
                               FontWeight="Bold"/>

                    <Grid Grid.Row="1" Margin="0,14,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="170"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Passport No" Foreground="#FF9CA3AF"/>
                        <TextBlock Grid.Row="0" Grid.Column="1" x:Name="TxtPassportNo" Foreground="White" FontWeight="SemiBold"/>

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Name" Foreground="#FF9CA3AF" Margin="0,10,0,0"/>
                        <TextBlock Grid.Row="1" Grid.Column="1" x:Name="TxtName" Foreground="White" FontWeight="SemiBold" Margin="0,10,0,0"/>

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Nationality" Foreground="#FF9CA3AF" Margin="0,10,0,0"/>
                        <TextBlock Grid.Row="2" Grid.Column="1" x:Name="TxtNationality" Foreground="White" FontWeight="SemiBold" Margin="0,10,0,0"/>

                        <TextBlock Grid.Row="3" Grid.Column="0" Text="DOB" Foreground="#FF9CA3AF" Margin="0,10,0,0"/>
                        <TextBlock Grid.Row="3" Grid.Column="1" x:Name="TxtDob" Foreground="White" FontWeight="SemiBold" Margin="0,10,0,0"/>

                        <TextBlock Grid.Row="4" Grid.Column="0" Text="Expiry" Foreground="#FF9CA3AF" Margin="0,10,0,0"/>
                        <TextBlock Grid.Row="4" Grid.Column="1" x:Name="TxtExpiry" Foreground="White" FontWeight="SemiBold" Margin="0,10,0,0"/>

                        <TextBlock Grid.Row="5" Grid.Column="0" Text="Sex" Foreground="#FF9CA3AF" Margin="0,10,0,0"/>
                        <TextBlock Grid.Row="5" Grid.Column="1" x:Name="TxtSex" Foreground="White" FontWeight="SemiBold" Margin="0,10,0,0"/>
                    </Grid>

                    <StackPanel Grid.Row="2" Margin="0,18,0,0">
                        <TextBlock Text="Activity Log" Foreground="#FF9CA3AF" Margin="0,0,0,8"/>
                        <TextBox x:Name="LogBox"
                                 Height="170"
                                 IsReadOnly="True"
                                 TextWrapping="Wrap"
                                 VerticalScrollBarVisibility="Auto"
                                 Background="#FF05070D"
                                 Foreground="#FFE5E7EB"
                                 BorderBrush="#223047"
                                 BorderThickness="1"
                                 Padding="10"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Portrait Card -->
            <Border Grid.Column="1"
                    Background="#FF0B1220"
                    CornerRadius="18"
                    Padding="18"
                    BorderBrush="#223047"
                    BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="Portrait"
                               Foreground="White"
                               FontSize="18"
                               FontWeight="Bold"/>

                    <Border Margin="0,14,0,0"
                            Background="#FF05070D"
                            CornerRadius="14"
                            Height="280"
                            BorderBrush="#223047"
                            BorderThickness="1">
                        <Image x:Name="PortraitImage" Stretch="Uniform" />
                    </Border>

                    <TextBlock x:Name="HintText"
                               Foreground="#FFD1D5DB"
                               FontSize="13"
                               Margin="0,12,0,0"
                               Text="Tip: Keep passport steady for 1–2 seconds."/>
                </StackPanel>
            </Border>

            <!-- REMOVE OVERLAY -->
            <Border x:Name="RemoveOverlay"
                    Grid.ColumnSpan="2"
                    Visibility="Collapsed"
                    Background="#AA000000"
                    CornerRadius="18">
                <Border Background="#FF0B1220"
                        CornerRadius="18"
                        Padding="28"
                        Width="560"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        BorderBrush="#223047"
                        BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="Remove Passport"
                                   Foreground="White"
                                   FontSize="26"
                                   FontWeight="Bold"
                                   TextAlignment="Center"/>
                        <TextBlock x:Name="RemoveOverlayText"
                                   Margin="0,12,0,0"
                                   Text="Please remove the passport from the reader."
                                   Foreground="#FFD1D5DB"
                                   FontSize="16"
                                   TextAlignment="Center"/>
                    </StackPanel>
                </Border>
            </Border>
        </Grid>

        <!-- Footer Buttons -->
        <StackPanel Grid.Row="2" Margin="0,16,0,0" Orientation="Horizontal" HorizontalAlignment="Left">
            <Button Content="Init"
                    Width="140"
                    Height="44"
                    Click="Init_Click"
                    Background="#FF1D4ED8"
                    Foreground="White"
                    BorderThickness="0"
                    FontWeight="SemiBold"/>

            <Button Content="Free"
                    Width="140"
                    Height="44"
                    Margin="12,0,0,0"
                    Click="Free_Click"
                    Background="#FF111827"
                    Foreground="White"
                    BorderBrush="#223047"
                    BorderThickness="1"
                    FontWeight="SemiBold"/>
        </StackPanel>
    </Grid>
</UserControl>