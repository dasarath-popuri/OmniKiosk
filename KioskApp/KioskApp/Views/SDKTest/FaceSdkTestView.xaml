<UserControl x:Class="OmniKiosk.Wpf.Views.SDKTest.FaceSdkTestView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:OmniKiosk.Wpf.Views.SDKTest"
             Background="#FF05070D"
             Loaded="UserControl_Loaded"
             Unloaded="UserControl_Unloaded">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" CornerRadius="18" Background="#FF0B1220" Padding="16" BorderBrush="#223047" BorderThickness="1">
            <DockPanel>
                <Button Content="← Back"
                        Width="120"
                        Height="42"
                        Click="Back_Click"
                        Background="#FF111827"
                        Foreground="White"
                        BorderBrush="#223047"
                        BorderThickness="1"
                        FontWeight="SemiBold"/>

                <StackPanel Margin="16,0,0,0">
                    <TextBlock Text="Face Capture &amp; Recognition"
                               Foreground="White"
                               FontSize="24"
                               FontWeight="Bold"/>
                    <TextBlock Text="Press Start Detect and look at the camera. If matched, confirm. Otherwise register."
                               Foreground="#FFD1D5DB"
                               FontSize="14"
                               Margin="0,4,0,0"/>
                </StackPanel>

                <Border DockPanel.Dock="Right"
                        CornerRadius="999"
                        Background="#FF111827"
                        Padding="12,6"
                        BorderBrush="#223047"
                        BorderThickness="1">
                    <TextBlock x:Name="StatusText"
                               Foreground="White"
                               FontSize="13"
                               FontWeight="SemiBold"
                               Text="Ready."/>
                </Border>
            </DockPanel>
        </Border>

        <!-- Preview -->
        <Border x:Name="PreviewBorder"
                Grid.Row="1"
                Margin="0,16,0,0"
                Background="#FF0B1220"
                CornerRadius="18"
                BorderBrush="#223047"
                BorderThickness="1">
            <Grid>
                <local:NativeVideoHost x:Name="VisHost"/>

                <local:NativeVideoHost x:Name="NirHost"
                                       Width="1" Height="1"
                                       Opacity="0"
                                       HorizontalAlignment="Left"
                                       VerticalAlignment="Top"/>

                <!-- Welcome Toast Overlay -->
                <Border x:Name="WelcomeToast"
                        Visibility="Collapsed"
                        Background="#CC000000"
                        CornerRadius="18">
                    <Border Background="#FF0B1220"
                            CornerRadius="18"
                            Padding="26"
                            Width="560"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            BorderBrush="#223047"
                            BorderThickness="1">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock x:Name="WelcomeTitle"
                                       Text="Welcome!"
                                       Foreground="White"
                                       FontSize="28"
                                       FontWeight="Bold"
                                       TextAlignment="Center"/>
                            <TextBlock x:Name="WelcomeSub"
                                       Margin="0,10,0,0"
                                       Text="Confirmed."
                                       Foreground="#FFD1D5DB"
                                       FontSize="16"
                                       TextAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </Border>
            </Grid>
        </Border>

        <!-- CONFIRM POPUP -->
        <Popup x:Name="ConfirmPopup"
               PlacementTarget="{Binding ElementName=PreviewBorder}"
               Placement="Center"
               AllowsTransparency="True"
               StaysOpen="True"
               IsOpen="False">
            <Border Background="#AA000000" CornerRadius="18">
                <Border Background="#FF0B1220"
                        CornerRadius="18"
                        Padding="22"
                        Width="720"
                        BorderBrush="#223047"
                        BorderThickness="1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="220"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0"
                                CornerRadius="16"
                                Background="#FF05070D"
                                BorderBrush="#223047"
                                BorderThickness="1"
                                Margin="0,0,16,0">
                            <Image x:Name="ConfirmFaceImage" Stretch="UniformToFill"/>
                        </Border>

                        <StackPanel Grid.Column="1">
                            <TextBlock x:Name="ConfirmTitle"
                                       Text="Welcome!"
                                       Foreground="White"
                                       FontSize="26"
                                       FontWeight="Bold"/>
                            <TextBlock x:Name="ConfirmText"
                                       Margin="0,10,0,0"
                                       Text="Is this you?"
                                       Foreground="#FFD1D5DB"
                                       FontSize="15"/>

                            <StackPanel Orientation="Horizontal" Margin="0,18,0,0">
                                <Button Content="Yes, it's me"
                                        Width="170"
                                        Height="44"
                                        Click="ConfirmYes_Click"
                                        Background="#FF16A34A"
                                        Foreground="White"
                                        BorderThickness="0"
                                        FontWeight="SemiBold"/>

                                <Button Content="Not me"
                                        Width="120"
                                        Height="44"
                                        Margin="12,0,0,0"
                                        Click="ConfirmNo_Click"
                                        Background="#FF111827"
                                        Foreground="White"
                                        BorderBrush="#223047"
                                        BorderThickness="1"
                                        FontWeight="SemiBold"/>
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                </Border>
            </Border>
        </Popup>

        <!-- REGISTER POPUP -->
        <Popup x:Name="RegisterPopup"
               PlacementTarget="{Binding ElementName=PreviewBorder}"
               Placement="Center"
               AllowsTransparency="True"
               StaysOpen="True"
               IsOpen="False">
            <Border Background="#AA000000" CornerRadius="18">
                <Border Background="#FF0B1220"
                        CornerRadius="18"
                        Padding="22"
                        Width="820"
                        BorderBrush="#223047"
                        BorderThickness="1">

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="260"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0"
                                CornerRadius="16"
                                Background="#FF05070D"
                                BorderBrush="#223047"
                                BorderThickness="1"
                                Margin="0,0,16,0">
                            <Image x:Name="RegisterFaceImage" Stretch="UniformToFill"/>
                        </Border>

                        <StackPanel Grid.Column="1">
                            <TextBlock Text="Register Customer"
                                       Foreground="White"
                                       FontSize="26"
                                       FontWeight="Bold"/>

                            <TextBlock x:Name="RegisterHint"
                                       Margin="0,10,0,14"
                                       Text="Enter details to save this face."
                                       Foreground="#FFD1D5DB"/>

                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="170"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Row="0" Grid.Column="0" Foreground="#FF9CA3AF" Text="Name" VerticalAlignment="Center"/>
                                <TextBox x:Name="TxtName" Grid.Row="0" Grid.Column="1" Height="40" Margin="10,6,0,6"
                                         Background="#FF05070D" Foreground="White" BorderBrush="#223047" BorderThickness="1" Padding="10"/>

                                <TextBlock Grid.Row="1" Grid.Column="0" Foreground="#FF9CA3AF" Text="ID Type" VerticalAlignment="Center"/>
                                <ComboBox x:Name="CmbIdType" Grid.Row="1" Grid.Column="1" Height="40" Margin="10,6,0,6"
                                          Background="#FF05070D" Foreground="White" BorderBrush="#223047" BorderThickness="1">
                                    <ComboBoxItem Content="Passport"/>
                                    <ComboBoxItem Content="NRIC"/>
                                    <ComboBoxItem Content="Work Permit"/>
                                    <ComboBoxItem Content="Other"/>
                                </ComboBox>

                                <TextBlock Grid.Row="2" Grid.Column="0" Foreground="#FF9CA3AF" Text="ID No" VerticalAlignment="Center"/>
                                <TextBox x:Name="TxtIdNo" Grid.Row="2" Grid.Column="1" Height="40" Margin="10,6,0,6"
                                         Background="#FF05070D" Foreground="White" BorderBrush="#223047" BorderThickness="1" Padding="10"/>

                                <TextBlock Grid.Row="3" Grid.Column="0" Foreground="#FF9CA3AF" Text="Phone" VerticalAlignment="Center"/>
                                <TextBox x:Name="TxtPhone" Grid.Row="3" Grid.Column="1" Height="40" Margin="10,6,0,6"
                                         Background="#FF05070D" Foreground="White" BorderBrush="#223047" BorderThickness="1" Padding="10"/>
                            </Grid>

                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,18,0,0">
                                <Button Content="Cancel"
                                        Width="120"
                                        Height="44"
                                        Click="RegisterCancel_Click"
                                        Background="#FF111827"
                                        Foreground="White"
                                        BorderBrush="#223047"
                                        BorderThickness="1"
                                        FontWeight="SemiBold"/>

                                <Button Content="Save"
                                        Width="140"
                                        Height="44"
                                        Margin="10,0,0,0"
                                        Click="RegisterSave_Click"
                                        Background="#FF1D4ED8"
                                        Foreground="White"
                                        BorderThickness="0"
                                        FontWeight="SemiBold"/>
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                </Border>
            </Border>
        </Popup>

        <!-- Footer -->
        <StackPanel Grid.Row="2" Margin="0,16,0,0">
            <TextBox x:Name="EventLog"
                     Height="90"
                     IsReadOnly="True"
                     TextWrapping="Wrap"
                     VerticalScrollBarVisibility="Auto"
                     Background="#FF0B1220"
                     Foreground="#FFE5E7EB"
                     BorderBrush="#223047"
                     BorderThickness="1"
                     Padding="10"/>

            <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                <Button Content="Open" Width="120" Height="44" Click="Open_Click"
                        Background="#FF111827" Foreground="White" BorderBrush="#223047" BorderThickness="1" FontWeight="SemiBold"/>
                <Button Content="Start Detect" Width="160" Height="44" Margin="12,0,0,0" Click="Start_Click"
                        Background="#FF1D4ED8" Foreground="White" BorderThickness="0" FontWeight="SemiBold"/>
                <Button Content="Stop" Width="120" Height="44" Margin="12,0,0,0" Click="Stop_Click"
                        Background="#FF111827" Foreground="White" BorderBrush="#223047" BorderThickness="1" FontWeight="SemiBold"/>
                <Button Content="Close" Width="120" Height="44" Margin="12,0,0,0" Click="Close_Click"
                        Background="#FF111827" Foreground="White" BorderBrush="#223047" BorderThickness="1" FontWeight="SemiBold"/>
            </StackPanel>
        </StackPanel>
    </Grid>
</UserControl>