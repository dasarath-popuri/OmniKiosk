<UserControl x:Class="OmniKiosk.Wpf.Views.SDKTest.PrinterSdkTestView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#FF05070D">
    <Grid Margin="32">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" CornerRadius="16" Background="#FF0B1220" Padding="20" BorderBrush="#223047" BorderThickness="1" Margin="0,0,0,24">
            <DockPanel>
                <Button Content="← Back" Width="140" Height="48" Click="Back_Click" Background="#FF111827" Foreground="White" BorderBrush="#223047" BorderThickness="1"/>
                <TextBlock Text="Bixolon BK3-3 Printer Test" Foreground="White" FontSize="28" FontWeight="Bold" VerticalAlignment="Center" Margin="24,0,0,0"/>
            </DockPanel>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Margin="0,0,16,0">
                <TextBlock Text="Printer Name (Windows Driver):" Foreground="Gray" FontWeight="SemiBold" Margin="0,0,0,8"/>
                <TextBox x:Name="TxtPrinterName" Text="BIXOLON BK3-3" Height="50" FontSize="18" VerticalContentAlignment="Center" Background="#FF0B1220" Foreground="White" BorderBrush="#223047" BorderThickness="1" Padding="10" Margin="0,0,0,24"/>

                <Button Content="🖨️ Print Test Receipt" Height="60" Click="PrintTest_Click" Background="#FF1D4ED8" Foreground="White" FontWeight="Bold" FontSize="18" Margin="0,0,0,16"/>
                <!--<Button Content="✂️ Test Cut &amp; Presenter Eject" Height="60" Click="CutAndEject_Click" Background="#FF111827" Foreground="White" BorderBrush="#223047" BorderThickness="1" FontWeight="Bold" FontSize="18" Margin="0,0,0,24"/>-->

                <TextBlock Text="Event Log:" Foreground="Gray" FontWeight="SemiBold" Margin="0,0,0,8"/>
                <TextBox x:Name="TxtLog" Height="200" IsReadOnly="True" VerticalScrollBarVisibility="Auto" Background="#FF0B1220" Foreground="#FFE5E7EB" BorderBrush="#223047" BorderThickness="1" Padding="10" FontFamily="Consolas"/>
            </StackPanel>

            <Border Grid.Column="1" Background="#FF0B1220" BorderBrush="#223047" BorderThickness="1" CornerRadius="16" Padding="24" Margin="16,0,0,0">
                <StackPanel>
                    <TextBlock Text="Receipt Preview" Foreground="#FF1D4ED8" FontSize="20" FontWeight="Bold" Margin="0,0,0,16"/>
                    <Border Background="White" Padding="20" CornerRadius="4">
                        <TextBlock FontFamily="Consolas" Foreground="Black" FontSize="14">
                            <Run Text="================================"/> <LineBreak/>
                            <Run Text="      OMNIREMIT EXCHANGE" FontWeight="Bold"/> <LineBreak/>
                            <Run Text="================================"/> <LineBreak/>
                            <Run Text="Date: "/> <Run x:Name="PreviewDate"/> <LineBreak/>
                            <Run Text="Type: BUY (USD)"/> <LineBreak/>
                            <LineBreak/>
                            <Run Text="Amount In:       100.00 USD"/> <LineBreak/>
                            <Run Text="Rate:            4.7200"/> <LineBreak/>
                            <Run Text="Amount Out:   RM 472.00" FontWeight="Bold"/> <LineBreak/>
                            <LineBreak/>
                            <Run Text="Thank you for your business!"/> <LineBreak/>
                            <Run Text="================================"/>
                        </TextBlock>
                    </Border>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>