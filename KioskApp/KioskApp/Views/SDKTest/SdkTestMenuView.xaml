<UserControl x:Class="OmniKiosk.Wpf.Views.SDKTest.SdkTestMenuView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#0F0F11"
             FontFamily="Segoe UI, Tahoma, Geneva, Verdana, sans-serif">

    <UserControl.Resources>
        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="#1C1C1E"/>
            <Setter Property="BorderBrush" Value="#2C2C2E"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="16"/>
            <Setter Property="Margin" Value="15"/>
            <Setter Property="Padding" Value="24"/>
            <Setter Property="Width" Value="300"/>
            <Setter Property="Height" Value="180"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="Black" BlurRadius="15" Opacity="0.3" ShadowDepth="4"/>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CardTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="22"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>

        <Style x:Key="CardSubtitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="#8E8E93"/>
            <Setter Property="Margin" Value="0,8,0,0"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="VerticalAlignment" Value="Top"/>
        </Style>

        <Style x:Key="ActionButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Height" Value="44"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="BtnBorder" Background="#0A84FF" CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="BtnBorder" Property="Background" Value="#409CFF"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="BtnBorder" Property="Background" Value="#0062D6"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="BackButtonStyle" TargetType="Button" BasedOn="{StaticResource ActionButtonStyle}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="BtnBorder" Background="#2C2C2E" BorderBrush="#3A3A3C" BorderThickness="1" CornerRadius="12">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="BtnBorder" Property="Background" Value="#3A3A3C"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="BtnBorder" Property="Background" Value="#1C1C1E"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="SDK Test Menu"
                   FontSize="42"
                   Foreground="#FFFFFF"
                   FontWeight="Bold"
                   HorizontalAlignment="Center"
                   Margin="0,0,0,30"/>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" BorderThickness="0">
            <WrapPanel HorizontalAlignment="Center" VerticalAlignment="Center">

                <Border Style="{StaticResource CardStyle}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Text="Passport Reader" Style="{StaticResource CardTitleStyle}"/>
                        <TextBlock Grid.Row="1" Text="Test passport scanning" Style="{StaticResource CardSubtitleStyle}"/>
                        <Button Grid.Row="2" Content="TEST" Click="TestPassport_Click" Style="{StaticResource ActionButtonStyle}"/>
                    </Grid>
                </Border>

                <Border Style="{StaticResource CardStyle}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Text="IC Reader" Style="{StaticResource CardTitleStyle}"/>
                        <TextBlock Grid.Row="1" Text="Test IC reading" Style="{StaticResource CardSubtitleStyle}"/>
                        <Button Grid.Row="2" Content="TEST" Click="TestIc_Click" Style="{StaticResource ActionButtonStyle}"/>
                    </Grid>
                </Border>

                <Border Style="{StaticResource CardStyle}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Text="Face Capture" Style="{StaticResource CardTitleStyle}"/>
                        <TextBlock Grid.Row="1" Text="Liveness + face compare" Style="{StaticResource CardSubtitleStyle}"/>
                        <Button Grid.Row="2" Content="TEST" Click="TestFace_Click" Style="{StaticResource ActionButtonStyle}"/>
                    </Grid>
                </Border>

                <Border Style="{StaticResource CardStyle}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Text="Bixolon Printer" Style="{StaticResource CardTitleStyle}"/>
                        <TextBlock Grid.Row="1" Text="Print receipts &amp; test feed" Style="{StaticResource CardSubtitleStyle}"/>
                        <Button Grid.Row="2" Content="TEST" Click="TestPrinter_Click" Style="{StaticResource ActionButtonStyle}"/>
                    </Grid>
                </Border>

                <Border Style="{StaticResource CardStyle}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Text="Money Dispenser" Style="{StaticResource CardTitleStyle}"/>
                        <TextBlock Grid.Row="1" Text="Test dispensing notes" Style="{StaticResource CardSubtitleStyle}"/>
                        <Button Grid.Row="2" Content="TEST" Click="TestDispenser_Click" Style="{StaticResource ActionButtonStyle}"/>
                    </Grid>
                </Border>

                <Border Style="{StaticResource CardStyle}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Text="Money Receiver" Style="{StaticResource CardTitleStyle}"/>
                        <TextBlock Grid.Row="1" Text="Test receiving notes" Style="{StaticResource CardSubtitleStyle}"/>
                        <Button Grid.Row="2" Content="TEST" Click="TestReceiver_Click" Style="{StaticResource ActionButtonStyle}"/>
                    </Grid>
                </Border>

            </WrapPanel>
        </ScrollViewer>

        <Button Grid.Row="2"
                Content="BACK"
                Width="240"
                Height="56"
                HorizontalAlignment="Center"
                Margin="0,30,0,0"
                Click="Back_Click"
                Style="{StaticResource BackButtonStyle}"/>
    </Grid>
</UserControl>