<UserControl x:Class="OmniKiosk.Wpf.Views.SDKTest.ICSdkTestView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#FF05070D">
    <Grid Margin="32">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" CornerRadius="16" Background="#FF0B1220" Padding="20" BorderBrush="#223047" BorderThickness="1" Margin="0,0,0,24">
            <DockPanel>
                <Button Content="← Back" Width="140" Height="48" Click="Back_Click" Background="#FF111827" Foreground="White" BorderBrush="#223047" BorderThickness="1"/>
                <TextBlock Text="MyKad (IC) Reader Test" Foreground="White" FontSize="28" FontWeight="Bold" VerticalAlignment="Center" Margin="24,0,0,0"/>
            </DockPanel>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Margin="0,0,16,0">
                <Button x:Name="BtnRead" Content="Read MyKad" Height="54" Click="Read_Click" Background="#FF1D4ED8" Foreground="White" FontWeight="Bold" Margin="0,0,0,24"/>
                <TextBlock Text="Event Log:" Foreground="Gray" FontWeight="SemiBold" Margin="0,0,0,8"/>
                <TextBox x:Name="TxtLog" Height="350" IsReadOnly="True" VerticalScrollBarVisibility="Auto" Background="#FF0B1220" Foreground="#FFE5E7EB" BorderBrush="#223047" BorderThickness="1" Padding="10" FontFamily="Consolas"/>
            </StackPanel>

            <Border Grid.Column="1" Background="#FF0B1220" BorderBrush="#223047" BorderThickness="1" CornerRadius="16" Padding="24" Margin="16,0,0,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Background="#FF111827" Width="180" Height="220" BorderBrush="#223047" BorderThickness="1" CornerRadius="12" ClipToBounds="True" VerticalAlignment="Top">
                        <Image x:Name="ImgPortrait" Stretch="UniformToFill"/>
                    </Border>
                    <StackPanel Grid.Column="1" Margin="24,0,0,0">
                        <TextBlock Text="Extracted Data" Foreground="#FF1D4ED8" FontSize="20" FontWeight="Bold" Margin="0,0,0,24"/>
                        <TextBlock Text="Full Name" Foreground="Gray" FontSize="14"/>
                        <TextBlock x:Name="TxtName" Text="-" Foreground="White" FontSize="18" FontWeight="Bold" Margin="0,0,0,16" TextWrapping="Wrap"/>
                        <TextBlock Text="IC Number" Foreground="Gray" FontSize="14"/>
                        <TextBlock x:Name="TxtIdNo" Text="-" Foreground="White" FontSize="18" FontWeight="Bold" Margin="0,0,0,16"/>
                        <TextBlock Text="Gender" Foreground="Gray" FontSize="14"/>
                        <TextBlock x:Name="TxtGender" Text="-" Foreground="White" FontSize="18" FontWeight="Bold"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>