<UserControl x:Class="OmniKiosk.Wpf.Views.SDKTest.DispenserSdkTestView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#FF05070D">
    <Grid Margin="32">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" CornerRadius="16" Background="#FF0B1220" Padding="20" BorderBrush="#223047" BorderThickness="1" Margin="0,0,0,24">
            <DockPanel>
                <Button Content="← Back" Width="140" Height="48" Click="Back_Click" Background="#FF111827" Foreground="White" BorderBrush="#223047" BorderThickness="1"/>
                <TextBlock Text="Puloon ECDM-400 Dispenser Test" Foreground="White" FontSize="28" FontWeight="Bold" VerticalAlignment="Center" Margin="24,0,0,0"/>
            </DockPanel>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Margin="0,0,16,0">
                <Border Background="#FF0B1220" BorderBrush="#223047" BorderThickness="1" CornerRadius="16" Padding="24">
                    <StackPanel>
                        <TextBlock Text="Connection" Foreground="White" FontSize="20" FontWeight="Bold" Margin="0,0,0,16"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="TxtComPort" Text="COM2" FontSize="18" Padding="8" Margin="0,0,8,0"/>
                            <Button Grid.Column="1" Content="Connect" Width="100" Click="Connect_Click" Margin="0,0,8,0"/>
                            <Button Grid.Column="2" Content="Disconnect" Width="100" Click="Disconnect_Click"/>
                        </Grid>

                        <TextBlock Text="Hardware Actions" Foreground="White" FontSize="20" FontWeight="Bold" Margin="0,32,0,16"/>
                        <UniformGrid Columns="2" Rows="2">
                            <Button Content="Reset Machine" Height="50" Margin="4" Click="Reset_Click"/>
                            <Button Content="Get Status" Height="50" Margin="4" Click="Status_Click"/>
                            <Button Content="Purge Path" Height="50" Margin="4" Click="Purge_Click"/>
                            <Button Content="ROM Version" Height="50" Margin="4" Click="Rom_Click"/>
                        </UniformGrid>
                    </StackPanel>
                </Border>

                <Border Background="#FF0B1220" BorderBrush="#223047" BorderThickness="1" CornerRadius="16" Padding="24" Margin="0,24,0,0">
                    <StackPanel>
                        <TextBlock Text="Dispense Setup" Foreground="White" FontSize="20" FontWeight="Bold" Margin="0,0,0,16"/>
                        <Grid Margin="0,5">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="60"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Cassette 1 (Top):" Foreground="White" FontSize="16" VerticalAlignment="Center"/>
                            <TextBox x:Name="TxtC1" Grid.Column="1" Text="0" FontSize="18" TextAlignment="Center"/>
                        </Grid>
                        <Grid Margin="0,5">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="60"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Cassette 2:" Foreground="White" FontSize="16" VerticalAlignment="Center"/>
                            <TextBox x:Name="TxtC2" Grid.Column="1" Text="0" FontSize="18" TextAlignment="Center"/>
                        </Grid>
                        <Grid Margin="0,5">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="60"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Cassette 3:" Foreground="White" FontSize="16" VerticalAlignment="Center"/>
                            <TextBox x:Name="TxtC3" Grid.Column="1" Text="0" FontSize="18" TextAlignment="Center"/>
                        </Grid>
                        <Grid Margin="0,5">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="60"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Cassette 4 (Bot):" Foreground="White" FontSize="16" VerticalAlignment="Center"/>
                            <TextBox x:Name="TxtC4" Grid.Column="1" Text="0" FontSize="18" TextAlignment="Center"/>
                        </Grid>

                        <Grid Margin="0,24,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Button x:Name="BtnTestDispense" Content="Test Dispense" Grid.Column="0" Margin="0,0,4,0" Height="50" Click="TestDispense_Click" IsEnabled="False" Background="#FFF59E0B"/>
                            <Button x:Name="BtnDispense" Content="💵 Dispense Cash" Grid.Column="1" Margin="4,0,0,0" Height="50" Click="Dispense_Click" IsEnabled="False" Background="#FF10B981" Foreground="White" FontWeight="Bold"/>
                        </Grid>
                    </StackPanel>
                </Border>
            </StackPanel>

            <Border Grid.Column="1" Background="#FF0B1220" BorderBrush="#223047" BorderThickness="1" CornerRadius="16" Padding="16" Margin="16,0,0,0">
                <TextBox x:Name="TxtLog" Background="Transparent" Foreground="#FF10B981" BorderThickness="0" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" IsReadOnly="True" FontFamily="Consolas"/>
            </Border>
        </Grid>
    </Grid>
</UserControl>