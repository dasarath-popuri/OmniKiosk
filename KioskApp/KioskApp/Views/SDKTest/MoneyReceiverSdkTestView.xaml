<UserControl x:Class="OmniKiosk.Wpf.Views.SDKTest.MoneyReceiverSdkTestView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Black"
             Loaded="UserControl_Loaded"
             Unloaded="UserControl_Unloaded">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <DockPanel Grid.Row="0" Margin="0,0,0,12">
            <Button Content="← Back" Width="120" Height="40" Click="Back_Click"/>
            <TextBlock Text="Money Receiver"
                       Foreground="White"
                       FontSize="26"
                       FontWeight="Bold"
                       VerticalAlignment="Center"
                       Margin="16,0,0,0"/>
        </DockPanel>

        <!-- Main -->
        <Border Grid.Row="1" BorderBrush="#334155" BorderThickness="2" CornerRadius="18" Padding="18">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Top Controls -->
                <Grid Grid.Row="0" Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="220"/>
                        <ColumnDefinition Width="240"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Port" Foreground="#CBD5E1" Margin="0,0,0,6"/>
                        <ComboBox x:Name="CmbPort" Height="38"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Margin="14,0,0,0">
                        <TextBlock Text="Target Amount (RM)" Foreground="#CBD5E1" Margin="0,0,0,6"/>
                        <TextBox x:Name="TxtTarget"
                                 Height="38"
                                 Text="0"
                                 Padding="10,6"
                                 FontSize="16"/>
                    </StackPanel>

                    <StackPanel Grid.Column="2" Margin="14,0,0,0">
                        <TextBlock Text="Status" Foreground="#CBD5E1" Margin="0,0,0,6"/>
                        <TextBlock x:Name="TxtStatus" Foreground="White" FontSize="16" Text="Idle"/>
                    </StackPanel>

                    <Button Grid.Column="3" Content="Open" Width="120" Height="46" Margin="12,18,0,0" Click="Open_Click"/>
                    <Button Grid.Column="4" Content="Close" Width="120" Height="46" Margin="10,18,0,0" Click="Close_Click"/>
                </Grid>

                <!-- Cards -->
                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Session Card -->
                    <Border Grid.Column="0" Background="#0F172A" CornerRadius="16" Padding="16" Margin="0,0,10,0">
                        <StackPanel>
                            <TextBlock Text="Session" Foreground="White" FontSize="18" FontWeight="Bold"/>

                            <Grid Margin="0,14,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <!--<StackPanel Grid.Column="0">
                                    <TextBlock Text="Total Accepted" Foreground="#94A3B8" Margin="0,0,0,4"/>
                                    <TextBlock x:Name="TxtTotal" Foreground="White" FontSize="36" FontWeight="Bold" Text="RM 0.00"/>
                                </StackPanel>-->

                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Total Accepted" Foreground="#94A3B8" Margin="0,0,0,4"/>
                                    <TextBlock x:Name="TxtTotal" Foreground="White" FontSize="36" FontWeight="Bold" Text="0.00" TextWrapping="Wrap"/>
                                </StackPanel>

                                <StackPanel Grid.Column="1" Margin="16,0,0,0">
                                    <TextBlock Text="Target" Foreground="#94A3B8" Margin="0,0,0,4"/>
                                    <TextBlock x:Name="TxtTargetLabel" Foreground="White" FontSize="20" FontWeight="Bold" Text="RM 0.00"/>
                                </StackPanel>
                            </Grid>

                            <ProgressBar x:Name="ProgTarget" Height="18" Margin="0,12,0,0"/>

                            <StackPanel Orientation="Horizontal" Margin="0,16,0,0">
                                <Button Content="Start Accept" Width="160" Height="46" Click="StartAccept_Click"/>
                                <Button Content="Stop" Width="120" Height="46" Margin="10,0,0,0" Click="StopAccept_Click"/>
                                <Button Content="Reset" Width="120" Height="46" Margin="10,0,0,0" Click="Reset_Click"/>
                            </StackPanel>

                            <TextBlock Text="Notes" Foreground="#94A3B8" Margin="0,18,0,6"/>
                            <ListBox x:Name="LstNotes" Height="220"/>
                        </StackPanel>
                    </Border>

                    <!-- Device Log Card -->
                    <Border Grid.Column="1" Background="#0F172A" CornerRadius="16" Padding="16" Margin="10,0,0,0">
                        <StackPanel>
                            <TextBlock Text="Device Log" Foreground="White" FontSize="18" FontWeight="Bold"/>
                            <TextBox x:Name="TxtLog"
                                     Margin="0,10,0,0"
                                     Height="330"
                                     IsReadOnly="True"
                                     TextWrapping="Wrap"
                                     VerticalScrollBarVisibility="Auto"/>
                        </StackPanel>
                    </Border>

                    <!-- Escrow Overlay -->
                    <Border x:Name="EscrowOverlay"
                            Grid.ColumnSpan="2"
                            Visibility="Collapsed"
                            Background="#CC000000"
                            CornerRadius="18">
                        <Border Background="#111827" CornerRadius="18"
                                Padding="22"
                                Width="540"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center">
                            <StackPanel>
                                <TextBlock Text="Note Detected"
                                           Foreground="White"
                                           FontSize="22"
                                           FontWeight="Bold"/>

                                <TextBlock x:Name="TxtEscrowValue"
                                           Margin="0,12,0,0"
                                           Foreground="White"
                                           FontSize="44"
                                           FontWeight="Bold"
                                           Text="RM 0.00"/>

                                <TextBlock x:Name="TxtEscrowHint"
                                           Margin="0,8,0,0"
                                           Foreground="#CBD5E1"
                                           Text="Accept this note?"/>

                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,18,0,0">
                                    <Button Content="Return" Width="140" Height="48" Click="EscrowReturn_Click"/>
                                    <Button Content="Accept" Width="170" Height="48" Margin="10,0,0,0" Click="EscrowStack_Click"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </Border>

                </Grid>
            </Grid>
        </Border>

        <!-- Footer -->
        <StackPanel Grid.Row="2" Margin="0,12,0,0">
            <TextBlock Text="Important: Build x86 (MPOST.dll is typically 32-bit)." Foreground="#94A3B8"/>
        </StackPanel>
    </Grid>
</UserControl>