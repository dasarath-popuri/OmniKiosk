<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Colors -->
    <Color x:Key="BgColor">#0B1220</Color>
    <Color x:Key="CardColor">#0F1724</Color>
    <Color x:Key="PrimaryColor">#60A5FA</Color>
    <!-- Lighter blue -->
    <Color x:Key="AccentColor">#06B6D4</Color>
    <Color x:Key="TextPrimary">#E6EEF8</Color>
    <Color x:Key="TextSecondary">#94A3B8</Color>
    <Color x:Key="Danger">#F87171</Color>

    <!-- Brushes -->
    <SolidColorBrush x:Key="BgBrush" Color="{StaticResource BgColor}"/>
    <SolidColorBrush x:Key="CardBrush" Color="{StaticResource CardColor}"/>
    <SolidColorBrush x:Key="PrimaryBrush" Color="{StaticResource PrimaryColor}"/>
    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource AccentColor}"/>
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource TextPrimary}"/>
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource TextSecondary}"/>
    <SolidColorBrush x:Key="DangerBrush" Color="{StaticResource Danger}"/>

    <!-- Sizes / Styles (mirror light) -->
    <Style TargetType="TextBlock" x:Key="CardTitle">
        <Setter Property="FontSize" Value="20"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
    </Style>

    <Style TargetType="TextBlock" x:Key="LabelSmall">
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
    </Style>

    <Style TargetType="Button" x:Key="PrimaryButton">
        <Setter Property="Background" Value="{StaticResource PrimaryBrush}"/>
        <Setter Property="Foreground" Value="Black"/>
        <Setter Property="FontSize" Value="16"/>
        <Setter Property="Height" Value="48"/>
        <Setter Property="Padding" Value="16,6"/>
        <Setter Property="BorderThickness" Value="0"/>
    </Style>

    <Style TargetType="TextBox" x:Key="InputBox">
        <Setter Property="Height" Value="44"/>
        <Setter Property="FontSize" Value="15"/>
        <Setter Property="Padding" Value="8"/>
        <Setter Property="Background" Value="#071524"/>
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
    </Style>

    <Style TargetType="ComboBox" x:Key="InputCombo">
        <Setter Property="Height" Value="44"/>
        <Setter Property="FontSize" Value="15"/>
        <Setter Property="Padding" Value="6"/>
        <Setter Property="Background" Value="#071524"/>
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
    </Style>

    <Style TargetType="Border" x:Key="CardBorder">
        <Setter Property="Background" Value="{StaticResource CardBrush}"/>
        <Setter Property="CornerRadius" Value="10"/>
        <Setter Property="Padding" Value="16"/>
        <Setter Property="Margin" Value="0,8,0,8"/>
    </Style>

</ResourceDictionary>
