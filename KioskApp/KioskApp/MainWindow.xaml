<Window x:Class="OmniKiosk.Wpf.MainWindow"
        x:Name="MainFrame"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        xmlns:loc="clr-namespace:OmniKiosk.Wpf.Helpers"
        Title="Vivo Money Kiosk"
        WindowState="Maximized"
        WindowStyle="None"
        Background="{StaticResource BackgroundBrush}"
        Loaded="Window_Loaded">

    <DockPanel>
        <Border Background="{StaticResource PrimaryBrush}" DockPanel.Dock="Top" Height="76">
            <Grid Margin="28,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="Vivo Money" FontFamily="{StaticResource DisplayFont}" FontSize="24" FontWeight="Bold" Foreground="White" VerticalAlignment="Center"/>

                <TextBlock x:Name="TxtWelcome" Grid.Column="1" Text="{loc:Loc WelcomeText}" VerticalAlignment="Center"
                           FontFamily="{StaticResource PrimaryFont}" FontSize="18" FontWeight="SemiBold"
                           Foreground="White" Opacity="0.85" TextAlignment="Center" HorizontalAlignment="Center"/>

                <Button x:Name="BtnCloseApp" Content="Close" Grid.Column="2" Width="90" Height="40"
                        Background="Transparent" Foreground="White" FontSize="15" FontWeight="SemiBold"
                        BorderBrush="White" BorderThickness="1.5" Cursor="Hand"
                        Click="BtnCloseApp_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="8">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>
        </Border>

        <Grid>
            <MediaElement x:Name="BackgroundVideo" LoadedBehavior="Manual" UnloadedBehavior="Stop"
                          Stretch="UniformToFill" IsMuted="True" MediaEnded="BackgroundVideo_MediaEnded"/>

            <!--<Border Background="#88121816"/>-->

            <!-- HOME / ATTRACT SCREEN -->
            <Grid x:Name="HomeScreen" Visibility="Visible">
                <Border VerticalAlignment="Bottom" HorizontalAlignment="Center" Margin="0,0,0,90"
                        Background="#CCFFFFFF" CornerRadius="18" Padding="48,22">
                    <StackPanel Orientation="Horizontal">
                        <Ellipse Width="14" Height="14" Fill="{StaticResource AccentGoldBrush}" VerticalAlignment="Center" Margin="0,0,16,0">
                            <Ellipse.Triggers>
                                <EventTrigger RoutedEvent="Ellipse.Loaded">
                                    <BeginStoryboard>
                                        <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                                            <DoubleAnimation Storyboard.TargetProperty="Opacity" From="1" To="0.25" Duration="0:0:1"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </EventTrigger>
                            </Ellipse.Triggers>
                        </Ellipse>
                        <TextBlock Text="{loc:Loc Home_TapToStart}" FontFamily="{StaticResource DisplayFont}" FontSize="16" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Bottom"/>
                    </StackPanel>
                </Border>
            </Grid>

            <Border x:Name="TapCatcher" Background="Transparent" MouseDown="TapCatcher_MouseDown" Visibility="Visible"/>

            <!-- LANGUAGE SELECTION SCREEN -->
            <Grid x:Name="LanguageSelectionScreen" Background="{StaticResource BackgroundBrush}" Visibility="Collapsed">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Margin="40">

                    <TextBlock Text="{loc:Loc LanguageSelection_Title}" Style="{StaticResource HeaderText}" TextAlignment="Center" HorizontalAlignment="Center"/>
                    <TextBlock Text="{loc:Loc LanguageSelection_Subtitle}" Foreground="{StaticResource TextSecondaryBrush}" FontSize="{StaticResource FontSizeNormal}" TextAlignment="Center" HorizontalAlignment="Center" Margin="0,8,0,48"/>

                    <WrapPanel HorizontalAlignment="Center" Orientation="Horizontal">

                        <Button x:Name="BtnEnglish" Click="BtnEnglish_Click" Width="420" Height="280" Margin="20,0" Cursor="Hand" Background="Transparent" BorderThickness="0">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="Bd" Style="{StaticResource Card}" Padding="0">
                                        <StackPanel VerticalAlignment="Center">
                                            <TextBlock Text="English" FontFamily="{StaticResource DisplayFont}" FontSize="40" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}" HorizontalAlignment="Center"/>
                                            <TextBlock Text="Malaysia &amp; International" FontSize="15" Foreground="{StaticResource TextSecondaryBrush}" HorizontalAlignment="Center" Margin="0,8,0,0"/>
                                        </StackPanel>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Bd" Property="Background" Value="{StaticResource PrimarySurfaceBrush}"/>
                                            <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource PrimaryBrush}"/>
                                            <Setter TargetName="Bd" Property="BorderThickness" Value="2.5"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                        <Button x:Name="BtnMalay" Click="BtnMalay_Click" Width="420" Height="280" Margin="20,0" Cursor="Hand" Background="Transparent" BorderThickness="0">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="Bd" Style="{StaticResource Card}" Padding="0">
                                        <StackPanel VerticalAlignment="Center">
                                            <TextBlock Text="Bahasa Melayu" FontFamily="{StaticResource DisplayFont}" FontSize="36" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}" HorizontalAlignment="Center" TextAlignment="Center"/>
                                            <TextBlock Text="Malaysia" FontSize="15" Foreground="{StaticResource TextSecondaryBrush}" HorizontalAlignment="Center" Margin="0,8,0,0"/>
                                        </StackPanel>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Bd" Property="Background" Value="{StaticResource PrimarySurfaceBrush}"/>
                                            <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource PrimaryBrush}"/>
                                            <Setter TargetName="Bd" Property="BorderThickness" Value="2.5"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                    </WrapPanel>
                </StackPanel>
            </Grid>

            <!-- MAIN MENU SCREEN -->
            <Grid x:Name="MenuScreen" Visibility="Collapsed" Background="{StaticResource BackgroundBrush}">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel MaxWidth="1400" Margin="40" HorizontalAlignment="Center">

                        <StackPanel Margin="0,20,0,48" HorizontalAlignment="Center">
                            <TextBlock x:Name="TxtMainMenu" Text="{loc:Loc MainMenu}" Style="{StaticResource HeaderText}" HorizontalAlignment="Center"/>
                            <TextBlock x:Name="SelectMenu" Text="{loc:Loc SelectMenu}" FontSize="{StaticResource FontSizeNormal}" Foreground="{StaticResource TextSecondaryBrush}" HorizontalAlignment="Center" Margin="0,8,0,0"/>
                        </StackPanel>

                        <WrapPanel HorizontalAlignment="Center" Orientation="Horizontal">

                            <!-- 1. Send Money - Gold Border, Green Accents -->
                            <Border Width="380" Height="360" Margin="14" Style="{StaticResource Card}" BorderBrush="{StaticResource AccentGoldBrush}" BorderThickness="2" Cursor="Hand" MouseDown="OpenRemittance_Click">
                                <StackPanel VerticalAlignment="Center">
                                    <Border Width="88" Height="88" CornerRadius="44" Background="{StaticResource PrimarySurfaceBrush}" HorizontalAlignment="Center" Margin="0,0,0,24">
                                        <TextBlock Text="💸" FontSize="42" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <TextBlock x:Name="BtnSM" Text="{loc:Loc SendMoney}" FontFamily="{StaticResource DisplayFont}" FontSize="28" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                                    <TextBlock x:Name="SMLblTxt" Text="{loc:Loc SMLblTxt}" FontSize="16" Foreground="{StaticResource TextSecondaryBrush}" TextWrapping="Wrap" TextAlignment="Center" Margin="0,0,0,20"/>
                                    <Border Background="{StaticResource PrimaryBrush}" CornerRadius="10" Padding="24,10" HorizontalAlignment="Center">
                                        <TextBlock x:Name="StartTxt" Text="{loc:Loc StartTxt}" FontSize="16" FontWeight="Bold" Foreground="White"/>
                                    </Border>
                                </StackPanel>
                            </Border>

                            <!-- 2. Money Exchange - Gold Border, Gold Accents -->
                            <Border Width="380" Height="360" Margin="14" Style="{StaticResource Card}" BorderBrush="{StaticResource AccentGoldBrush}" BorderThickness="2" Cursor="Hand" MouseDown="OpenMoneyExchange_Click">
                                <StackPanel VerticalAlignment="Center">
                                    <Border Width="88" Height="88" CornerRadius="44" Background="{StaticResource AccentGoldLightBrush}" HorizontalAlignment="Center" Margin="0,0,0,24">
                                        <TextBlock Text="💵" FontSize="42" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <TextBlock x:Name="BtnMoneyExchange" Text="{loc:Loc MoneyExchange}" FontFamily="{StaticResource DisplayFont}" FontSize="28" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                                    <TextBlock Text="{loc:Loc MoneyExchangeDesc}" FontSize="16" Foreground="{StaticResource TextSecondaryBrush}" TextWrapping="Wrap" TextAlignment="Center" Margin="0,0,0,20"/>
                                    <Border Background="{StaticResource AccentGoldBrush}" CornerRadius="10" Padding="24,10" HorizontalAlignment="Center">
                                        <TextBlock Text="{loc:Loc StartTxt}" FontSize="16" FontWeight="Bold" Foreground="White"/>
                                    </Border>
                                </StackPanel>
                            </Border>

                            <!-- 3. Queue pre-booking - Gold Border, Green Accents -->
                            <Border Width="380" Height="360" Margin="14" Style="{StaticResource Card}" BorderBrush="{StaticResource AccentGoldBrush}" BorderThickness="2" Cursor="Hand" MouseDown="BtnQueueX_Click">
                                <StackPanel VerticalAlignment="Center">
                                    <Border Width="88" Height="88" CornerRadius="44" Background="{StaticResource PrimarySurfaceBrush}" HorizontalAlignment="Center" Margin="0,0,0,24">
                                        <TextBlock Text="🎫" FontSize="42" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <TextBlock x:Name="BtnQueueX" Text="{loc:Loc QueueXchange}" FontFamily="{StaticResource DisplayFont}" FontSize="26" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}" HorizontalAlignment="Center" TextAlignment="Center" Margin="0,0,0,10"/>
                                    <TextBlock x:Name="MCLblTxt" Text="{loc:Loc MCLblTxt}" FontSize="16" Foreground="{StaticResource TextSecondaryBrush}" TextWrapping="Wrap" TextAlignment="Center" Margin="0,0,0,20"/>
                                    <Border Background="{StaticResource PrimaryBrush}" CornerRadius="10" Padding="24,10" HorizontalAlignment="Center">
                                        <TextBlock x:Name="StartTxt1" Text="{loc:Loc StartTxt}" FontSize="16" FontWeight="Bold" Foreground="White"/>
                                    </Border>
                                </StackPanel>
                            </Border>

                            <!-- 4. Browse products - Gold Border, Gold Accents -->
                            <Border Width="380" Height="360" Margin="14" Style="{StaticResource Card}" BorderBrush="{StaticResource AccentGoldBrush}" BorderThickness="2" Cursor="Hand" MouseDown="BtnOmni_Click">
                                <StackPanel VerticalAlignment="Center">
                                    <Border Width="88" Height="88" CornerRadius="44" Background="{StaticResource AccentGoldLightBrush}" HorizontalAlignment="Center" Margin="0,0,0,24">
                                        <TextBlock Text="🌐" FontSize="42" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <TextBlock x:Name="BtnOmni" Text="{loc:Loc VisitOmni}" FontFamily="{StaticResource DisplayFont}" FontSize="28" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                                    <TextBlock x:Name="BrowseTxt" Text="{loc:Loc BrowseTxt}" FontSize="16" Foreground="{StaticResource TextSecondaryBrush}" TextWrapping="Wrap" TextAlignment="Center" Margin="0,0,0,20"/>
                                    <Border Background="{StaticResource AccentGoldBrush}" CornerRadius="10" Padding="24,10" HorizontalAlignment="Center">
                                        <TextBlock x:Name="BTxt" Text="{loc:Loc BTxt}" FontSize="16" FontWeight="Bold" Foreground="White"/>
                                    </Border>
                                </StackPanel>
                            </Border>

                            <!-- 5. Today's rates - Gold Border, Green Accents -->
                            <Border Width="380" Height="360" Margin="14" Style="{StaticResource Card}" BorderBrush="{StaticResource AccentGoldBrush}" BorderThickness="2" Cursor="Hand" MouseDown="BtnRateBoard_Click">
                                <StackPanel VerticalAlignment="Center">
                                    <Border Width="88" Height="88" CornerRadius="44" Background="{StaticResource PrimarySurfaceBrush}" HorizontalAlignment="Center" Margin="0,0,0,24">
                                        <TextBlock Text="💱" FontSize="42" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <TextBlock x:Name="BtnRates" Text="{loc:Loc RatesToday}" FontFamily="{StaticResource DisplayFont}" FontSize="28" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                                    <TextBlock x:Name="RatesTxt" Text="{loc:Loc RatesTxt}" FontSize="16" Foreground="{StaticResource TextSecondaryBrush}" TextWrapping="Wrap" TextAlignment="Center" Margin="0,0,0,20"/>
                                    <Border Background="{StaticResource PrimaryBrush}" CornerRadius="10" Padding="24,10" HorizontalAlignment="Center">
                                        <TextBlock x:Name="ViewRateTxt" Text="{loc:Loc ViewRateTxt}" FontSize="16" FontWeight="Bold" Foreground="White"/>
                                    </Border>
                                </StackPanel>
                            </Border>

                            <!-- 6. Test SDKs - Gold Border, De-emphasized -->
                            <Border Width="380" Height="360" Margin="14" Style="{StaticResource Card}" BorderBrush="{StaticResource AccentGoldBrush}" BorderThickness="2" Opacity="0.7" Cursor="Hand" MouseDown="OpenTest_Click">
                                <StackPanel VerticalAlignment="Center">
                                    <Border Width="88" Height="88" CornerRadius="44" Background="{StaticResource BackgroundBrush}" HorizontalAlignment="Center" Margin="0,0,0,24">
                                        <TextBlock Text="🛠️" FontSize="42" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <TextBlock x:Name="BtnTest" FontFamily="{StaticResource DisplayFont}" FontSize="24" FontWeight="Bold" Foreground="{StaticResource TextSecondaryBrush}" HorizontalAlignment="Center" Margin="0,0,0,10" Text="Test SDKs"/>
                                    <TextBlock x:Name="SMLblTxts" Text="Hardware testing environment" FontSize="15" Foreground="{StaticResource TextSecondaryBrush}" TextWrapping="Wrap" TextAlignment="Center" Margin="0,0,0,14"/>
                                    <TextBlock x:Name="Test" Text="TEST" FontSize="13" FontWeight="Bold" Foreground="{StaticResource TextSecondaryBrush}" HorizontalAlignment="Center" Visibility="Collapsed"/>
                                </StackPanel>
                            </Border>

                        </WrapPanel>

                        <Button x:Name="BtnNavClose" Content="{loc:Loc Back}" Style="{StaticResource OutlineButton}" Width="280" Margin="0,44,0,20" HorizontalAlignment="Center" Click="BtnNavClose_Click"/>
                    </StackPanel>
                </ScrollViewer>
            </Grid>
            
            <Grid x:Name="SdkHostScreen" Visibility="Collapsed">
                <ContentControl x:Name="SdkHostContent" />
            </Grid>

            <!-- Money Exchange Flow Host -->
            <Grid x:Name="MoneyExchangeHostScreen" Visibility="Collapsed" Background="Black">
                <ContentControl x:Name="MoneyExchangeHostContent"/>
            </Grid>

            <!-- WEBVIEW SCREEN -->
            <Grid x:Name="WebViewScreen" Visibility="Collapsed">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <wv2:WebView2 x:Name="WebView" Grid.Row="1" Source="about:blank"/>
            </Grid>

        </Grid>

    </DockPanel>
</Window>
