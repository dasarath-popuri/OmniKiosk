<Application x:Class="OmniKiosk.Wpf.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Themes/ThemeLight.xaml"/>
                <ResourceDictionary Source="Themes/ThemeDark.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <!-- ADD THESE VALIDATION STYLES -->
            <!--<Style x:Key="ValidationBorder" TargetType="Border">
