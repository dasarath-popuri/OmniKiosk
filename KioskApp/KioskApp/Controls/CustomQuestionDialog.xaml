<Window x:Class="OmniKiosk.Wpf.Controls.CustomQuestionDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title=""
        Height="Auto"
        Width="550"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        SizeToContent="Height">

    <Border Background="White"
            CornerRadius="20"
            Padding="40"
            BorderThickness="0">
        <Border.Effect>
            <DropShadowEffect BlurRadius="30" ShadowDepth="0" Opacity="0.4" Color="#000000"/>
        </Border.Effect>

        <StackPanel>
            <!-- Icon -->
            <Border Width="90" Height="90"
                    Background="White"
                    CornerRadius="45"
                    Margin="0,0,0,24"
                    HorizontalAlignment="Center">
                <TextBlock Text="⚠"
                         FontSize="52"
                         Foreground="DarkOrange"
                         HorizontalAlignment="Center"
                         VerticalAlignment="Center"
                         FontWeight="Bold"/>
            </Border>

            <!-- Title -->
            <TextBlock x:Name="TitleText"
                     Text="Confirm Action"
                     FontSize="28"
                     FontWeight="Bold"
                     Foreground="#1F2937"
                     HorizontalAlignment="Center"
                     TextWrapping="Wrap"
                     TextAlignment="Center"
                     Margin="0,0,0,16"/>

            <!-- Message -->
            <TextBlock x:Name="MessageText"
                     Text="Are you sure you want to proceed?"
                     FontSize="17"
                     Foreground="#6B7280"
                     TextAlignment="Center"
                     TextWrapping="Wrap"
                     LineHeight="26"
                     MaxWidth="450"
                     Margin="0,0,0,36"/>

            <!-- Yes Button -->
            <Button x:Name="YesButton"
                    Content="Yes, Proceed"
                    Background="#2563EB"
                    Foreground="White"
                    FontSize="20"
                    FontWeight="Bold"
                    Height="64"
                    BorderThickness="0"
                    Cursor="Hand"
                    Margin="0,0,0,0"
                    Click="YesButton_Click">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}"
                                            CornerRadius="12"
                                            BorderThickness="0">
                                        <ContentPresenter HorizontalAlignment="Center" 
                                                        VerticalAlignment="Center"
                                                        Content="{TemplateBinding Content}"/>
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#1D4ED8"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>

            <!-- No Button -->
            <Button x:Name="NoButton"
                    Content="No, Cancel"
                    Background="Red"
                    Foreground="White"
                    FontSize="20"
                    FontWeight="SemiBold"
                    Height="64"
                    BorderThickness="2"
                    BorderBrush="#E5E7EB"
                    Cursor="Hand"
                    Margin="0,12,0,0"
                    Click="NoButton_Click">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}"
                                            BorderBrush="{TemplateBinding BorderBrush}"
                                            BorderThickness="{TemplateBinding BorderThickness}"
                                            CornerRadius="12">
                                        <ContentPresenter HorizontalAlignment="Center" 
                                                        VerticalAlignment="Center"
                                                        Content="{TemplateBinding Content}"/>
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#F3F4F6"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>
        </StackPanel>
    </Border>
</Window>