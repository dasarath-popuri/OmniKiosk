<Window x:Class="OmniKiosk.Wpf.Controls.CustomTermsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title=""
        WindowStyle="None"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="Transparent"
        AllowsTransparency="True"
        Width="900"
        Height="700"
        Topmost="True"
        ShowInTaskbar="False">

    <Border Background="White"
            CornerRadius="24"
            Padding="40"
            BorderThickness="0">
        <Border.Effect>
            <DropShadowEffect BlurRadius="40" ShadowDepth="0" Opacity="0.3" Color="#000000"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <StackPanel Grid.Row="0" Margin="0,0,0,24">
                <Border Background="#FEF3C7"
                        CornerRadius="16"
                        Width="80"
                        Height="80"
                        HorizontalAlignment="Center"
                        Margin="0,0,0,20">
                    <TextBlock Text="📜"
                               FontSize="48"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                </Border>

                <TextBlock Text="Terms and Conditions"
                           FontSize="32"
                           FontWeight="Bold"
                           Foreground="#1E293B"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,8"/>

                <TextBlock Text="Please read carefully and accept to continue"
                           FontSize="16"
                           Foreground="#64748B"
                           HorizontalAlignment="Center"/>
            </StackPanel>

            <!-- Terms Content -->
            <Border Grid.Row="1"
                    Background="#F8FAFC"
                    CornerRadius="16"
                    Padding="32"
                    Margin="0,0,0,24">
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <StackPanel>
                        <!-- Regulatory Section -->
                        <!--<TextBlock Text="Regulatory Compliance"
                                   FontSize="20"
                                   FontWeight="Bold"
                                   Foreground="#1E293B"
                                   Margin="0,0,0,16"/>

                        <StackPanel Margin="0,0,0,24">
                            <Border Background="White"
                                    CornerRadius="12"
                                    Padding="16"
                                    Margin="0,0,0,12">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Background="#EFF6FF"
                                            CornerRadius="8"
                                            Width="32"
                                            Height="32"
                                            Margin="0,0,16,0">
                                        <TextBlock Text="🏛️"
                                                   FontSize="18"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                    </Border>
                                    <TextBlock Grid.Column="1"
                                               Text="This transaction is subject to Bank Negara Malaysia (BNM) regulations"
                                               FontSize="15"
                                               Foreground="#1E293B"
                                               TextWrapping="Wrap"
                                               VerticalAlignment="Center"
                                               LineHeight="24"/>
                                </Grid>
                            </Border>

                            <Border Background="White"
                                    CornerRadius="12"
                                    Padding="16"
                                    Margin="0,0,0,12">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Background="#FEF3C7"
                                            CornerRadius="8"
                                            Width="32"
                                            Height="32"
                                            Margin="0,0,16,0">
                                        <TextBlock Text="⚠️"
                                                   FontSize="18"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                    </Border>
                                    <TextBlock Grid.Column="1"
                                               Text="We are required to report suspicious transactions to relevant authorities"
                                               FontSize="15"
                                               Foreground="#1E293B"
                                               TextWrapping="Wrap"
                                               VerticalAlignment="Center"
                                               LineHeight="24"/>
                                </Grid>
                            </Border>
                        </StackPanel>-->

                        <!-- Transfer Details Section -->
                        <!--<TextBlock Text="Transfer Details"
                                   FontSize="20"
                                   FontWeight="Bold"
                                   Foreground="#1E293B"
                                   Margin="0,0,0,16"/>-->

                        <StackPanel Margin="0,0,0,24">
                            <Border Background="White"
                                    CornerRadius="12"
                                    Padding="16"
                                    Margin="0,0,0,12">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Background="#ECFDF5"
                                            CornerRadius="8"
                                            Width="32"
                                            Height="32"
                                            Margin="0,0,16,0">
                                        <TextBlock Text="⏱️"
                                                   FontSize="18"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                    </Border>
                                    <TextBlock Grid.Column="1"
                                               Text="Transfer completion time varies by destination country (1-3 business days)"
                                               FontSize="15"
                                               Foreground="#1E293B"
                                               TextWrapping="Wrap"
                                               VerticalAlignment="Center"
                                               LineHeight="24"/>
                                </Grid>
                            </Border>

                            <Border Background="White"
                                    CornerRadius="12"
                                    Padding="16"
                                    Margin="0,0,0,12">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Background="#FEF2F2"
                                            CornerRadius="8"
                                            Width="32"
                                            Height="32"
                                            Margin="0,0,16,0">
                                        <TextBlock Text="📅"
                                                   FontSize="18"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                    </Border>
                                    <TextBlock Grid.Column="1"
                                               Text="Delays may occur due to bank holidays or regulatory checks"
                                               FontSize="15"
                                               Foreground="#1E293B"
                                               TextWrapping="Wrap"
                                               VerticalAlignment="Center"
                                               LineHeight="24"/>
                                </Grid>
                            </Border>

                            <Border Background="White"
                                    CornerRadius="12"
                                    Padding="16">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Background="#EFF6FF"
                                            CornerRadius="8"
                                            Width="32"
                                            Height="32"
                                            Margin="0,0,16,0">
                                        <TextBlock Text="🧾"
                                                   FontSize="18"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                    </Border>
                                    <TextBlock Grid.Column="1"
                                               Text="Keep your transaction receipt for your records"
                                               FontSize="15"
                                               Foreground="#1E293B"
                                               TextWrapping="Wrap"
                                               VerticalAlignment="Center"
                                               LineHeight="24"/>
                                </Grid>
                            </Border>
                        </StackPanel>

                        <!-- Your Confirmation Section -->
                        <Border Background="#FEF3C7"
                                CornerRadius="16"
                                Padding="24"
                                Margin="0,0,0,0">
                            <StackPanel>
                                <TextBlock Text="By clicking 'I Accept', you confirm that:"
                                           FontSize="18"
                                           FontWeight="Bold"
                                           Foreground="#92400E"
                                           Margin="0,0,0,16"/>

                                <StackPanel>
                                    <Grid Margin="0,0,0,12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="✓"
                                                   FontSize="20"
                                                   FontWeight="Bold"
                                                   Foreground="#F59E0B"
                                                   Margin="0,0,12,0"/>
                                        <TextBlock Grid.Column="1"
                                                   Text="All information provided is true and accurate"
                                                   FontSize="15"
                                                   Foreground="#92400E"
                                                   TextWrapping="Wrap"
                                                   VerticalAlignment="Center"
                                                   LineHeight="24"/>
                                    </Grid>

                                    <Grid Margin="0,0,0,12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="✓"
                                                   FontSize="20"
                                                   FontWeight="Bold"
                                                   Foreground="#F59E0B"
                                                   Margin="0,0,12,0"/>
                                        <TextBlock Grid.Column="1"
                                                   Text="You have read and understood these terms"
                                                   FontSize="15"
                                                   Foreground="#92400E"
                                                   TextWrapping="Wrap"
                                                   VerticalAlignment="Center"
                                                   LineHeight="24"/>
                                    </Grid>

                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="✓"
                                                   FontSize="20"
                                                   FontWeight="Bold"
                                                   Foreground="#F59E0B"
                                                   Margin="0,0,12,0"/>
                                        <TextBlock Grid.Column="1"
                                                   Text="You agree to comply with all applicable regulations"
                                                   FontSize="15"
                                                   Foreground="#92400E"
                                                   TextWrapping="Wrap"
                                                   VerticalAlignment="Center"
                                                   LineHeight="24"/>
                                    </Grid>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <!-- Buttons -->
            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Decline Button -->
                <Button x:Name="DeclineButton"
                        Grid.Column="0"
                        Content="I Decline"
                        Height="70"
                        FontSize="20"
                        FontWeight="Bold"
                        Foreground="#64748B"
                        Background="White"
                        BorderBrush="#E2E8F0"
                        BorderThickness="2"
                        Cursor="Hand"
                        Click="DeclineButton_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="border"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="12"
                                    Padding="30,0">
                                <ContentPresenter HorizontalAlignment="Center" 
                                                VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="border" Property="Background" Value="#F8FAFC"/>
                                    <Setter TargetName="border" Property="BorderBrush" Value="#CBD5E1"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <!-- Accept Button -->
                <Button x:Name="AcceptButton"
                        Grid.Column="2"
                        Content="✓ I Accept"
                        Height="70"
                        FontSize="20"
                        FontWeight="Bold"
                        Foreground="White"
                        Background="#10B981"
                        BorderThickness="0"
                        Cursor="Hand"
                        Click="AcceptButton_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="border"
                                    Background="{TemplateBinding Background}"
                                    CornerRadius="12"
                                    Padding="30,0">
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="20" ShadowDepth="0" Opacity="0.3" Color="#10B981"/>
                                </Border.Effect>
                                <ContentPresenter HorizontalAlignment="Center" 
                                                VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="border" Property="Background" Value="#059669"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>
        </Grid>
    </Border>
</Window>