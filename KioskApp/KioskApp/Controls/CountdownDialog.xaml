<Window x:Class="OmniKiosk.Wpf.Controls.CountdownDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="Transparent"
        AllowsTransparency="True"
        Width="700"
        Height="Auto"
        SizeToContent="Height">

    <Border Background="White"
            CornerRadius="24"
            Padding="50">
        <Border.Effect>
            <DropShadowEffect BlurRadius="40" ShadowDepth="0" Opacity="0.3" Color="#000000"/>
        </Border.Effect>

        <StackPanel>
            <!-- Timer Circle -->
            <Border Width="120" Height="120"
                    CornerRadius="60"
                    Background="#F59E0B"
                    HorizontalAlignment="Center"
                    Margin="0,0,0,30">
                <Viewbox Width="80" Height="80">
                    <TextBlock x:Name="CountdownText"
                               Text="20"
                               FontSize="48"
                               FontWeight="Bold"
                               Foreground="White"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                </Viewbox>
            </Border>

            <!-- Title -->
            <TextBlock Text="⏱️ Session Timeout Warning"
                       FontSize="32"
                       FontWeight="Bold"
                       Foreground="#1E293B"
                       TextAlignment="Center"
                       Margin="0,0,0,20"
                       TextWrapping="Wrap"/>

            <!-- Message -->
            <TextBlock x:Name="MessageText"
                       FontSize="18"
                       Foreground="#64748B"
                       TextAlignment="Center"
                       TextWrapping="Wrap"
                       Margin="0,0,0,40"
                       LineHeight="28">
                <Run Text="Your session will expire in "/>
                <Run x:Name="SecondsText" Text="20" FontWeight="Bold" Foreground="#F59E0B"/>
                <Run Text=" seconds due to inactivity."/>
                <LineBreak/>
                <LineBreak/>
                <Run Text="Would you like to continue your transaction?"/>
            </TextBlock>

            <!-- Buttons -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Go Back Button -->
                <Button x:Name="GoBackButton"
                        Grid.Column="0"
                        Content="Go Back"
                        Height="70"
                        FontSize="20"
                        FontWeight="Bold"
                        Foreground="#64748B"
                        Background="White"
                        BorderBrush="#E2E8F0"
                        BorderThickness="2"
                        Cursor="Hand"
                        Click="GoBackButton_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="border"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="12"
                                    Padding="30,0">
                                <ContentPresenter HorizontalAlignment="Center" 
                                                VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="border" Property="Background" Value="#F8FAFC"/>
                                    <Setter TargetName="border" Property="BorderBrush" Value="#CBD5E1"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <!-- Stay Here Button -->
                <Button x:Name="StayHereButton"
                        Grid.Column="2"
                        Content="Stay Here"
                        Height="70"
                        FontSize="20"
                        FontWeight="Bold"
                        Foreground="White"
                        Background="#10B981"
                        BorderThickness="0"
                        Cursor="Hand"
                        Click="StayHereButton_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="border"
                                    Background="{TemplateBinding Background}"
                                    CornerRadius="12"
                                    Padding="30,0">
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="20" ShadowDepth="0" Opacity="0.3" Color="#10B981"/>
                                </Border.Effect>
                                <ContentPresenter HorizontalAlignment="Center" 
                                                VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="border" Property="Background" Value="#059669"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>
        </StackPanel>
    </Border>
</Window>